internal pointer fileargs_cinit(
    casper: internal pointer,
    argc_value: internal int,
    argv_value: internal charpp,
    oflags: internal int,
    mode: internal mode_t,
    rights: internal pointer,
    flags: internal int
):
    if LIBC_FILEARGS == 0 then
        fileargs = libc_singleton(0, 8)
        LIBC_FILEARGS = reinterpret(i64, fileargs)
    end
    if LIBC_FILEARGS != 0 then
        poke32(LIBC_FILEARGS, 0, flags)
    end
    return reinterpret(pointer, LIBC_FILEARGS)
end

internal pointer cap_net_limit_init(channel: internal pointer, flags: internal int):
