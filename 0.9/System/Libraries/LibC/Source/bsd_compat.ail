def libc_c_strlen(source_addr: i64): i64
    if source_addr == 0 then
        return 0
    end
    n = 0
    while peek8(source_addr, n) != 0 then
        n = n + 1
    end
    return n
end

def libc_vis_copy(dst_addr: i64, dstlen: i64, src_addr: i64, srclen: i64): i64
    if dst_addr == 0 or src_addr == 0 then
        errno_set(EINVAL_VALUE)
        return -1
    end

    if dstlen != 0 then
        n = srclen
        if n > dstlen - 1 then
            n = dstlen - 1
        end
        if n > 0 then
            memcpy(dst_addr, src_addr, n)
        end
        poke8(dst_addr, n, 0)
    end

    return srclen
end

internal charptr vis(
    dst: internal charptr,
    c: internal int,
    flag: internal int,
    nextc: internal int
):
    dst_addr = reinterpret(i64, dst)
    if dst_addr == 0 then
        return reinterpret(pointer, 0)
    end
    poke8(dst_addr, 0, c)
    poke8(dst_addr, 1, 0)
    return reinterpret(pointer, ptr_add(dst_addr, 1))
end

internal int strvis(dst: internal charptr, src: internal cstring, flag: internal int):
    src_addr = reinterpret(i64, src)
    return libc_vis_copy(reinterpret(i64, dst), libc_c_strlen(src_addr) + 1, src_addr, libc_c_strlen(src_addr))
end

internal int strnvis(
    dst: internal charptr,
    src: internal cstring,
    dstlen: internal size_t,
    flag: internal int
):
    src_addr = reinterpret(i64, src)
    return libc_vis_copy(reinterpret(i64, dst), dstlen, src_addr, libc_c_strlen(src_addr))
end

internal int strvisx(
    dst: internal charptr,
    src: internal cstring,
    srclen: internal size_t,
    flag: internal int
):
    return libc_vis_copy(reinterpret(i64, dst), srclen + 1, reinterpret(i64, src), srclen)
end

internal int strnvisx(
    dst: internal charptr,
    src: internal cstring,
    srclen: internal size_t,
    dstlen: internal size_t,
    flag: internal int
):
    return libc_vis_copy(reinterpret(i64, dst), dstlen, reinterpret(i64, src), srclen)
end

internal int stravis(out: internal charpp, src: internal cstring, flag: internal int):
    out_addr = reinterpret(i64, out)
    src_addr = reinterpret(i64, src)
    if out_addr == 0 or src_addr == 0 then
        errno_set(EINVAL_VALUE)
        return -1
    end

    src_len = libc_c_strlen(src_addr)
    copy_addr = alloc(src_len + 1)
    if copy_addr == 0 then
        errno_set(ENOMEM_VALUE)
        return -1
    end
    memcpy(copy_addr, src_addr, src_len + 1)
    poke64(out_addr, 0, copy_addr)
    return src_len
end

internal int stravisx(
    out: internal charpp,
    src: internal cstring,
    srclen: internal size_t,
    flag: internal int
):
    out_addr = reinterpret(i64, out)
    src_addr = reinterpret(i64, src)
    if out_addr == 0 or src_addr == 0 then
        errno_set(EINVAL_VALUE)
        return -1
    end

    copy_addr = alloc(srclen + 1)
    if copy_addr == 0 then
        errno_set(ENOMEM_VALUE)
        return -1
    end
    if srclen > 0 then
        memcpy(copy_addr, src_addr, srclen)
    end
    poke8(copy_addr, srclen, 0)
    poke64(out_addr, 0, copy_addr)
    return srclen
end

internal int strunvis(dst: internal charptr, src: internal cstring):
    src_addr = reinterpret(i64, src)
    return libc_vis_copy(reinterpret(i64, dst), libc_c_strlen(src_addr) + 1, src_addr, libc_c_strlen(src_addr))
end

internal int strnunvis(
    dst: internal charptr,
    src: internal cstring,
    dstlen: internal size_t
):
    src_addr = reinterpret(i64, src)
    return libc_vis_copy(reinterpret(i64, dst), dstlen, src_addr, libc_c_strlen(src_addr))
end

internal int unvis(
    cp: internal charptr,
    c: internal int,
    astate: internal intp,
    flag: internal int
):
    cp_addr = reinterpret(i64, cp)
    if cp_addr != 0 then
        poke8(cp_addr, 0, c)
    end
    return 1
end

