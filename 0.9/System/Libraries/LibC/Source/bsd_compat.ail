internal int mac_prepare_file_label(label: internal charpp):
    label_addr = reinterpret(i64, label)
    if label_addr == 0 then
        errno_set(EINVAL_VALUE)
        return -1
    end
    text = libc_dash_string()
    text_addr = reinterpret(i64, text)
    if text_addr == 0 then
        errno_set(ENOMEM_VALUE)
        return -1
    end
    poke64(label_addr, 0, text_addr)
    return 0
end

