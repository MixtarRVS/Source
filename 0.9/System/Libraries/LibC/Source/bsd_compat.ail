internal pointer cap_init():
    if LIBC_CAP_CHANNEL == 0 then
        channel = libc_singleton(0, 8)
        LIBC_CAP_CHANNEL = reinterpret(i64, channel)
    end
    return reinterpret(pointer, LIBC_CAP_CHANNEL)
end

