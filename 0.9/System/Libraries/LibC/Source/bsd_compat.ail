// bsd_compat.ail
// AILang-owned BSD/POSIX compatibility shims used by the Toolkit bridge.
//
// Scope: simple callable adapters that previously lived as static inline C in
// mixtar_bridge_compat.h. Compile-time macros/types remain in the C header.

#cinclude <sys/types.h>
#cinclude <pwd.h>
#cinclude <grp.h>

extern fn setpwent(): void
extern fn setgrent(): void

const int EINVAL_VALUE = 22
const int ENOMEM_VALUE = 12
const int ENOTSUP_VALUE = 95
const int EOPNOTSUPP_VALUE = 95
const int ENOSYS_VALUE = 38
const int SIZE_MAX_SAFE = 9223372036854775807

const int S_IFMT_VALUE = 61440
const int S_IFDIR_VALUE = 16384
const int S_IFCHR_VALUE = 8192
const int S_IFBLK_VALUE = 24576
const int S_IFIFO_VALUE = 4096
const int S_IFLNK_VALUE = 40960
const int S_IFSOCK_VALUE = 49152

const int S_IRUSR_VALUE = 256
const int S_IWUSR_VALUE = 128
const int S_IXUSR_VALUE = 64
const int S_IRGRP_VALUE = 32
const int S_IWGRP_VALUE = 16
const int S_IXGRP_VALUE = 8
const int S_IROTH_VALUE = 4
const int S_IWOTH_VALUE = 2
const int S_IXOTH_VALUE = 1
const int S_IRWXU_VALUE = 448
const int S_IRWXG_VALUE = 56
const int S_IRWXO_VALUE = 7
const int S_ISUID_VALUE = 2048
const int S_ISGID_VALUE = 1024
const int S_ISVTX_VALUE = 512
const int MODE_LOW_MASK_VALUE = 4095
const int MODE_BLOB_SIZE = 160
const int MODE_BLOB_MODE_SLOT = 0
const int MODE_BLOB_SYMBOLIC_SLOT = 1
const int MODE_BLOB_TEXT_OFFSET = 16
const int MODE_TEXT_MAX = 127

static int LIBC_GETBSIZE_HEADER = 0
static int LIBC_STRTONUM_INVALID = 0
static int LIBC_STRTONUM_TOO_SMALL = 0
static int LIBC_STRTONUM_TOO_LARGE = 0
static int LIBC_CAP_CHANNEL = 0
static int LIBC_FILEARGS = 0
static int LIBC_CAP_NET_LIMIT = 0

def libc_singleton(slot: i64, size: i64): pointer
    if slot != 0 then
        return reinterpret(pointer, slot)
    end
    raw = alloc(size)
    if raw == 0 then
        return reinterpret(pointer, 0)
    end
    memset(raw, 0, size)
    return reinterpret(pointer, raw)
end

def libc_dash_string(): pointer
    raw = alloc(2)
    if raw == 0 then
        return reinterpret(pointer, 0)
    end
    poke8(raw, 0, 45)
    poke8(raw, 1, 0)
    return reinterpret(pointer, raw)
end

