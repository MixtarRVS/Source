def libc_write_perm_char(out_addr: i64, offset: i64, enabled: i64, yes: i64): void
    if enabled != 0 then
        poke8(out_addr, offset, yes)
    else
        poke8(out_addr, offset, 45)
    end
    return
end

internal void strmode(mode: internal mode_t, out: internal charptr):
    out_addr = reinterpret(i64, out)
    kind = mode & S_IFMT_VALUE
    type_ch = 45

    if kind == S_IFDIR_VALUE then
        type_ch = 100
    end
    if kind == S_IFLNK_VALUE then
        type_ch = 108
    end
    if kind == S_IFCHR_VALUE then
        type_ch = 99
    end
    if kind == S_IFBLK_VALUE then
        type_ch = 98
    end
    if kind == S_IFIFO_VALUE then
        type_ch = 112
    end
    if kind == S_IFSOCK_VALUE then
        type_ch = 115
    end

    poke8(out_addr, 0, type_ch)
    libc_write_perm_char(out_addr, 1, mode & S_IRUSR_VALUE, 114)
    libc_write_perm_char(out_addr, 2, mode & S_IWUSR_VALUE, 119)
    libc_write_perm_char(out_addr, 3, mode & S_IXUSR_VALUE, 120)
    libc_write_perm_char(out_addr, 4, mode & S_IRGRP_VALUE, 114)
    libc_write_perm_char(out_addr, 5, mode & S_IWGRP_VALUE, 119)
    libc_write_perm_char(out_addr, 6, mode & S_IXGRP_VALUE, 120)
    libc_write_perm_char(out_addr, 7, mode & S_IROTH_VALUE, 114)
    libc_write_perm_char(out_addr, 8, mode & S_IWOTH_VALUE, 119)
    libc_write_perm_char(out_addr, 9, mode & S_IXOTH_VALUE, 120)
    poke8(out_addr, 10, 32)
    poke8(out_addr, 11, 0)
    return
end

def libc_getbsize_header(): pointer
    if LIBC_GETBSIZE_HEADER == 0 then
        raw = alloc(11)
        if raw == 0 then
            return reinterpret(pointer, 0)
        end
        poke8(raw, 0, 53)
        poke8(raw, 1, 49)
        poke8(raw, 2, 50)
        poke8(raw, 3, 45)
        poke8(raw, 4, 98)
        poke8(raw, 5, 108)
        poke8(raw, 6, 111)
        poke8(raw, 7, 99)
        poke8(raw, 8, 107)
        poke8(raw, 9, 115)
        poke8(raw, 10, 0)
        LIBC_GETBSIZE_HEADER = raw
    end
    return reinterpret(pointer, LIBC_GETBSIZE_HEADER)
end

internal charptr getbsize(headerlen: internal intp, blocksize: internal longp):
    header_addr = libc_getbsize_header()
    headerlen_addr = reinterpret(i64, headerlen)
    blocksize_addr = reinterpret(i64, blocksize)

    if headerlen_addr != 0 then
        poke32(headerlen_addr, 0, 10)
    end
    if blocksize_addr != 0 then
        poke64(blocksize_addr, 0, 512)
    end

    return header_addr
end

def libc_parse_octal_mode_value(text: pointer): i64
    addr = reinterpret(i64, text)
    if addr == 0 then
        return -1
    end
    if peek8(addr, 0) == 0 then
        return -1
    end

    idx = 0
    value = 0
    while true then
        ch = peek8(addr, idx)
        if ch == 0 then
            break
        end
        if ch < 48 or ch > 55 then
            return -1
        end
        value = value * 8 + (ch - 48)
        if value > MODE_LOW_MASK_VALUE then
            return -1
        end
        idx++
    end
    return value
end

def libc_symbolic_who_bit(ch: i64): i64
    if ch == 117 then
        return S_IRWXU_VALUE | S_ISUID_VALUE
    end
    if ch == 103 then
        return S_IRWXG_VALUE | S_ISGID_VALUE
    end
    if ch == 111 then
        return S_IRWXO_VALUE
    end
    if ch == 97 then
        return S_IRWXU_VALUE | S_IRWXG_VALUE | S_IRWXO_VALUE | S_ISUID_VALUE | S_ISGID_VALUE | S_ISVTX_VALUE
    end
    return 0
end

def libc_mode_perm_for_who(perm: i64, who: i64, base: i64): i64
    bits = 0

    if perm == 114 then
        if (who & S_IRWXU_VALUE) != 0 then
            bits = bits | S_IRUSR_VALUE
        end
        if (who & S_IRWXG_VALUE) != 0 then
            bits = bits | S_IRGRP_VALUE
        end
        if (who & S_IRWXO_VALUE) != 0 then
            bits = bits | S_IROTH_VALUE
        end
        return bits
    end

    if perm == 119 then
        if (who & S_IRWXU_VALUE) != 0 then
            bits = bits | S_IWUSR_VALUE
        end
        if (who & S_IRWXG_VALUE) != 0 then
            bits = bits | S_IWGRP_VALUE
        end
        if (who & S_IRWXO_VALUE) != 0 then
            bits = bits | S_IWOTH_VALUE
        end
        return bits
    end

    if perm == 120 or perm == 88 then
        if perm == 88 and (base & (S_IXUSR_VALUE | S_IXGRP_VALUE | S_IXOTH_VALUE)) == 0 then
            return 0
        end
        if (who & S_IRWXU_VALUE) != 0 then
            bits = bits | S_IXUSR_VALUE
        end
        if (who & S_IRWXG_VALUE) != 0 then
            bits = bits | S_IXGRP_VALUE
        end
        if (who & S_IRWXO_VALUE) != 0 then
            bits = bits | S_IXOTH_VALUE
        end
        return bits
    end

    return -1
end

def libc_parse_symbolic_mode_value(text: pointer, base: i64): i64
    addr = reinterpret(i64, text)
    if addr == 0 then
        return -1
    end
    if peek8(addr, 0) == 0 then
        return -1
    end

    idx = 0
    mode = base
    while true then
        ch = peek8(addr, idx)
        if ch == 0 then
            break
        end

        who = 0
        while true then
            bit = libc_symbolic_who_bit(ch)
            if bit == 0 then
                break
            end
            who = who | bit
            idx++
            ch = peek8(addr, idx)
        end
        if who == 0 then
            who = S_IRWXU_VALUE | S_IRWXG_VALUE | S_IRWXO_VALUE
        end

        op = peek8(addr, idx)
        if op != 43 and op != 45 and op != 61 then
            return -1
        end
        idx++

        bits = 0
        while true then
            ch = peek8(addr, idx)
            if ch == 0 or ch == 44 then
                break
            end
            piece = libc_mode_perm_for_who(ch, who, mode)
            if piece < 0 then
                return -1
            end
            bits = bits | piece
            idx++
        end

        if op == 43 then
            mode = mode | bits
        else
            if op == 45 then
                mode = mode & (MODE_LOW_MASK_VALUE - bits)
            else
                mode = mode & (MODE_LOW_MASK_VALUE - who)
                mode = mode | bits
            end
        end

        if ch == 44 then
            idx++
        end
    end
    return mode
end

def libc_copy_mode_text(src: pointer, dst_addr: i64): void
    src_addr = reinterpret(i64, src)
    i = 0
    while i < MODE_TEXT_MAX then
        ch = peek8(src_addr, i)
        poke8(dst_addr, MODE_BLOB_TEXT_OFFSET + i, ch)
        if ch == 0 then
            return
        end
        i++
    end
    poke8(dst_addr, MODE_BLOB_TEXT_OFFSET + MODE_TEXT_MAX, 0)
    return
end

internal pointer setmode(mode_text: internal cstring):
    text = reinterpret(pointer, mode_text)
    parsed = libc_parse_octal_mode_value(text)
    symbolic = 0

    if parsed < 0 then
        parsed = libc_parse_symbolic_mode_value(text, 0)
        if parsed < 0 then
            return reinterpret(pointer, 0)
        end
        symbolic = 1
    end

    blob = alloc(MODE_BLOB_SIZE)
    if blob == 0 then
        return reinterpret(pointer, 0)
    end
    memset(blob, 0, MODE_BLOB_SIZE)
    poke64(blob, MODE_BLOB_MODE_SLOT, parsed)
    poke64(blob, MODE_BLOB_SYMBOLIC_SLOT, symbolic)
    if symbolic != 0 then
        libc_copy_mode_text(text, blob)
    end
    return reinterpret(pointer, blob)
end

internal mode_t getmode(set: internal const_pointer, base: internal mode_t):
    blob = reinterpret(i64, set)
    if blob == 0 then
        return base
    end

    symbolic = peek64(blob, MODE_BLOB_SYMBOLIC_SLOT)
    if symbolic != 0 then
        text_addr = ptr_add(blob, MODE_BLOB_TEXT_OFFSET)
        parsed = libc_parse_symbolic_mode_value(reinterpret(pointer, text_addr), base)
        if parsed >= 0 then
            return parsed
        end
    end

    return peek64(blob, MODE_BLOB_MODE_SLOT)
end

def libc_strtonum_error_text(kind: i64): pointer
    if kind == 1 then
        if LIBC_STRTONUM_INVALID == 0 then
            raw = alloc(8)
            if raw == 0 then
                return reinterpret(pointer, 0)
            end
            poke8(raw, 0, 105)
            poke8(raw, 1, 110)
            poke8(raw, 2, 118)
            poke8(raw, 3, 97)
            poke8(raw, 4, 108)
            poke8(raw, 5, 105)
            poke8(raw, 6, 100)
            poke8(raw, 7, 0)
            LIBC_STRTONUM_INVALID = raw
        end
        return reinterpret(pointer, LIBC_STRTONUM_INVALID)
    end
    if kind == 2 then
        if LIBC_STRTONUM_TOO_SMALL == 0 then
            raw = alloc(10)
            if raw == 0 then
                return reinterpret(pointer, 0)
            end
            poke8(raw, 0, 116)
            poke8(raw, 1, 111)
            poke8(raw, 2, 111)
            poke8(raw, 3, 32)
            poke8(raw, 4, 115)
            poke8(raw, 5, 109)
            poke8(raw, 6, 97)
            poke8(raw, 7, 108)
            poke8(raw, 8, 108)
            poke8(raw, 9, 0)
            LIBC_STRTONUM_TOO_SMALL = raw
        end
        return reinterpret(pointer, LIBC_STRTONUM_TOO_SMALL)
    end
    if LIBC_STRTONUM_TOO_LARGE == 0 then
        raw = alloc(10)
        if raw == 0 then
            return reinterpret(pointer, 0)
        end
        poke8(raw, 0, 116)
        poke8(raw, 1, 111)
        poke8(raw, 2, 111)
        poke8(raw, 3, 32)
        poke8(raw, 4, 108)
        poke8(raw, 5, 97)
        poke8(raw, 6, 114)
        poke8(raw, 7, 103)
        poke8(raw, 8, 101)
        poke8(raw, 9, 0)
        LIBC_STRTONUM_TOO_LARGE = raw
    end
    return reinterpret(pointer, LIBC_STRTONUM_TOO_LARGE)
end

def libc_store_errstr(errstr: pointer, kind: i64): void
    slot = reinterpret(i64, errstr)
    if slot == 0 then
        return
    end
    if kind == 0 then
        poke64(slot, 0, 0)
    else
        text = libc_strtonum_error_text(kind)
        poke64(slot, 0, reinterpret(i64, text))
    end
    return
end

internal longlong strtonum(
    nptr: internal cstring,
    minval: internal longlong,
    maxval: internal longlong,
    errstr: internal cstringp
):
    addr = reinterpret(i64, nptr)
    errslot = reinterpret(pointer, errstr)
    if addr == 0 then
        libc_store_errstr(errslot, 1)
        return 0
    end

    idx = 0
    sign = 1
    ch = peek8(addr, idx)
    if ch == 45 then
        sign = -1
        idx++
    else
        if ch == 43 then
            idx++
        end
    end

    ch = peek8(addr, idx)
    if ch < 48 or ch > 57 then
        libc_store_errstr(errslot, 1)
        return 0
    end

    value = 0
    while true then
        ch = peek8(addr, idx)
        if ch == 0 then
            break
        end
        if ch < 48 or ch > 57 then
            libc_store_errstr(errslot, 1)
            return 0
        end
        digit = ch - 48
        if value > SIZE_MAX_SAFE / 10 then
            if sign < 0 then
                libc_store_errstr(errslot, 2)
            else
                libc_store_errstr(errslot, 3)
            end
            return 0
        end
        value = value * 10 + digit
        idx++
    end

    if sign < 0 then
        value = 0 - value
    end

    if value < minval then
        libc_store_errstr(errslot, 2)
        return 0
    end
    if value > maxval then
        libc_store_errstr(errslot, 3)
        return 0
    end

    libc_store_errstr(errslot, 0)
    return value
end

internal charptr fflagstostr(flags: internal ulong):
    out = alloc(1)
    if out == 0 then
        return reinterpret(pointer, 0)
    end
    poke8(out, 0, 0)
    return reinterpret(pointer, out)
end

internal int strtofflags(
    stringp: internal charpp,
    setp: internal uintp,
    clrp: internal uintp
):
    set_addr = reinterpret(i64, setp)
    if set_addr != 0 then
        poke32(set_addr, 0, 0)
    end

    clr_addr = reinterpret(i64, clrp)
    if clr_addr != 0 then
        poke32(clr_addr, 0, 0)
    end

    stringp_addr = reinterpret(i64, stringp)
    if stringp_addr == 0 then
        return 0
    end

    string_addr = peek64(stringp_addr, 0)
    if string_addr == 0 then
        return 0
    end

    first = peek8(string_addr, 0)
    if first == 0 then
        return 0
    end

    errno_set(EOPNOTSUPP_VALUE)
    return -1
end

internal pointer recallocarray(
    memory: internal pointer,
    oldnmemb: internal size_t,
    nmemb: internal size_t,
    size: internal size_t
):
    old_count = oldnmemb + 0
    new_count = nmemb + 0
    elem_size = size + 0

    if old_count != 0 and elem_size > SIZE_MAX_SAFE / old_count then
        errno_set(ENOMEM_VALUE)
        return reinterpret(pointer, 0)
    end
    if new_count != 0 and elem_size > SIZE_MAX_SAFE / new_count then
        errno_set(ENOMEM_VALUE)
        return reinterpret(pointer, 0)
    end

    old_size = old_count * elem_size
    new_size = new_count * elem_size
    ptr_addr = reinterpret(i64, memory)

    if new_size == 0 then
        if ptr_addr != 0 and old_size != 0 then
            memset(ptr_addr, 0, old_size)
        end
        if ptr_addr != 0 then
            dealloc(ptr_addr)
        end
        return reinterpret(pointer, 0)
    end

    next_addr = realloc(ptr_addr, new_size)
    if next_addr == 0 then
        return reinterpret(pointer, 0)
    end

    if new_size > old_size then
        fill_addr = ptr_add(next_addr, old_size)
        memset(fill_addr, 0, new_size - old_size)
    end

    return reinterpret(pointer, next_addr)
end

internal void freezero(memory: internal pointer, size: internal size_t):
    ptr_addr = reinterpret(i64, memory)
    byte_count = size + 0
    if ptr_addr != 0 and byte_count != 0 then
        memset(ptr_addr, 0, byte_count)
    end
    if ptr_addr != 0 then
        dealloc(ptr_addr)
    end
    return
end
