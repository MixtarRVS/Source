    include <limits.h>
end

abi header "sys/malloc.h":
    guard MIXTAR_BRIDGE_SYS_MALLOC_H
    include <stdlib.h>
end

abi header "sys/tty.h":
    guard MIXTAR_BRIDGE_SYS_TTY_H

    struct tty:
        dummy: int
    end
end

abi header "util.h":
    guard MIXTAR_BRIDGE_UTIL_H
    include "libutil.h"
    include "mixtar_bridge_compat.h"
end

abi header "sys/acl.h":
    guard MIXTAR_BRIDGE_SYS_ACL_H
    include <errno.h>
    include <stdlib.h>
    include <unistd.h>

    define _PC_ACL_NFS4 = 20001
    define _PC_ACL_EXTENDED = 20002
    define ACL_TYPE_ACCESS = 1
    define ACL_TYPE_NFS4 = 2
    define ACL_BRAND_POSIX = 1
    define ACL_BRAND_NFS4 = 2
    define ACL_EXTENDED = 1

    typedef acl_t = pointer
    typedef acl_type_t = int

    prototype acl_t acl_get_fd_np(fd: int, type: acl_type_t)
    prototype acl_t acl_get_link_np(path: cstring, type: acl_type_t)
    prototype int acl_set_fd_np(fd: int, acl: acl_t, type: acl_type_t)
    prototype int acl_is_trivial_np(acl: acl_t, trivial: "int *")
    prototype int acl_is_trivial(acl: acl_t, trivial: "int *")
    prototype int acl_free(obj: pointer)
    prototype int acl_supported(path: cstring, type: acl_type_t)
end

abi header "login_cap.h":
    guard MIXTAR_BRIDGE_LOGIN_CAP_H
    include <pwd.h>
    include <stdint.h>
    include <stdlib.h>
    include <sys/types.h>

    define LOGIN_DEFCLASS = "default"
    define LOGIN_DEFSTYLE = "passwd"
    define LOGIN_DEFSERVICE = "login"
    define LOGIN_DEFUMASK = 022
    define _PATH_LOGIN_CONF = "/etc/login.conf"
    define _PATH_LOGIN_CONF_D = "/etc/login.conf.d"

    define LOGIN_SETGROUP = 0x0001
    define LOGIN_SETLOGIN = 0x0002
    define LOGIN_SETPATH = 0x0004
    define LOGIN_SETPRIORITY = 0x0008
    define LOGIN_SETRESOURCES = 0x0010
    define LOGIN_SETUMASK = 0x0020
    define LOGIN_SETUSER = 0x0040
    define LOGIN_SETENV = 0x0080
    define LOGIN_SETRTABLE = 0x0100
    define LOGIN_SETALL = 0x01ff

    define pw_class = pw_gecos

    typedef login_cap_t = "struct login_cap"

    struct login_cap:
        lc_class: charptr
        lc_cap: charptr
        lc_style: charptr
    end

    prototype "login_cap_t *" login_getclass(class_name: charptr)
    prototype void login_close(lc: "login_cap_t *")
    prototype int login_getcapbool(lc: "login_cap_t *", cap: charptr, def: uint)
    prototype "quad_t" login_getcapnum(
        lc: "login_cap_t *",
        cap: charptr,
        def: "quad_t",
        error: "quad_t"
    )
    prototype "quad_t" login_getcapsize(
        lc: "login_cap_t *",
        cap: charptr,
        def: "quad_t",
        error: "quad_t"
    )
    prototype charptr login_getcapstr(
        lc: "login_cap_t *",
        cap: charptr,
        def: charptr,
        error: charptr
    )
    prototype "quad_t" login_getcaptime(
        lc: "login_cap_t *",
        cap: charptr,
        def: "quad_t",
        error: "quad_t"
    )
    prototype charptr login_getstyle(lc: "login_cap_t *", style: charptr, type: charptr)
    prototype int setclasscontext(class_name: charptr, flags: uint)
    prototype int setusercontext(
        lc: "login_cap_t *",
        pwd: "struct passwd *",
        uid: uid_t,
        flags: uint
    )
end

