// toolkit_coverage.ail
// AILang entry point for rerunnable Toolkit coverage reporting.

int toolkit_coverage_report():
    if file_exists("System/Userland/Generated") == 0 then
        mkdir("System/Userland/Generated")
    end
    if file_exists("System/Userland/Generated/reports") == 0 then
        mkdir("System/Userland/Generated/reports")
    end
    cmd = "" + "python System/Userland/Bridge/scripts/toolkit_coverage.py"
    rc = system(cmd)
    dealloc(cmd)
    return rc
end
