        case "cmp":
            return "" + "Certified WSL smoke surface:\n\n- `cmp -s` same-file and different-file statuses.\n\nKnown non-certification:\n\n- full upstream option/error matrix and host-specific edge cases beyond the documented smoke surface.\n"
        case "colrm":
