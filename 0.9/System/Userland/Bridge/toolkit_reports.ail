        case "df":
            return "" + "Certified WSL smoke surface:\n\n- `df -k /tmp` prints a filesystem table through the mounted filesystem stat path.\n\nKnown non-certification:\n\n- raw FFS/ext2 device inspection, mount table edge cases, block-size matrix, and BSD-specific filesystem flag behavior.\n"
        case "mknod":
            return "" + "Certified WSL smoke surface:\n\n- FIFO creation with `mknod path p`\n- invalid option usage diagnostics.\n\nKnown non-certification:\n\n- block/character device node creation, major/minor parser matrix, privilege failures, and filesystem-specific node behavior.\n"
        case "tsort":
            return "" + "Certified WSL smoke surface:\n\n- simple dependency-chain topological sorting.\n\nKnown non-certification:\n\n- cycle diagnostics, hints-file mode, duplicate edge handling, and very large graph behavior.\n"
        case "who":
            return "" + "Certified WSL smoke surface:\n\n- reads and prints one controlled Linux `struct utmp` fixture through `MIXTAR_UTMP_PATH`.\n\nKnown non-certification:\n\n- default host utmp discovery on WSL, terminal identity mode, all formatting flags, and cross-platform utmp time-field width differences.\n"
        case "diff":
            return "" + "Certified WSL smoke surface:\n\n- identical regular files exit 0 with no output\n- unified diff for changed regular files exits 1 and contains expected hunk lines\n- missing-file diagnostics are nonzero and report the missing path.\n\nKnown non-certification:\n\n- recursive directory diff matrix\n- binary file behavior\n- every output format and ignore option.\n"
        case "patch":
            return "" + "Certified WSL smoke surface:\n\n- applying a simple unified diff inside a temporary directory\n- invalid option usage exits nonzero.\n\nKnown non-certification:\n\n- reject/fuzz/reverse patch matrices\n- numbered backup behavior beyond compile-time bridge support\n- ed-script patch mode.\n"
        case "getconf":
            return "" + "Certified WSL smoke surface:\n\n- `ARG_MAX` sysconf parity with native Linux getconf\n- `PATH_MAX /tmp` pathconf parity with native Linux getconf\n- OpenBSD/XSI constant lookup through `_XOPEN_NAME_MAX`.\n\nKnown non-certification:\n\n- full POSIX variable matrix\n- every `-v` compilation environment profile\n- exact OpenBSD-vs-Linux unsupported-variable policy.\n"
        case "zic":
            return "" + "Certified WSL smoke surface:\n\n- `zic -v` exits successfully\n- invalid option usage exits nonzero.\n\nKnown non-certification:\n\n- full timezone source compilation matrix\n- leap-second database behavior\n- exact diagnostic text across libc/timezone database versions.\n"
        case "zdump":
            return "" + "Certified WSL smoke surface:\n\n- `zdump UTC` prints a UTC-prefixed line\n- invalid option usage exits nonzero.\n\nKnown non-certification:\n\n- full timezone transition matrix\n- verbose/range option behavior\n- exact wall-clock output across timezone database versions.\n"
        case "file":
            return "" + "Certified WSL smoke surface:\n\n- `file -b` classifies a plain text fixture\n- missing-path diagnostic surface is exercised.\n\nKnown non-certification:\n\n- full magic database parity\n- binary/container type recognition matrix\n- MIME and compressed-file behavior.\n"
        case "sort":
            return "" + "Certified WSL smoke surface:\n\n- sorting two input lines ascending\n- reverse sorting through `-r`.\n\nKnown non-certification:\n\n- stable-sort behavior through qsort-backed Bridge fallbacks\n- locale/collation matrices\n- merge/temp-file/resource-limit behavior.\n"
        case "m4":
            return "" + "Certified WSL smoke surface:\n\n- command-line macro expansion\n- `define` macro expansion from stdin.\n\nKnown non-certification:\n\n- full m4 language matrix\n- include path behavior\n- tracing, diversions, and GNU-extension edge cases.\n"
        case "awk":
            return "" + "Certified WSL smoke surface:\n\n- `BEGIN` arithmetic execution\n- field splitting and numeric accumulation over a fixture.\n\nKnown non-certification:\n\n- full awk language matrix\n- regex/locale behavior\n- file redirection, pipes, and long-running program behavior.\n"
        case "diff3":
            return "" + "Certified WSL smoke surface:\n\n- simple three-way diff output/exit status parity with host Linux `diff3`\n- missing-operand usage diagnostics.\n\nKnown non-certification:\n\n- full merge/edit-script option matrix\n- file names containing shell metacharacters in the hosted wrapper\n- exact OpenBSD-vs-GNU diagnostic wording.\n"
        case "gencat":
            return "" + "Certified WSL smoke surface:\n\n- creates a nonempty OpenBSD-format message catalog from a small source fixture\n- no-argument usage diagnostics.\n\nKnown non-certification:\n\n- GNU catalog binary compatibility\n- full message-source escape/parser matrix\n- runtime `catopen`/`catgets` use of generated catalogs.\n"
        case "gprof":
            return "" + "Certified WSL smoke surface:\n\n- missing executable/profile input diagnostic\n- unsupported `-c` call-graph diagnostic on amd64.\n\nKnown non-certification:\n\n- complete gmon.out parsing\n- flat/call graph output parity\n- architecture-specific call discovery beyond OpenBSD amd64 compile coverage.\n"
        case "ipcrm":
            return "" + "Certified WSL smoke surface:\n\n- no-argument no-op exits successfully\n- invalid option emits usage and exits nonzero.\n\nKnown non-certification:\n\n- destructive message-queue/shared-memory/semaphore removal\n- privilege/error matrix for real IPC objects\n- OpenBSD kernel-not-configured SIGSYS path.\n"
        case "ipcs":
            return "" + "Certified WSL smoke surface:\n\n- `ipcs -T` emits message, shared-memory, and semaphore totals sections through the Bridge sysctl view\n- invalid option emits usage and exits nonzero.\n\nKnown non-certification:\n\n- exact live Linux SysV IPC object enumeration parity\n- kvm core/namelist inspection beyond compile/link compatibility\n- OpenBSD kernel-not-configured warning paths.\n"
        case "mt":
            return "" + "Certified WSL smoke surface:\n\n- no-argument usage diagnostics\n- unknown command diagnostics before opening a tape device\n- `/dev/null` status fails safely as a non-tape device.\n\nKnown non-certification:\n\n- physical tape device ioctl behavior\n- remote RMT transport\n- `eject` hardlink invocation mode.\n"
        case "w":
            return "" + "Certified WSL smoke surface:\n\n- invalid option usage diagnostics\n- `w -h` executes through the Linux kvm/proc Bridge and current utmp path.\n\nKnown non-certification:\n\n- exact OpenBSD utmp accounting parity\n- reverse DNS display mode\n- `uptime` hardlink invocation mode.\n"
        case "vmstat":
            return "" + "Certified WSL smoke surface:\n\n- invalid option usage diagnostics only.\n\nKnown non-certification:\n\n- live Linux VM/disk/interrupt statistics\n- kvm core inspection paths\n- interval/repetition output parity.\n"
        case "yacc":
            return "" + "Certified WSL smoke surface:\n\n- generates `y.tab.c` from a minimal grammar\n- invalid option exits nonzero.\n\nKnown non-certification:\n\n- complete yacc grammar/error matrix\n- exact diagnostic parity for all malformed grammar cases\n- yyfix helper installation.\n"
        case "lex":
            return "" + "Certified WSL smoke surface:\n\n- generates scanner C from a minimal `.l` file\n- `--version` reports the upstream flex/lex identity.\n\nKnown non-certification:\n\n- complete flex option matrix\n- C++ scanner generation\n- compiled scanner runtime matrix\n- generated runtime libraries `libmain` and `libyywrap` installation.\n"
        case "watch":
            return "" + "Certified WSL smoke surface:\n\n- no-argument usage diagnostics\n- invalid interval rejection before curses initialization.\n\nKnown non-certification:\n\n- interactive terminal refresh loop\n- curses rendering matrix\n- child process output display under a real pty\n- real libevent dispatch semantics; Bridge event.h is a compile/smoke shim\n- rusage rendering and keyboard command matrix.\n"
        case "less":
            return "" + "Certified WSL smoke surface:\n\n- `less --version` reports the OpenBSD less identity\n- `TERM=xterm less -F -X <short-file>` prints a small file non-interactively.\n\nKnown non-certification:\n\n- interactive paging/navigation\n- terminal resize/input behavior\n- help-file lookup and `lesskey`\n- `more` hardlink invocation mode.\n"
        case "vi":
            return "" + "Certified WSL smoke surface:\n\n- scripted `vi -e <file>` append/write/quit path\n- invalid option exits nonzero.\n\nKnown non-certification:\n\n- full-screen curses editing behavior\n- terminal resize/input behavior\n- recovery daemon behavior\n- `ex` and `view` hardlink invocation modes.\n"
        case "vipw":
            return "" + "Certified WSL smoke surface:\n\n- invalid option usage diagnostics\n- no-op edit path over a sandbox passwd file exits cleanly with `no changes made`.\n\nKnown non-certification:\n\n- editing real system account databases\n- passwd lock contention behavior\n- editor invocation and recovery prompts\n- real OpenBSD `pwd_mkdb` database generation.\n"
        case "umount":
            return "" + "Certified WSL smoke surface:\n\n- no-argument usage diagnostics\n- non-mounted path diagnostic.\n\nKnown non-certification:\n\n- real unmount execution\n- NFS RPC mount-daemon notification\n- `-a` full mount table traversal beyond the Bridge root fixture\n- force-unmount privilege/error matrix.\n"
        case "mount":
            return "" + "Certified WSL smoke surface:\n\n- no-argument read-only mount table display through the Bridge root fixture\n- invalid option usage diagnostics.\n\nKnown non-certification:\n\n- real mount execution through mount helpers\n- `/etc/fstab` traversal\n- disklabel filesystem detection\n- network/NFS mount behavior and mountd signaling.\n"
        case "fsck":
            return "" + "Certified WSL smoke surface:\n\n- no-argument empty-fstab traversal exits cleanly\n- invalid option usage diagnostics\n- missing-device path exits nonzero without successful filesystem check.\n\nKnown non-certification:\n\n- real filesystem checking or repair\n- real `/etc/fstab` traversal\n- disklabel filesystem detection\n- fsck helper behavior against mounted or block devices.\n"
        case "init":
            return "" + "Certified WSL smoke surface:\n\n- normal-process execution exits nonzero through the upstream non-root or non-PID1 guard.\n\nKnown non-certification:\n\n- PID1 boot orchestration\n- getty/session lifecycle\n- rc startup/shutdown execution\n- securelevel and reboot transitions.\n"
        case "sysctl":
            return "" + "Certified WSL smoke surface:\n\n- `sysctl kern.ostype` read-only query through the Bridge\n- invalid option usage diagnostics.\n\nKnown non-certification:\n\n- setting kernel variables\n- full OpenBSD MIB namespace parity\n- network, sensor, VFS, debug, and architecture-specific sysctl matrices.\n"
        case "swapon":
            return "" + "Certified WSL smoke surface:\n\n- no-argument usage diagnostics in `swapon` mode\n- real swap activation path exits nonzero through the Bridge EPERM guard.\n\nKnown non-certification:\n\n- real swap activation/deactivation\n- full `/etc/fstab` swap traversal\n- priority mutation\n- swap listing through configured devices.\n"
        case "ping":
            return "" + "Certified WSL smoke surface:\n\n- no-capability raw socket guard exits nonzero with `socket: Operation not permitted`.\n\nKnown non-certification:\n\n- parser usage after successful socket open\n- setuid/capability policy\n- packet send/receive timing\n- IPv6 `ping6` hardlink mode.\n"
        case "top":
            return "" + "Certified WSL smoke surface:\n\n- invalid option usage diagnostics\n- invalid display-count diagnostics.\n\nKnown non-certification:\n\n- non-interactive process display\n- interactive curses input loop\n- exact OpenBSD process accounting on Linux\n- every sort/filter/display toggle\n- long-running refresh behavior.\n"
        case "fdisk":
            return "" + "Certified WSL smoke surface:\n\n- no-argument usage diagnostics\n- nonexistent disk path exits nonzero before any real disk access.\n\nKnown non-certification:\n\n- real disklabel ioctl mapping\n- GPT/MBR read/write parity on block devices\n- interactive editor behavior\n- Mixtar device passthrough and privilege policy.\n"
        case "cron":
            return "" + "Certified WSL smoke surface:\n\n- invalid option usage diagnostics only.\n\nKnown non-certification:\n\n- daemon lifecycle\n- cron socket creation\n- crontab spool loading\n- at-job scanning\n- user context switching\n- scheduled job execution.\n"
        case "su":
            return "" + "Certified WSL smoke surface:\n\n- invalid option usage diagnostics only.\n\nKnown non-certification:\n\n- BSD authentication behavior\n- wheel policy\n- login class and environment setup\n- setuid/setgid/user-context switching\n- shell execution.\n"
        case "passwd":
            return "" + "Certified WSL smoke surface:\n\n- invalid option usage diagnostics only.\n\nKnown non-certification:\n\n- current password authentication\n- password hashing policy\n- readpassphrase interaction\n- `/etc/master.passwd` locking/copying/mkdb update\n- passwd database parity on Linux.\n"
        case "login":
            return "" + "Certified WSL smoke surface:\n\n- invalid option usage diagnostics only.\n\nKnown non-certification:\n\n- BSD authentication behavior\n- utmp/wtmp/lastlog/failedlogin writes\n- tty ownership and permission changes\n- login class/session/environment setup\n- nologin/motd/hushlogin behavior\n- shell execution.\n"
        case "reboot":
            return "" + "Certified WSL smoke surface:\n\n- invalid option usage diagnostics only.\n\nKnown non-certification:\n\n- real reboot/halt/poweroff execution\n- init signaling and rc shutdown flow\n- wtmp logging behavior.\n"
        case "stty":
            return "" + "Certified WSL smoke surface:\n\n- `stty -a` reads terminal state under a pseudo-tty\n- non-tty input path exits nonzero.\n\nKnown non-certification:\n\n- terminal mutation behavior\n- full mode/character parser matrix\n- OpenBSD-only line discipline and terminal flag effects.\n"
        case "pkill":
            return "" + "Certified WSL smoke surface:\n\n- no-argument usage diagnostics\n- process discovery over Linux `/proc` with signal 0 against a controlled `sleep` process.\n\nKnown non-certification:\n\n- actually terminating processes\n- interactive confirmation\n- full uid/gid/tty/session/process-group filters\n- pgrep name-based dispatch and output formatting.\n"
        case "ps":
            return "" + "Certified WSL smoke surface:\n\n- `ps -ax` reads the process table and prints a headered process list\n- `ps -ax -o pid,comm` exercises selected OpenBSD format output.\n\nKnown non-certification:\n\n- exact OpenBSD kernel accounting fields on Linux\n- tty/session filtering matrix\n- full `%cpu`, `%mem`, pledge/unveil, and kernel-core inspection fidelity\n- every output column alias and width edge case.\n"
        case "getent":
            return "" + "Certified WSL smoke surface:\n\n- `getent passwd <current-user>` returns a passwd entry\n- `getent hosts localhost` returns a localhost mapping.\n\nKnown non-certification:\n\n- full ethers/RPC/services/shells matrix\n- exact OpenBSD-vs-glibc NSS ordering and formatting edge cases.\n"
        case "dmesg":
            return "" + "Certified WSL smoke surface:\n\n- no-argument execution exits successfully through the Bridge msgbuf surface\n- invalid option reports usage and exits nonzero.\n\nKnown non-certification:\n\n- reading real Linux host kernel logs\n- startup-message ring buffer fidelity\n- kernel-core `-M/-N` inspection.\n"
        case "nm":
            return "" + "Certified WSL smoke surface:\n\n- reads symbols from its own ELF binary\n- rejects a missing/non-object input path.\n\nKnown non-certification:\n\n- archive ranlib edge cases\n- every output format/radix/sort option\n- exact parity with OpenBSD on non-ELF object formats.\n"
        case "rpcgen":
            return "" + "Certified WSL smoke surface:\n\n- generates a C header from a simple RPC IDL file\n- invalid option exits nonzero.\n\nKnown non-certification:\n\n- full RPC language matrix\n- all client/server/table/sample generation modes\n- exact XDR output parity across libtirpc, glibc, and OpenBSD environments.\n"
        case "ed":
            return "" + "Certified WSL smoke surface:\n\n- scripted non-interactive append/write flow\n- reopening a written file and printing an explicit line range.\n\nKnown non-certification:\n\n- full ed command matrix\n- terminal/signal behavior\n- recovery behavior and all error diagnostics.\n"
        case "nproc":
            return "" + "Certified WSL smoke surface:\n\n- default affinity CPU count parity with native Linux `nproc`\n- `--all` configured CPU count parity\n- `--ignore` clamp-to-one behavior\n- `--version` output surface.\n\nKnown non-certification:\n\n- unusual CPU affinity masks outside the WSL host process\n- FreeBSD cpuset jail/domain behavior, which does not exist on hosted Linux.\n"
        default:
            return "" + "No certification scope recorded.\n"
    end
end

string toolkit_cert_report(tool: string):
    target = toolkit_target(tool)
    compat = toolkit_test_report_path(tool)
    upstream = toolkit_upstream_test_report_path(tool)
    scope = toolkit_cert_scope(tool)
    body = "" + "# "
    body2 = body + tool
    dealloc(body)
    body3 = body2 + " Certification\n\nStatus: certified for documented WSL smoke surface.\n\nGenerated target:\n\n```text\n"
    dealloc(body2)
    body4 = body3 + target
    dealloc(body3)
    body5 = body4 + "\n```\n\nCompatibility report:\n\n```text\n"
    dealloc(body4)
    body6 = body5 + compat
    dealloc(body5)
    body7 = body6 + "\n```\n\nUpstream-derived report:\n\n```text\n"
    dealloc(body6)
    body8 = body7 + upstream
    dealloc(body7)
    body9 = body8 + "\n```\n\n"
    dealloc(body8)
    body10 = body9 + scope
    dealloc(body9)
    body11 = body10 + "\nCertification rule:\n\nThis is not full upstream equivalence. It is a rerunnable proof that the generated Linux target builds, passes the documented smoke surface, and passes the currently automated upstream-derived edge tests where upstream tests exist.\n"
    dealloc(body10)
    dealloc(target, compat, upstream, scope)
    return body11
end

string toolkit_report(tool: string):
    src = toolkit_source(tool)
    target = toolkit_target(tool)
    cmd = toolkit_compile_command(tool)
    notes = toolkit_report_notes(tool)
    body = "" + "# "
    body2 = body + tool
    dealloc(body)
    body3 = body2 + " Bridge Gap Report\n\nSource: `"
    dealloc(body2)
    body4 = body3 + src
    dealloc(body3)
    body5 = body4 + "`\n\nPolicy:\n\n"
    dealloc(body4)
    body6 = body5 + "- Mirrored OpenBSD/FreeBSD source remains untouched.\n"
    dealloc(body5)
    body7 = body6 + "- Bridge headers provide compatibility only where Linux lacks the selected upstream surface.\n"
    dealloc(body6)
    body8 = body7 + "- Promotion to `Tools/` requires strict compile plus behavior comparison.\n\n"
    dealloc(body7)
    body9 = body8 + notes
    dealloc(body8)
    body10 = body9 + "Generated target:\n\n```text\n"
    dealloc(body9)
    body11 = body10 + target
    dealloc(body10)
    body12 = body11 + "\n```\n\nStrict translated build command:\n\n```sh\n"
    dealloc(body11)
    body13 = body12 + cmd
    dealloc(body12)
    body14 = body13 + "\n```\n\nOpen validation before promotion:\n\n"
    dealloc(body13)
    body15 = body14 + "- compare generated output against selected-upstream behavior tests\n"
    dealloc(body14)
    body16 = body15 + "- record semantic mismatches here before promotion\n"
    dealloc(body15)
    dealloc(src, target, cmd, notes)
    return body16
end

string toolkit_plan(tool: string):
    target = toolkit_target(tool)
    cmd = toolkit_compile_command(tool)
    wsl_cmd = toolkit_wsl_command(tool)
    body = "" + "# "
    body2 = body + tool
    dealloc(body)
    body3 = body2 + " Build Plan\n\nGenerated target:\n\n```text\n"
    dealloc(body2)
    body4 = body3 + target
    dealloc(body3)
    body5 = body4 + "\n```\n\nLinux command:\n\n```sh\n"
    dealloc(body4)
    body6 = body5 + cmd
    dealloc(body5)
    body7 = body6 + "\n```\n\nWSL executor command:\n\n```powershell\n"
    dealloc(body6)
    body8 = body7 + wsl_cmd
    dealloc(body7)
    body9 = body8 + "\n```\n\nDo not patch upstream FreeBSD source if this fails; update the Bridge gap report.\n"
    dealloc(body8)
    dealloc(target, cmd, wsl_cmd)
    return body9
end

int toolkit_write_docs(tool: string):
    toolkit_ensure_dirs_for(tool)
    report = toolkit_report(tool)
    plan = toolkit_plan(tool)
    report_path = toolkit_report_path(tool)
    plan_path = toolkit_plan_path(tool)
    report_rc = write_file(report_path, report)
    plan_rc = write_file(plan_path, plan)
    dealloc(report, plan, report_path, plan_path)
    if report_rc == 0 then
        return 1
    end
    if plan_rc == 0 then
        return 1
    end
    return 0
end

int toolkit_write_cert_one(tool: string):
    toolkit_ensure_dirs_for(tool)
    report = toolkit_cert_report(tool)
    path = toolkit_cert_report_path(tool)
    rc = write_file(path, report)
    dealloc(report, path)
    if rc == 0 then
        return 1
    end
    return 0
end
