        case "jot":
            return "" + "Certified WSL smoke surface:\n\n- simple integer range generation.\n\nKnown non-certification:\n\n- full upstream option/error matrix and host-specific edge cases beyond the documented smoke surface.\n"
        case "csplit":
            return "" + "Certified WSL smoke surface:\n\n- regex split into deterministic chunk files.\n\nKnown non-certification:\n\n- full upstream option/error matrix and host-specific edge cases beyond the documented smoke surface.\n"
        case "nl":
            return "" + "Certified WSL smoke surface:\n\n- `-ba` numbers all lines with Linux host parity\n- regex body numbering through `-bpPATTERN`\n\nKnown non-certification:\n\n- logical page delimiter matrix, multibyte delimiter matrix, and full upstream option/error cases.\n"
        case "rmt":
            return "" + "Certified WSL smoke surface:\n\n- EOF on stdin exits cleanly\n- invalid option emits usage and exits nonzero\n\nKnown non-certification:\n\n- remote tape protocol commands, real device access, and read/write/seek behavior.\n"
        case "shutdown":
