def format_interp_bench(iterations):
    i = 0
    sink = 0
    while i < iterations then
        si = str(i)
        s = "v=#{si}"
        sink = sink + len(s)
        i = i + 1
    end
    return sink
end


def main(): int
    iterations = 1000
    result = format_interp_bench(iterations)
    print(result)
    return 0
end
