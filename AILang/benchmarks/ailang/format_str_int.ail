def format_str_int_bench(iterations):
    i = 0
    sink = 0
    while i < iterations then
        s = str(i)
        sink = sink + len(s)
        i = i + 1
    end
    return sink
end


def main(): int
    iterations = 400000
    result = format_str_int_bench(iterations)
    print(result)
    return 0
end
