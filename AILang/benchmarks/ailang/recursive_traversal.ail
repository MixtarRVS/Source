def recursive_fib(n: i32): i64
    if n <= 1 then
        return 1
    end
    return recursive_fib(n - 1) + recursive_fib(n - 2)
end


def recursive_bench(iterations: i32): i64
    return recursive_fib(iterations)
end


def main(): int
    i32 depth = 32
    i64 result = recursive_bench(depth)
    print(result)
    return 0
end
