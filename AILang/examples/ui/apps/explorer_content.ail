def explorer_draw_header(window: int, width: int): void
    x = 218
    ail_ui_draw_rect(window, x, 170, width - x, 32, 0xffffff)
    ail_ui_draw_rect(window, x, 201, width - x, 1, 0xe5e7eb)
    explorer_text(window, 258, 181, 2, 0x1f4c7a, "Name")
    explorer_text(window, 568, 181, 2, 0x1f4c7a, "Date modified")
    explorer_text(window, 750, 181, 2, 0x1f4c7a, "Type")
    explorer_text(window, 908, 181, 2, 0x1f4c7a, "Size")
    ail_ui_draw_rect(window, 560, 170, 1, 32, 0xe5e7eb)
    ail_ui_draw_rect(window, 742, 170, 1, 32, 0xe5e7eb)
    ail_ui_draw_rect(window, 890, 170, 1, 32, 0xe5e7eb)
end


def explorer_file_row(
    window: int,
    frame: UiFrame,
    state: ExplorerState,
    id: int,
    width: int,
    y: int,
    name: string,
    date: string,
    kind: string,
    size: string,
    icon_kind: int
): int
    rect = ui_rect(218, y - 2, width - 218, 34)
    clicked = ui_button_logic(frame, id, rect)
    visual = ui_button_visual(frame, id, rect)
    selected = 0

    if state.active_row == id then
        selected = 1
    end
    if clicked == 1 then
        state.active_row = id
        selected = 1
    end
    if visual != 0 and selected == 0 then
        ail_ui_draw_rect(window, 218, y - 2, width - 218, 34, 0xf5f9ff)
    end
    if selected == 1 then
        ail_ui_draw_rect(window, 218, y - 2, width - 218, 34, 0xe8f2ff)
    end
    if icon_kind == 1 then
        explorer_folder_icon(window, 246, y + 5)
    else
        explorer_file_icon(window, 246, y + 3, 0x60a5fa)
    end
    explorer_text(window, 272, y + 7, 2, 0x111827, name)
    explorer_text(window, 568, y + 7, 2, 0x6b4f3d, date)
    explorer_text(window, 750, y + 7, 2, 0x4b5563, kind)
    explorer_text(window, 952, y + 7, 2, 0x6b4f3d, size)
    ui_rect_free(rect)
    return clicked
end


def explorer_draw_rows(window: int, width: int, frame: UiFrame, state: ExplorerState): int
    changed = 0
    if state.active_tab == 1 then
        if explorer_file_row(window, frame, state, 3001, width, 212, "out", "08.05.2026 21:28", "File folder", "", 1) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3002, width, 249, "ail_ui_win32_min.o", "08.05.2026 21:35", "O File", "9 KB", 2) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3003, width, 286, "ail_ui_win32_min_check.o", "08.05.2026 22:05", "O File", "14 KB", 2) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3004, width, 323, "micro_platform_demo", "08.05.2026 21:34", "Application", "269 KB", 2) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3005, width, 360, "micro_platform_desktop", "08.05.2026 23:07", "C Source File", "59 KB", 2) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3006, width, 397, "micro_platform_loop", "08.05.2026 21:35", "C Source File", "27 KB", 2) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3007, width, 434, "svg_demo", "08.05.2026 21:08", "Application", "283 KB", 2) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3008, width, 471, "svg_demo", "08.05.2026 21:08", "Firefox HTML Doc...", "3 KB", 2) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3009, width, 508, "micro_platform_desktop_demo", "08.05.2026 23:07", "Application", "295 KB", 2) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3010, width, 545, "ui_desktop", "08.05.2026 23:18", "C Source File", "59 KB", 2) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3011, width, 582, "ui_desktop_demo", "08.05.2026 23:18", "Application", "295 KB", 2) == 1 then
            changed = 1
        end
    else
        if explorer_file_row(window, frame, state, 3101, width, 212, "generated", "08.05.2026 23:18", "File folder", "", 1) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3102, width, 249, "package", "08.05.2026 22:41", "File folder", "", 1) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3103, width, 286, "ui_desktop_demo", "08.05.2026 23:18", "Application", "295 KB", 2) == 1 then
            changed = 1
        end
        if explorer_file_row(window, frame, state, 3104, width, 323, "svg_demo", "08.05.2026 21:08", "Application", "283 KB", 2) == 1 then
            changed = 1
        end
    end
    return changed
end


def explorer_draw_status(window: int, width: int, height: int, state: ExplorerState): void
    ail_ui_draw_rect(window, 0, height - 30, width, 30, 0xffffff)
    if state.active_tab == 1 then
        if state.active_row == 0 then
            explorer_text(window, 18, height - 22, 2, 0x111827, "11 items")
        else
            explorer_text(window, 18, height - 22, 2, 0x111827, "11 items    1 item selected")
        end
    else
        if state.active_row == 0 then
            explorer_text(window, 18, height - 22, 2, 0x111827, "4 items")
        else
            explorer_text(window, 18, height - 22, 2, 0x111827, "4 items    1 item selected")
        end
    end
    explorer_border(window, width - 68, height - 24, 30, 24, 0xf3f4f6, 0xd1d5db)
    explorer_text(window, width - 60, height - 19, 1, 0x374151, "===")
    explorer_border(window, width - 28, height - 24, 18, 24, 0xffffff, 0xd1d5db)
end


def explorer_draw_content(window: int, width: int, height: int, frame: UiFrame, state: ExplorerState): int
    changed = 0
    style = new UiFramePaint()
    caption = new UiCaptionPaint()
    style.frame_color = 0xdce5f4
    style.background_color = 0xffffff
    ui_frame_paint_set_border(style, 0xc3ccdb, 1)
    ui_frame_paint_set_gradient(style, 0xdce5f4, 0xf5f7fb, 3, 1)
    ui_frame_paint_surface(window, style, 0, 0, width, height, 50)

    if explorer_draw_titlebar(window, width, frame, state, caption) == 1 then
        changed = 1
    end
    if explorer_draw_top_path(window, width, frame, state) == 1 then
        changed = 1
    end
    explorer_draw_commandbar(window, width)
    explorer_draw_sidebar(window, height)
    explorer_draw_header(window, width)
    if explorer_draw_rows(window, width, frame, state) == 1 then
        changed = 1
    end
    explorer_draw_status(window, width, height, state)
    ui_caption_paint_free(caption)
    ui_frame_paint_free(style)
    return changed
end
