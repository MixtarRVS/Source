                width -> 340 px
                height -> 27 px
                fill -> #3b3b40
            end
            text:
                x -> 50 px
                y -> 55 px
                text -> "testing34"
                color -> #c7ccd3
            end
            text:
                x -> 31 px
                y -> 82 px
                text -> "v"
                color -> #c7ccd3
            end
            text:
                x -> 72 px
                y -> 82 px
                text -> "Source Files"
                color -> #dfe7ef
            end
            text:
                x -> 98 px
                y -> 109 px
                text -> "application.cxx"
                color -> #c7ccd3
            end
            text:
                x -> 98 px
                y -> 136 px
                text -> "main.cxx"
                color -> #c7ccd3
            end
            text:
                x -> 98 px
                y -> 163 px
                text -> "new_file1.cxx"
                color -> #c7ccd3
            end
            text:
                x -> 98 px
                y -> 190 px
                text -> "new_file2.cxx"
                color -> #c7ccd3
            end
            text:
                x -> 98 px
                y -> 217 px
                text -> "new_file3.cxx"
                color -> #c7ccd3
            end
            text:
                x -> 98 px
                y -> 244 px
                text -> "renderer.cxx"
                color -> #c7ccd3
            end
            text:
                x -> 31 px
                y -> 289 px
                text -> "v"
                color -> #c7ccd3
            end
            text:
                x -> 72 px
                y -> 289 px
                text -> "Header Files"
                color -> #dfe7ef
            end
            text:
                x -> 98 px
                y -> 316 px
                text -> "application.hxx"
                color -> #c7ccd3
            end
            text:
                x -> 98 px
                y -> 343 px
                text -> "renderer.hxx"
                color -> #c7ccd3
            end
            text:
                x -> 31 px
                y -> 384 px
                text -> "v"
                color -> #c7ccd3
            end
            text:
                x -> 72 px
                y -> 384 px
                text -> "Resource Files"
                color -> #dfe7ef
            end
            text:
                x -> 98 px
                y -> 411 px
                text -> "app.rc"
                color -> #c7ccd3
            end
            text:
                x -> 98 px
                y -> 438 px
                text -> "testing34.mxs"
                color -> #c7ccd3
            end
        end

        panel editor:
            x -> 342 px
            y -> 108 px
            width -> 1364 px
            right -> 342 px
            height -> 833 px
            bottom -> 184 px
            background -> #1e1e1e
            border -> #50555d

            text:
                x -> 612 px
                y -> 391 px
                text -> "No file is open."
                color -> #93a2b5
            end
            text:
                x -> 542 px
                y -> 417 px
                text -> "Use File > New File... to start editing."
                color -> #93a2b5
            end
            text:
                x -> 616 px
                y -> 463 px
                text -> "Create New File"
                color -> #dfe7ef
            end
        end

        panel output:
            x -> 342 px
            y -> 941 px
            width -> 1364 px
            right -> 342 px
            height -> 184 px
            bottom -> 0 px
            background -> #1e1e1e
            border -> #50555d

            rect:
                x -> 0 px
                y -> 0 px
                width -> 1364 px
                height -> 30 px
                fill -> #252526
            end
            text:
                x -> 22 px
                y -> 8 px
                text -> "Output"
                color -> #78bbff
            end
            rect:
                x -> 12 px
                y -> 28 px
                width -> 70 px
                height -> 2 px
                fill -> #007acc
            end
            text:
                x -> 104 px
                y -> 8 px
                text -> "Problems"
                color -> #c7ccd3
            end
            text:
                x -> 194 px
                y -> 8 px
                text -> "Terminal"
                color -> #c7ccd3
            end
            text:
                x -> 290 px
                y -> 8 px
                text -> "Build"
                color -> #c7ccd3
            end
            text:
                x -> 12 px
                y -> 48 px
                text -> "Run a Python file or build CMake executable with Debug > Start Without Debugging or Ctrl+F5 to see process output here."
                color -> #dfe7ef
            end
        end

        panel properties:
            x -> 1706 px
            y -> 108 px
            width -> 342 px
            right -> 0 px
            height -> 1017 px
            bottom -> 0 px
            background -> #252526
            border -> #3f3f46

            text:
                x -> 12 px
                y -> 20 px
                text -> "PROPERTIES"
                color -> #dfe7ef
            end
            text:
                x -> 318 px
                y -> 17 px
                text -> "#"
                color -> #a9b4c0
            end
            text:
                x -> 38 px
                y -> 64 px
                text -> "(none)"
                color -> #dfe7ef
            end

            property_grid:
                x -> 12 px
                y -> 88 px
                key_width -> 132 px
                value_width -> 184 px
                row_height -> 32 px
                key_fill -> #2d2d30
                value_fill -> #1e1e1e
                border -> #3f3f46
                key_color -> #9399a1
                value_color -> #c7ccd3

                row:
                    label -> "File Name"
                    value -> "(none)"
                end
                row:
                    label -> "Full Path"
                    value -> "..."
                end
                row:
                    label -> "Size"
                    value -> "0 KB"
                end
                row:
                    label -> "Encoding"
                    value -> "UTF-8"
                end
                row:
                    label -> "Item Type"
                    value -> "None"
                end
            end

            text:
                x -> 12 px
                y -> 272 px
                text -> "ADVANCED"
                color -> #dfe7ef
            end
            property_grid:
                x -> 12 px
                y -> 304 px
                key_width -> 132 px
                value_width -> 184 px
                row_height -> 32 px
                key_fill -> #2d2d30
                value_fill -> #1e1e1e
                border -> #3f3f46
                key_color -> #9399a1
                value_color -> #c7ccd3

                row:
                    label -> "Build Action"
                    value -> "Compile"
                end
                row:
                    label -> "Copy to Output"
                    value -> "Do not copy"
                end
            end
        end
