window editor:
    width -> 2048 px
    height -> 1125 px
    title -> "AILang Editor - workspace"
    background -> #1e1e1e
    layout -> "absolute"

    caption:
        type -> "default"
        height -> 42 px
        background -> #172730
        background_end -> #131a21
        border -> #05070a
        title_color -> #e8eef5
        title_x -> 30 px
        title_y -> 12 px
        icon_x -> 10 px
        icon_y -> 15 px
        icon_fill -> #0f253c
        icon_border -> #1169b1

        controls:
            position -> "right"
            top -> 1 px
            right -> 10 px
            width -> 132 px
            height -> 30 px
            minimize_width -> 42 px
            middle_width -> 42 px
            close_width -> 50 px
            middle_offset -> 41 px
            close_offset -> 82 px
            normal_fill -> transparent
            close_fill -> transparent
            hover_fill -> #212b34
            pressed_fill -> #2a3743
            close_hover_fill -> #ce564b
            close_pressed_fill -> #5b2822
            button_border -> #334351
            close_border -> #d57167
            button_background -> #14191f
            corner_radius -> 8 px
            border_width -> 1 px
            glyph -> #e7f8f4
        end
    end

    body:
        layout -> "absolute"
        x -> 0 px
        y -> 0 px
        width -> 2048 px
        height -> 1125 px

        menubar:
            x -> 0 px
            y -> 42 px
            width -> 2048 px
            right -> 0 px
            height -> 30 px
            background -> #2d2d30
            border_bottom -> #3f3f46

            text:
                x -> 15 px
                y -> 9 px
                text -> "File"
                color -> #c7ccd3
            end
            text:
                x -> 59 px
                y -> 9 px
                text -> "Edit"
                color -> #c7ccd3
            end
            text:
                x -> 103 px
                y -> 9 px
                text -> "View"
                color -> #c7ccd3
            end
            text:
                x -> 151 px
                y -> 9 px
                text -> "Build"
                color -> #c7ccd3
            end
            text:
                x -> 207 px
                y -> 9 px
                text -> "Debug"
                color -> #c7ccd3
            end
            text:
                x -> 271 px
                y -> 9 px
                text -> "Tools"
                color -> #c7ccd3
            end
            text:
                x -> 331 px
                y -> 9 px
                text -> "Extensions"
                color -> #c7ccd3
            end
            text:
                x -> 453 px
                y -> 9 px
                text -> "Window"
                color -> #c7ccd3
            end
            text:
                x -> 529 px
                y -> 9 px
                text -> "Help"
                color -> #c7ccd3
            end
        end

        toolbar:
            x -> 0 px
            y -> 72 px
            width -> 2048 px
            right -> 0 px
            height -> 36 px
            background -> #25282e
            border_bottom -> #3f3f46

            text:
                x -> 16 px
                y -> 13 px
                text -> "<"
                color -> #9aa7b5
            end
            panel debug_combo:
                x -> 40 px
                y -> 6 px
                width -> 110 px
                height -> 26 px
                background -> #2a2d33
                border -> #3b414a
                text:
                    x -> 14 px
                    y -> 6 px
                    text -> "Debug"
                    color -> #dfe7ef
                end
                text:
                    x -> 86 px
                    y -> 6 px
                    text -> "v"
                    color -> #93a2b5
                end
            end
            panel arch_combo:
                x -> 155 px
                y -> 6 px
                width -> 88 px
                height -> 26 px
                background -> #2a2d33
                border -> #3b414a
                text:
                    x -> 14 px
                    y -> 6 px
                    text -> "x64"
                    color -> #dfe7ef
                end
                text:
                    x -> 64 px
                    y -> 6 px
                    text -> "v"
                    color -> #93a2b5
                end
            end
            text:
                x -> 258 px
                y -> 13 px
                text -> "Run testing34"
                color -> #6bc275
            end
            text:
                x -> 370 px
                y -> 13 px
                text -> "Stop"
                color -> #93a2b5
            end
        end

        panel solution_explorer:
