def ail_ui_event_height_px(): int
    return g_wayland_event_height_px
end
def ail_ui_begin_frame(window: int, color: int): void
    ail_ui_draw_rect(window, 0, 0, g_wayland_width_px, g_wayland_height_px, color)
end
def ail_ui_draw_rect(window: int, x: int, y: int, width: int, height: int, color: int): void
    if g_wayland_pixels == 0 then
        return
    end
    x0 = x
    y0 = y
    x1 = x + width
    y1 = y + height
    if x0 < 0 then
        x0 = 0
    end
    if y0 < 0 then
        y0 = 0
    end
    if x1 > g_wayland_width_px then
        x1 = g_wayland_width_px
    end
    if y1 > g_wayland_height_px then
        y1 = g_wayland_height_px
    end
    if x1 <= x0 or y1 <= y0 then
        return
    end
    pixel = wayland_color(color)
    yy = y0
    while yy < y1 then
        xx = x0
        base = yy * g_wayland_width_px
        while xx < x1 then
            poke32(g_wayland_pixels, base + xx, pixel)
            xx = xx + 1
        end
        yy = yy + 1
    end
end
def ail_ui_draw_text(window: int, x: int, y: int, scale: int, color: int, text: string): void
    // Minimal proof path: text shaping stays above the native backend.
