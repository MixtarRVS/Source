): void
    // Font selection is part of the richer text backend; keep ABI coverage now.
    ail_ui_draw_text_style(window, x, y, size_px, weight, color, text)
end
def ail_ui_set_clip(window: int, x: int, y: int, width: int, height: int): void
end
def ail_ui_clear_clip(window: int): void
end
def ail_ui_end_frame(window: int): void
    if g_wayland_surface != 0 and g_wayland_buffer != 0 then
        ail_wl_surface_attach(reinterpret(ptr, g_wayland_surface), reinterpret(ptr, g_wayland_buffer), 0, 0)
        ail_wl_surface_damage_buffer(reinterpret(ptr, g_wayland_surface), 0, 0, g_wayland_width_px, g_wayland_height_px)
        ail_wl_surface_commit(reinterpret(ptr, g_wayland_surface))
        ail_wl_display_flush(reinterpret(ptr, g_wayland_display))
    end
end
def ail_ui_sleep_ms(ms: int): void
    if ms > 0 then
        usleep(ms * 1000)
    end
end
def ail_ui_wait_event_ms(ms: int): void
    ail_ui_poll_event(g_wayland_surface)
    ail_ui_sleep_ms(ms)
end
def wayland_pure_smoke(): int
    if ail_ui_init() != 1 then
        return 1
    end
    window = ail_ui_open_window("AILang pure Wayland", 640, 360)
    if window == 0 then
        ail_ui_shutdown()
        return 2
    end
    ail_ui_begin_frame(window, 15791611)
    ail_ui_draw_rect(window, 48, 48, 220, 72, 3385907)
    ail_ui_end_frame(window)
    ail_ui_wait_event_ms(20)
    ail_ui_close_window(window)
    ail_ui_shutdown()
    return 0
end
def main(): int
    return wayland_pure_smoke()
end
