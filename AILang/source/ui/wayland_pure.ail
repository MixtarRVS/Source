def ail_ui_poll_event(window: int): int
    g_wayland_pending_event = AIL_UI_EVENT_NONE
    if g_wayland_display == 0 then
        return AIL_UI_EVENT_NONE
    end
    if ail_wl_display_dispatch_pending(reinterpret(ptr, g_wayland_display)) < 0 then
        g_wayland_alive = 0
        return AIL_UI_EVENT_CLOSE
    end
    kind = g_wayland_pending_event
    g_wayland_pending_event = AIL_UI_EVENT_NONE
    return kind
end

