    style.close_normal_bottom = 0x3a2326
    style.close_hover_top = 0xe85f51
    style.close_hover_mid = 0xd34031
    style.close_hover_bottom = 0x8e1c12
    style.close_pressed_top = 0x5b2822
    style.close_pressed_mid = 0x411c17
    style.close_pressed_bottom = 0x2c1210
    style.band_highlight = 0x858a96
    style.band_shadow = 0x05070a
    style.band_top_height = 11
    style.band_mid_height = 1
end


def ui_caption_paint_default_dark(style: UiCaptionPaint, accent: int, warm: int, close: int, close_pressed: int): void
    glow = ui_paint_lerp_color(warm, accent, 820, 1000)
    bg = ui_paint_lerp_color(0x101419, glow, 35, 1000)
    style.banded = 0
    style.button_normal_fill = -1
    style.button_hover_fill = ui_paint_lerp_color(bg, glow, 120, 1000)
    style.button_pressed_fill = ui_paint_lerp_color(bg, glow, 200, 1000)
    style.close_normal_fill = -1
    style.close_hover_fill = ui_paint_lerp_color(bg, close, 880, 1000)
    style.close_pressed_fill = close_pressed
    style.button_border_color = ui_paint_lerp_color(bg, glow, 280, 1000)
    style.close_border_color = ui_paint_lerp_color(style.close_hover_fill, 0xffffff, 160, 1000)
    style.button_background_color = bg
    style.button_border_width = 1
    style.button_corner_radius = 8
    style.glyph_color = 0xe7f8f4
    style.glyph_hover_color = 0xffffff
    style.close_glyph_color = 0xe7f8f4
    style.close_hot_glyph_color = 0xffffff
    style.band_highlight = 0x000000
    style.band_shadow = 0x000000
    style.band_top_height = 0
    style.band_mid_height = 0
end


def ui_caption_paint_apply_metrics(style: UiCaptionPaint, metrics: UiChromeMetrics): void
    style.band_top_height = metrics.caption_top_band_height
    style.band_mid_height = metrics.caption_mid_band_height
    style.button_corner_radius = metrics.control_outer_radius
end


def ui_caption_button_fill(style: UiCaptionPaint, kind: int, visual: int): int
    if kind == 4 then
        if visual == 2 then
            return style.close_pressed_fill
        end
        if visual == 1 then
            return style.close_hover_fill
        end
        return style.close_normal_fill
    end

    if visual == 2 then
        return style.button_pressed_fill
    end
    if visual == 1 then
        return style.button_hover_fill
    end
    return style.button_normal_fill
end


def ui_caption_band_top(style: UiCaptionPaint, kind: int, visual: int): int
    if kind == 4 then
        if visual == 2 then
            return style.close_pressed_top
        end
        if visual == 1 then
            return style.close_hover_top
        end
        return style.close_normal_top
    end

    if visual == 2 then
        return style.button_pressed_top
    end
    if visual == 1 then
        return style.button_hover_top
    end
    return style.button_normal_top
end


def ui_caption_band_mid(style: UiCaptionPaint, kind: int, visual: int): int
    if kind == 4 then
        if visual == 2 then
            return style.close_pressed_mid
        end
        if visual == 1 then
            return style.close_hover_mid
        end
        return style.close_normal_mid
    end

    if visual == 2 then
        return style.button_pressed_mid
    end
