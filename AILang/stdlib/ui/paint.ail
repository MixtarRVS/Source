        return style.button_hover_bottom
    end
    return style.button_normal_bottom
end


def ui_caption_glyph_color(style: UiCaptionPaint, kind: int, visual: int): int
    if kind == 4 then
        if visual != 0 then
            return style.close_hot_glyph_color
        end
        return style.close_glyph_color
    end

    if visual != 0 then
        return style.glyph_hover_color
    end
    return style.glyph_color
end


def ui_draw_caption_diag_down(window: int, x: int, y: int, size: int, thickness: int, color: int): void
    i = 0
    while i < size then
        ail_ui_draw_rect(window, x + i, y + i, thickness, thickness, color)
        i = i + 1
    end
end


def ui_draw_caption_diag_up(window: int, x: int, y: int, size: int, thickness: int, color: int): void
    i = 0
    while i < size then
        ail_ui_draw_rect(window, x + i, y + size - i, thickness, thickness, color)
        i = i + 1
    end
end


def ui_draw_caption_icon(
    window: int,
    kind: int,
    x: int,
    y: int,
    width: int,
    height: int,
    color: int
): void
    maximized = 0
    if height <= 28 then
        maximized = 1
    end
    glyph_down = 1

    if kind == 1 then
        line_w = 14
        line_h = 1
        line_y = 18
        offset_x = 0
        if maximized == 1 then
            line_w = 12
            line_h = 1
            line_y = 17
            offset_x = 0
        end
        ail_ui_draw_rect(window, x + ((width - line_w) / 2) + offset_x, y + line_y + glyph_down, line_w, line_h, color)
        return
    end

    if kind == 2 then
        icon_w = 16
        icon_h = 12
        ui_draw_border(window, x + ((width - icon_w) / 2), y + ((height - icon_h) / 2) - 1 + glyph_down, icon_w, icon_h, color, 1)
        return
    end

    if kind == 3 then
        icon_x = x + ((width - 12) / 2) - 1
        icon_y = y + ((height - 10) / 2) + 1 + glyph_down
        if maximized == 1 then
            icon_x = icon_x + 1
            icon_y = icon_y - 2
        end

        ail_ui_draw_rect(window, icon_x + 2, icon_y, 10, 1, color)
        ail_ui_draw_rect(window, icon_x + 11, icon_y, 1, 8, color)
        ail_ui_draw_rect(window, icon_x + 2, icon_y + 1, 1, 1, color)
        ail_ui_draw_rect(window, icon_x + 10, icon_y + 7, 1, 1, color)
        ui_draw_border(window, icon_x, icon_y + 2, 10, 8, color, 1)
        return
    end

    if kind == 4 then
        glyph_pixels = 12
        glyph_start = 0
        glyph_y_offset = -1
        if maximized == 1 then
            glyph_pixels = 10
            glyph_start = 1
            glyph_y_offset = -1
        end
        icon_x = x + ((width - 12) / 2)
        icon_y = y + ((height - 12) / 2) + glyph_y_offset + glyph_down

        i = 0
        while i < glyph_pixels then
            ail_ui_draw_rect(window, icon_x + glyph_start + i, icon_y + glyph_start + i, 1, 1, color)
            ail_ui_draw_rect(window, icon_x + glyph_start + (glyph_pixels - 1 - i), icon_y + glyph_start + i, 1, 1, color)
            i = i + 1
        end
    end
end


def ui_draw_caption_banded_face(
    window: int,
    style: UiCaptionPaint,
    x: int,
    y: int,
    width: int,
    height: int,
    kind: int,
    visual: int
): void
    top_h = style.band_top_height
    mid_h = style.band_mid_height
    if height < 16 then
        top_h = height / 2
    end
    if top_h < 1 then
        top_h = 1
    end
    if height - top_h - mid_h < 1 then
        mid_h = 0
    end

    ail_ui_draw_rect(window, x, y, width, top_h, ui_caption_band_top(style, kind, visual))
    if mid_h > 0 then
        ail_ui_draw_rect(window, x, y + top_h, width, mid_h, ui_caption_band_mid(style, kind, visual))
    end
    ail_ui_draw_rect(window, x, y + top_h + mid_h, width, height - top_h - mid_h, ui_caption_band_bottom(style, kind, visual))
    ail_ui_draw_rect(window, x, y, width, 1, style.band_highlight)
    ail_ui_draw_rect(window, x, y + height - 1, width, 1, style.band_shadow)
    ail_ui_draw_rect(window, x, y, 1, height, style.band_shadow)
    ail_ui_draw_rect(window, x + width - 1, y, 1, height, style.band_highlight)
end


def ui_draw_caption_button(
    window: int,
    style: UiCaptionPaint,
    x: int,
    y: int,
    width: int,
    height: int,
    kind: int,
    visual: int
): void
    fill = ui_caption_button_fill(style, kind, visual)
    glyph = ui_caption_glyph_color(style, kind, visual)
    border = style.button_border_color
    if kind == 4 then
        border = style.close_border_color
    end

    if style.banded == 1 then
        ui_draw_caption_banded_face(window, style, x, y, width, height, kind, visual)
    else
        if fill >= 0 then
            if style.button_corner_radius > 0 then
                bottom_left = 0
                bottom_right = 0
                if kind == 1 then
                    bottom_left = 1
                end
                if kind == 4 then
                    bottom_right = 1
                end
                if visual != 0 and style.button_border_width > 0 then
                    ui_draw_bottom_cornered_box_aa(
                        window,
                        x,
                        y,
                        width,
                        height,
                        fill,
                        border,
                        style.button_border_width,
                        style.button_corner_radius,
                        bottom_left,
                        bottom_right,
                        style.button_background_color
                    )
                else
                    ui_draw_bottom_cornered_rect_aa(
                        window,
                        x,
                        y,
                        width,
                        height,
                        fill,
                        style.button_corner_radius,
                        bottom_left,
                        bottom_right,
                        style.button_background_color
                    )
                end
            else
                ail_ui_draw_rect(window, x, y, width, height, fill)
            end
        end
    end
    if visual != 0 and style.button_border_width > 0 and style.button_corner_radius <= 0 then
        ui_draw_border(window, x, y, width, height, border, style.button_border_width)
    end
    ui_draw_caption_icon(window, kind, x, y, width, height, glyph)
end

def ui_draw_panel(window: int, x: int, y: int, width: int, height: int): void
    ail_ui_draw_rect(window, x + 4, y + 5, width, height, 0xd1d5db)
    ail_ui_draw_rect(window, x, y, width, height, 0xffffff)
    ail_ui_draw_rect(window, x, y, width, 1, 0xe5e7eb)
    ail_ui_draw_rect(window, x, y + height - 1, width, 1, 0xd8dee9)
    ail_ui_draw_rect(window, x, y, 1, height, 0xe5e7eb)
    ail_ui_draw_rect(window, x + width - 1, y, 1, height, 0xd8dee9)
end


