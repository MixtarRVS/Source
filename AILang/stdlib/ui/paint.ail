        return style.button_hover_mid
    end
    return style.button_normal_mid
end


def ui_caption_band_bottom(style: UiCaptionPaint, kind: int, visual: int): int
    if kind == 4 then
        if visual == 2 then
            return style.close_pressed_bottom
        end
        if visual == 1 then
            return style.close_hover_bottom
        end
        return style.close_normal_bottom
    end

    if visual == 2 then
        return style.button_pressed_bottom
    end
