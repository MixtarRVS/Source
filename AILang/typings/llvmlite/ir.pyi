from typing import Any, Iterable, Sequence

class Type:
    width: int
    pointee: Type
    element: Type
    elements: Sequence[Type]
    count: int
    def __call__(self, value: Any) -> Constant: ...
    def as_pointer(self, addrspace: int | None = ...) -> PointerType: ...
    def __getattr__(self, name: str) -> Any: ...

class Value:
    type: Type
    name: str
    def add_incoming(self, value: Any, block: Any) -> None: ...
    def bitcast(self, typ: Type) -> Value: ...
    def gep(self, indices: Sequence[Any]) -> Value: ...
    def __getattr__(self, name: str) -> Any: ...

class Constant(Value):
    constant: Any
    def __init__(self, typ: Type, constant: Any) -> None: ...
    @classmethod
    def literal_array(cls, values: Sequence[Any]) -> Constant: ...
    @classmethod
    def literal_struct(cls, values: Sequence[Any]) -> Constant: ...

class Function(Value):
    args: Sequence[Argument]
    blocks: Sequence[Block]
    attributes: Any
    calling_convention: str
    linkage: str
    function_type: FunctionType
    entry_basic_block: Block
    def __init__(self, module: Module, ftype: FunctionType, name: str) -> None: ...
    def append_basic_block(self, name: str = ...) -> Block: ...
    def set_metadata(self, name: str, node: Any) -> None: ...

class Argument(Value):
    def add_attribute(self, attr: str) -> None: ...

class Block:
    name: str
    is_terminated: bool
    def __getattr__(self, name: str) -> Any: ...

class IRBuilder:
    block: Block
    function: Function
    def __init__(self, block: Block | None = ...) -> None: ...
    def position_at_end(self, block: Block) -> None: ...
    def append_basic_block(self, name: str = ...) -> Block: ...
    def alloca(self, typ: Type, size: Any = ..., name: str = ...) -> Value: ...
    def load(self, ptr: Value, name: str = ...) -> Value: ...
    def store(self, value: Value, ptr: Value) -> Any: ...
    def call(self, fn: Value, args: Sequence[Any], name: str = ...) -> Value: ...
    def ret(self, value: Value) -> Any: ...
    def ret_void(self) -> Any: ...
    def branch(self, target: Block) -> Any: ...
    def cbranch(self, cond: Value, truebr: Block, falsebr: Block) -> Any: ...
    def if_then(self, pred: Value, likely: bool | None = ...) -> Any: ...
    def if_else(self, pred: Value, likely: bool | None = ...) -> Any: ...
    def switch(self, value: Value, default: Block) -> Any: ...
    def phi(self, typ: Type, name: str = ...) -> Any: ...
    def gep(
        self, ptr: Value, indices: Sequence[Any], name: str = ..., inbounds: bool = ...
    ) -> Value: ...
    def bitcast(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def ptrtoint(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def inttoptr(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def zext(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def sext(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def trunc(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def fpext(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def fptrunc(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def sitofp(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def uitofp(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def fptosi(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def fptoui(self, value: Value, typ: Type, name: str = ...) -> Value: ...
    def add(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def sub(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def mul(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def sdiv(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def udiv(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def srem(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def urem(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def fadd(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def fsub(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def fmul(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def fdiv(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def and_(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def or_(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def xor(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def not_(self, value: Value, name: str = ...) -> Value: ...
    def shl(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def ashr(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def lshr(self, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def icmp_signed(
        self, op: str, lhs: Value, rhs: Value, name: str = ...
    ) -> Value: ...
    def icmp_unsigned(
        self, op: str, lhs: Value, rhs: Value, name: str = ...
    ) -> Value: ...
    def fcmp_ordered(
        self, op: str, lhs: Value, rhs: Value, name: str = ...
    ) -> Value: ...
    def select(self, cond: Value, lhs: Value, rhs: Value, name: str = ...) -> Value: ...
    def extract_value(self, agg: Value, idx: int, name: str = ...) -> Value: ...
    def insert_value(
        self, agg: Value, value: Value, idx: int, name: str = ...
    ) -> Value: ...
    def extract_element(self, vec: Value, idx: Value, name: str = ...) -> Value: ...
    def insert_element(
        self, vec: Value, value: Value, idx: Value, name: str = ...
    ) -> Value: ...
    def atomic_rmw(
        self, op: str, ptr: Value, val: Value, ordering: str = ..., name: str = ...
    ) -> Value: ...
    def __getattr__(self, name: str) -> Any: ...

class Module:
    triple: str
    data_layout: str
    globals: dict[str, Any]
    def __init__(self, name: str = ..., context: Any = ...) -> None: ...
    def get_global(self, name: str) -> Any: ...
    def __str__(self) -> str: ...
    def __getattr__(self, name: str) -> Any: ...

class GlobalVariable(Value):
    linkage: str
    global_constant: bool
    initializer: Any
    unnamed_addr: bool
    def __init__(self, module: Module, typ: Type, name: str) -> None: ...

class IntType(Type):
    width: int
    def __init__(self, bits: int) -> None: ...

class FloatType(Type): ...
class DoubleType(Type): ...
class HalfType(Type): ...
class VoidType(Type): ...

class PointerType(Type):
    pointee: Type
    def __init__(self, pointee: Type, addrspace: int = ...) -> None: ...

class ArrayType(Type):
    element: Type
    count: int
    def __init__(self, element: Type, count: int) -> None: ...

class VectorType(Type):
    element: Type
    count: int
    def __init__(self, element: Type, count: int) -> None: ...

class LiteralStructType(Type):
    elements: Sequence[Type]
    def __init__(self, elements: Sequence[Type], packed: bool = ...) -> None: ...

class IdentifiedStructType(Type):
    name: str
    elements: Sequence[Type]
    def set_body(self, *elems: Type, packed: bool = ...) -> None: ...

class FunctionType(Type):
    return_type: Type
    args: Sequence[Type]
    var_arg: bool
    def __init__(
        self, return_type: Type, args: Sequence[Type], var_arg: bool = ...
    ) -> None: ...

class InlineAsm(Value):
    def __init__(
        self, ftype: FunctionType, asm: str, constraint: str, side_effect: bool = ...
    ) -> None: ...

class MetaDataString(Value):
    def __init__(self, module: Module, string: str) -> None: ...

class MDValue(Value):
    def __init__(
        self, module: Module, values: Iterable[Any], name: str = ...
    ) -> None: ...

def __getattr__(name: str) -> Any: ...
