+static FILE *
+gendep_open(pid_t *pid)
+{
+	int fds[2];
+	FILE *fp;
+	int serrno;
+
+	if (pipe(fds) == -1)
+		return NULL;
+
+	*pid = fork();
+	if (*pid == -1) {
+		serrno = errno;
+		close(fds[0]);
+		close(fds[1]);
+		errno = serrno;
+		return NULL;
+	}
+	if (*pid == 0) {
+		close(fds[0]);
+		if (fds[1] != STDOUT_FILENO) {
+			if (dup2(fds[1], STDOUT_FILENO) == -1)
+				_exit(127);
+			close(fds[1]);
+		}
+		execl(GENDEP, GENDEP, (char *)NULL);
+		_exit(127);
+	}
+
+	close(fds[1]);
+	fp = fdopen(fds[0], "r");
+	if (!fp) {
+		serrno = errno;
+		close(fds[0]);
+		while (waitpid(*pid, NULL, 0) == -1 && errno == EINTR)
+			;
+		errno = serrno;
+	}
+	return fp;
+}
+
+static bool
+gendep_close(FILE *fp, pid_t pid)
+{
+	int status;
+	bool ok;
+
+	ok = fclose(fp) == 0;
+	while (waitpid(pid, &status, 0) == -1) {
+		if (errno != EINTR)
+			return false;
+	}
+	return ok && WIFEXITED(status) && WEXITSTATUS(status) == 0;
+}
