schema = 1

[product]
id = "org.mixtar.Core"
name = "MixtarRVS"
version = "1.0-Core"
architecture = "x86_64"
base_release = "M1"
interface = "console"
language = "en"
source_date_epoch = 1784160000

[base]
root_archive = "Output/P1/MixtarRVS-M1-x86_64.root.tar"
release_lock = "Release/M1.lock.config"

[sdk]
channel = "10.0"
global_json = "Product/global.json"

[executor]
project = "Product/Executor/Mixtar.Executor.csproj"
configuration = "Release"
runtime = "linux-musl-x64"
publish_directory = "out/Product/Executor/linux-musl-x64"
binary = "Executor"
install_path = "System/Core/Product/Executor"

[overlay]
root = "Product/Root"

[zsh]
source = "System/Terminal/ZSH/zsh"
template = "Product/Templates/zsh.config.in"
bundle = "System/Terminal/ZSH/zsh.apx"

[runtime]
service = "System/Configuration/OpenRC/init.d/mixtar-product-runtime"
runlevel = "System/Configuration/OpenRC/runlevels/default/mixtar-product-runtime"

[output]
root_directory = "Output/P4/CoreRoot"
materialize_root = false
root_archive = "Output/P4/MixtarRVS-1.0-Core-x86_64.root.tar"
manifest = "Output/P4/MixtarRVS-1.0-Core-x86_64.manifest.config"
[image]
builder = "scripts/build_m1_image.py"
entrypoint = "scripts/build-m1.ps1"
entrypoint_arguments = ["-SkipP0", "-ProductImageOnly"]
prebuilt_root_environment = "MIXTAR_PREBUILT_ROOT_ARCHIVE"
output_environment = "MIXTAR_IMAGE_OUTPUT_DIRECTORY"
product_version_environment = "MIXTAR_PRODUCT_VERSION"
reuse_base_boot_environment = "MIXTAR_REUSE_BASE_BOOT"
reuse_base_boot = false
output_directory = "Output/P4/Image"

[contracts]
identity = "System/Configuration/Product/Identity.config"
executor_configuration = "System/Configuration/Product/Executor.config"
zsh_policy = "System/Configuration/Security/Applications/org.mixtar.Terminal.ZSH.config"

[test]
console_harness = "scripts/test-p2-console.py"
work_directory = "Output/P4/Test"
console_report = "Output/P4/Core.console.json"
release_report = "Output/P4/Core.release.json"
