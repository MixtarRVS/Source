schema = 1

[product]
id = "org.mixtar.Workbench"
name = "MixtarRVS Workbench"
version = "1.1-Workbench"
architecture = "x86_64"
interface = "graphical"
language = "en"

[base]
core_root = "Output/P4/CoreRoot"
core_archive = "Output/P4/MixtarRVS-1.0-Core-x86_64.root.tar"
release_lock = "Release/P4.graphics.lock.config"

[sdk]
channel = "10.0"
global_json = "Product/global.json"

[workbench]
project = "Product/Workbench/Mixtar.Workbench.csproj"
configuration = "Release"
runtime = "linux-x64"
publish_directory = "out/Product/Workbench/linux-x64"
binary = "Workbench"
install_path = "System/Core/Product/Workbench"

[stack]
builder = "Product/build-graphics-stack.sh"
build_directory = "out/Product/GraphicsStack"
prefix = "/System"
libraries = "/System/Libraries/Graphics"
loader = "/System/Libraries/Loader/ld-linux-x86-64.so.2"

[contracts]
budgets = "Root/System/Configuration/Product/P4.config"

[output]
root_directory = "Output/P4/GraphicsRoot"
root_archive = "Output/P4/MixtarRVS-1.1-Graphics-x86_64.overlay.tar"
manifest = "Output/P4/MixtarRVS-1.1-Graphics-x86_64.manifest.config"
elf_report = "Output/P4/Graphics.elf.json"
