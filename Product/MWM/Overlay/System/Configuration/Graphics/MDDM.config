schema = 1
model = "MixtarRVS Display Driver Model"
backend = "wayland"
renderer = "pixman"
allocator = "shm"
allow_software_renderer = true
allow_x11 = false
allow_xwayland = false

# The nested Wayland backend is the first P4 execution gate. The same MDDM
# contract will select "drm" after the DRM/KMS and libinput dependencies land.
