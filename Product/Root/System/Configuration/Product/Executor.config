schema = 1

[identity]
name = "Mixtar Executor"
contract = "mixtar.executor.v1"

[paths]
sessions = "/System/Runtime/Sessions"
policies = "/System/Configuration/Security/Applications"
logs = "/System/Logs/Executor/events.log"
users = "/Users"

[security]
require_active_session = true
deny_system_admin_process = true
