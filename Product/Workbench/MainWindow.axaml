<Window
    x:Class="Mixtar.Product.Workbench.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="MixtarRVS Workbench"
    Width="1280"
    Height="800"
    MinWidth="800"
    MinHeight="600"
    Background="#0B1220"
    Foreground="#E8EEF7"
    FontFamily="Noto Sans"
    WindowStartupLocation="CenterScreen"
    WindowDecorations="None"
    ExtendClientAreaToDecorationsHint="True"
    KeyDown="OnWindowKeyDown">

  <Window.Styles>
    <StyleInclude Source="/Theme.axaml" />
  </Window.Styles>

  <LayoutTransformControl x:Name="ScaleHost">
    <Grid x:Name="RootLayout" ClipToBounds="True" SizeChanged="OnRootSizeChanged">
      <Border Background="#0B1220" />

      <Ellipse Width="900" Height="620" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-330,-120,0" IsHitTestVisible="False">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="#7A1C5DAE" Offset="0" />
            <GradientStop Color="#001C5DAE" Offset="1" />
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>
      <Ellipse Width="560" Height="560" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-280,0,0,-250" IsHitTestVisible="False">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="#4A00BEFF" Offset="0" />
            <GradientStop Color="#0000BEFF" Offset="1" />
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>
      <Canvas x:Name="GridLines" IsHitTestVisible="False" Opacity="0.8" />

      <Canvas x:Name="DesktopCanvas">

      <!-- Snap preview overlay (HIG: snapping with preview) -->
      <Border x:Name="SnapPreview" ZIndex="8" IsVisible="False" Background="#2618B9FF"
              BorderBrush="#8018B9FF" BorderThickness="2" CornerRadius="8" IsHitTestVisible="False" />

        <!-- Terminal -->
        <Border x:Name="TerminalWindow" Classes="desktop-window active" Width="470" Height="270"
                Canvas.Left="28" Canvas.Top="58" ZIndex="20" PointerPressed="FocusDesktopWindow">
          <Grid RowDefinitions="34,*">
            <Border Classes="titlebar" Tag="TerminalWindow"
                    PointerPressed="BeginDesktopWindowDrag" PointerMoved="ContinueDesktopWindowDrag" PointerReleased="EndDesktopWindowDrag">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="window-title" Text="TERMINAL - WORKBENCH SHELL" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                  <Button Classes="window-dot min" Tag="TerminalWindow" Content="–" Click="OnDesktopMinimize" />
                  <Button Classes="window-dot max" Tag="TerminalWindow" Content="□" Click="OnDesktopMaximize" />
                  <Button Classes="window-dot close" Tag="TerminalWindow" Content="✕" Click="OnDesktopClose" />
                </StackPanel>
              </Grid>
            </Border>
            <Grid Grid.Row="1" RowDefinitions="*,34" Background="#F20E1013">
              <ScrollViewer x:Name="TerminalScroll" Margin="12,12,12,4">
                <StackPanel x:Name="TerminalLines" Spacing="4" />
              </ScrollViewer>
              <Grid Grid.Row="1" Margin="12,0" ColumnDefinitions="Auto,*">
                <TextBlock x:Name="TerminalPrompt" Text="root@mixtar:/#" Foreground="#27EE91" FontWeight="Bold"
                           FontFamily="Noto Sans Mono" FontSize="11" VerticalAlignment="Center" />
                <TextBox x:Name="TerminalInput" Grid.Column="1" Margin="8,0,0,0" Padding="4,0" Background="Transparent"
                         BorderThickness="0" FontFamily="Noto Sans Mono" KeyDown="OnTerminalKeyDown" />
              </Grid>
            </Grid>
          </Grid>
        </Border>

        <!-- Files -->
        <Border x:Name="FilesWindow" Classes="desktop-window" Width="680" Height="360"
                Canvas.Left="220" Canvas.Top="332" ZIndex="16" PointerPressed="FocusDesktopWindow">
          <Grid RowDefinitions="42,44,35,*,24">
            <Border Classes="titlebar" Tag="FilesWindow" Height="42" Padding="8,0,0,0"
                    PointerPressed="BeginDesktopWindowDrag" PointerMoved="ContinueDesktopWindowDrag" PointerReleased="EndDesktopWindowDrag">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom">
                  <StackPanel x:Name="FileTabsPanel" Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom" />
                  <Button Classes="tab-add" Content="+" Click="OnAddFileTab" VerticalAlignment="Bottom"
                          Margin="4,0,0,0" ToolTip.Tip="New tab" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0" VerticalAlignment="Top">
                  <Button Classes="window-dot min" Tag="FilesWindow" Content="–" Click="OnDesktopMinimize" />
                  <Button Classes="window-dot max" Tag="FilesWindow" Content="□" Click="OnDesktopMaximize" />
                  <Button Classes="window-dot close" Tag="FilesWindow" Content="✕" Click="OnDesktopClose" />
                </StackPanel>
              </Grid>
            </Border>
            <Grid Grid.Row="1" ColumnDefinitions="78,*,170" Margin="8,8" ColumnSpacing="8">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Classes="tool" Width="24" Padding="0" Tag="back" Content="&lt;" Click="OnAction" />
                <Button Classes="tool" Width="24" Padding="0" Tag="forward" Content="&gt;" Click="OnAction" />
                <Button Classes="tool" Width="24" Padding="0" Tag="up" Content="^" Click="OnAction" />
              </StackPanel>
              <Grid Grid.Column="1">
                <Border x:Name="Breadcrumb" Background="#D31E2126" BorderBrush="#5A5FA2FF" BorderThickness="1"
                        CornerRadius="5" Padding="4,0" PointerPressed="OnAddressPressed">
                  <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal" VerticalAlignment="Center" />
                  </ScrollViewer>
                </Border>
                <TextBox x:Name="AddressBox" IsVisible="False" Text="/" Padding="8,0"
                         FontFamily="Noto Sans Mono" KeyDown="OnAddressKeyDown" />
                <Popup x:Name="AddressPopup" PlacementTarget="{Binding ElementName=AddressBox}"
                       Placement="BottomEdgeAlignedLeft" IsLightDismissEnabled="False">
                  <Border Background="#F514161A" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1"
                          CornerRadius="7" Padding="8" MinWidth="380" BoxShadow="0 14 40 0 #C0000000">
                    <StackPanel x:Name="AddressSuggestions" Spacing="0" />
                  </Border>
                </Popup>
              </Grid>
              <TextBox x:Name="FileSearch" Grid.Column="2" PlaceholderText="Search" Padding="8,0" TextChanged="OnFileSearchChanged" />
            </Grid>
            <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*" Margin="8,0" ColumnSpacing="8">
              <Button Classes="tool" Tag="reload" Content="Refresh" Click="OnAction" />
              <Button Grid.Column="1" Classes="tool" Tag="newfolder" Content="New Folder" Click="OnAction" />
              <Button x:Name="DeleteButton" Grid.Column="2" Classes="tool danger" Tag="delete" Content="Delete" Click="OnAction" />
              <TextBlock x:Name="PathHint" Grid.Column="3" Text="" Foreground="#668AB9"
                         HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Noto Sans Mono" FontSize="10" />
            </Grid>
            <Grid Grid.Row="3" ColumnDefinitions="170,*">
              <Border BorderBrush="#344B97FF" BorderThickness="0,1,1,0" Background="#3D0F1114" Padding="8,8">
                <ScrollViewer>
                  <StackPanel x:Name="TreePanel" Spacing="0" />
                </ScrollViewer>
              </Border>
              <Grid Grid.Column="1" RowDefinitions="28,*">
                <Border Background="#E61A1D22" Padding="12,0">
                  <Grid ColumnDefinitions="190,60,74,96,*">
                    <Button Classes="column-header" Tag="name" Content="Name" Click="OnSortColumn" />
                    <Button Grid.Column="1" Classes="column-header" Tag="type" Content="Type" Click="OnSortColumn" />
                    <Button Grid.Column="2" Classes="column-header" Tag="size" Content="Size" Click="OnSortColumn" />
                    <Button Grid.Column="3" Classes="column-header" Tag="modified" Content="Modified" Click="OnSortColumn" />
                    <TextBlock Grid.Column="4" Text="Entries" Foreground="#8BBCFF" FontFamily="Noto Sans Mono" FontSize="10" VerticalAlignment="Center" />
                  </Grid>
                </Border>
                <ScrollViewer Grid.Row="1">
                  <StackPanel x:Name="FileRows" />
                </ScrollViewer>
              </Grid>
            </Grid>
            <Border Grid.Row="4" Background="#520A0C0F" Padding="8,0">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock x:Name="ItemCount" Text="0 items" Foreground="#7FAEE6" FontFamily="Noto Sans Mono" FontSize="10" VerticalAlignment="Center" />
                <TextBlock x:Name="VolumeInfo" Grid.Column="1" Text="" Foreground="#668AB9" FontFamily="Noto Sans Mono"
                           FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                <TextBlock x:Name="SelectionStatus" Grid.Column="2" Text="No selection" Foreground="#7FAEE6"
                           FontFamily="Noto Sans Mono" FontSize="10" VerticalAlignment="Center" />
              </Grid>
            </Border>
          </Grid>
        </Border>

        <!-- Runtime -->
        <Border x:Name="RuntimeWindow" Classes="desktop-window" Width="290" Height="380"
                Canvas.Left="855" Canvas.Top="346" ZIndex="14" PointerPressed="FocusDesktopWindow">
          <Grid RowDefinitions="34,*">
            <Border Classes="titlebar" Tag="RuntimeWindow"
                    PointerPressed="BeginDesktopWindowDrag" PointerMoved="ContinueDesktopWindowDrag" PointerReleased="EndDesktopWindowDrag">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="window-title" Text="RUNTIME MONITOR" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                  <Button Classes="window-dot min" Tag="RuntimeWindow" Content="–" Click="OnDesktopMinimize" />
                  <Button Classes="window-dot close" Tag="RuntimeWindow" Content="✕" Click="OnDesktopClose" />
                </StackPanel>
              </Grid>
            </Border>
            <StackPanel Grid.Row="1" Margin="12,12" Spacing="8">
              <Grid ColumnDefinitions="50,*,40">
                <TextBlock Text="CPU" FontSize="10" />
                <Border x:Name="CpuTrack" Grid.Column="1" Height="6" Background="#17FFFFFF" CornerRadius="3" VerticalAlignment="Center">
                  <Border x:Name="CpuBar" Width="0" HorizontalAlignment="Left" Background="#18B9FF" CornerRadius="3" />
                </Border>
                <TextBlock x:Name="CpuText" Grid.Column="2" Text="--" FontSize="10" HorizontalAlignment="Right" />
              </Grid>
              <Border Classes="card" Padding="4" Height="46">
                <Canvas x:Name="CpuGraph" ClipToBounds="True" />
              </Border>
              <Grid ColumnDefinitions="50,*,40">
                <TextBlock Text="Memory" FontSize="10" />
                <Border x:Name="MemTrack" Grid.Column="1" Height="6" Background="#17FFFFFF" CornerRadius="3" VerticalAlignment="Center">
                  <Border x:Name="MemBar" Width="0" HorizontalAlignment="Left" Background="#18B9FF" CornerRadius="3" />
                </Border>
                <TextBlock x:Name="MemText" Grid.Column="2" Text="--" FontSize="10" HorizontalAlignment="Right" />
              </Grid>
              <Grid ColumnDefinitions="50,*,Auto">
                <TextBlock Text="Procs" FontSize="10" />
                <TextBlock x:Name="ProcText" Grid.Column="2" Text="--" FontSize="10" HorizontalAlignment="Right" />
              </Grid>
              <Grid ColumnDefinitions="50,*,Auto">
                <TextBlock Text="Uptime" FontSize="10" />
                <TextBlock x:Name="UptimeText" Grid.Column="2" Text="--" FontSize="10" HorizontalAlignment="Right" />
              </Grid>
              <TextBlock Text="TOP PROCESSES" Foreground="#8FC1FF" FontFamily="Noto Sans Mono" FontSize="10" FontWeight="Bold" />
              <Border Classes="card" Padding="8,8" MinHeight="90">
                <StackPanel x:Name="ProcessList" Spacing="4" />
              </Border>
              <Border Classes="card" Padding="8,8">
                <TextBlock x:Name="StateLines" Text="reading /System/State..." Foreground="#91B7E8"
                           FontFamily="Noto Sans Mono" FontSize="10" LineHeight="14" />
              </Border>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Network Inspector: hidden preview, waiting for a real traceroute backend -->
        <Border x:Name="NetworkWindow" Classes="desktop-window" Width="370" Height="380" IsVisible="False"
                Canvas.Left="510" Canvas.Top="68" ZIndex="12" PointerPressed="FocusDesktopWindow">
          <Grid RowDefinitions="34,Auto,*">
            <Border Classes="titlebar" Tag="NetworkWindow"
                    PointerPressed="BeginDesktopWindowDrag" PointerMoved="ContinueDesktopWindowDrag" PointerReleased="EndDesktopWindowDrag">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="window-title" Text="NETWORK INSPECTOR" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                  <Button Classes="window-dot min" Tag="NetworkWindow" Content="–" Click="OnDesktopMinimize" />
                  <Button Classes="window-dot close" Tag="NetworkWindow" Content="✕" Click="OnDesktopClose" />
                </StackPanel>
              </Grid>
            </Border>
            <Border Grid.Row="1" Background="#40FFC65C" Padding="12,4">
              <TextBlock Text="OFFLINE PREVIEW - sample topology, real traceroute planned"
                         Foreground="#FFE3AC" FontFamily="Noto Sans Mono" FontSize="10" />
            </Border>
            <Grid Grid.Row="2" RowDefinitions="180,Auto,*" Margin="12" RowSpacing="12">
              <Border Classes="card" Background="#F0020711">
                <Canvas Width="344" Height="176">
                  <Line StartPoint="38,78" EndPoint="125,116" Stroke="#416FA8E8" StrokeThickness="1" />
                  <Line StartPoint="125,116" EndPoint="218,66" Stroke="#416FA8E8" StrokeThickness="1" />
                  <Line StartPoint="218,66" EndPoint="320,126" Stroke="#416FA8E8" StrokeThickness="1" />
                  <Line StartPoint="38,78" EndPoint="218,66" Stroke="#244B79B6" StrokeThickness="1" />
                  <Button Classes="map-node local" Tag="local" Canvas.Left="26" Canvas.Top="66" Click="OnNetworkNode" />
                  <Button Classes="map-node" Tag="relay" Canvas.Left="113" Canvas.Top="104" Click="OnNetworkNode" />
                  <Button Classes="map-node selected" Tag="vault" Canvas.Left="206" Canvas.Top="54" Click="OnNetworkNode" />
                  <Button Classes="map-node" Tag="edge" Canvas.Left="308" Canvas.Top="114" Click="OnNetworkNode" />
                </Canvas>
              </Border>
              <Border Grid.Row="1" Classes="card" Padding="12,8">
                <Grid ColumnDefinitions="82,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                  <TextBlock Text="TARGET" Foreground="#8EB6E9" FontSize="10" />
                  <TextBlock x:Name="NodeName" Grid.Column="1" Text="local.mix" FontSize="10" />
                  <TextBlock Grid.Row="1" Text="ADDRESS" Foreground="#8EB6E9" FontSize="10" />
                  <TextBlock x:Name="NodeIp" Grid.Row="1" Grid.Column="1" Text="127.0.0.1" FontSize="10" />
                  <TextBlock Grid.Row="2" Text="LOCATION" Foreground="#8EB6E9" FontSize="10" />
                  <TextBlock x:Name="NodeLocation" Grid.Row="2" Grid.Column="1" Text="Local machine" FontSize="10" />
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Border>

        <!-- Text viewer -->
        <Border x:Name="ViewerWindow" Classes="desktop-window" Width="560" Height="400" IsVisible="False"
                Canvas.Left="300" Canvas.Top="120" ZIndex="18" PointerPressed="FocusDesktopWindow">
          <Grid RowDefinitions="34,*">
            <Border Classes="titlebar" Tag="ViewerWindow"
                    PointerPressed="BeginDesktopWindowDrag" PointerMoved="ContinueDesktopWindowDrag" PointerReleased="EndDesktopWindowDrag">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="ViewerTitle" Classes="window-title" Text="VIEWER" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                  <Button Classes="window-dot max" Tag="ViewerWindow" Content="□" Click="OnDesktopMaximize" />
                  <Button Classes="window-dot close" Tag="ViewerWindow" Content="✕" Click="OnDesktopClose" />
                </StackPanel>
              </Grid>
            </Border>
            <ScrollViewer Grid.Row="1" Margin="12,10" HorizontalScrollBarVisibility="Auto">
              <TextBlock x:Name="ViewerContent" FontFamily="Noto Sans Mono" FontSize="10"
                         Foreground="#C6DCFA" TextWrapping="NoWrap" />
            </ScrollViewer>
          </Grid>
        </Border>

        <!-- Settings -->
        <Border x:Name="SettingsWindow" Classes="desktop-window" Width="320" Height="215" IsVisible="False"
                Canvas.Left="420" Canvas.Top="180" ZIndex="22" PointerPressed="FocusDesktopWindow">
          <Grid RowDefinitions="34,*">
            <Border Classes="titlebar" Tag="SettingsWindow"
                    PointerPressed="BeginDesktopWindowDrag" PointerMoved="ContinueDesktopWindowDrag" PointerReleased="EndDesktopWindowDrag">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="window-title" Text="SETTINGS" />
                <Button Grid.Column="1" Classes="window-dot close" Tag="SettingsWindow" Content="✕" Click="OnDesktopClose" />
              </Grid>
            </Border>
            <StackPanel Grid.Row="1" Margin="12,12" Spacing="12">
              <TextBlock Text="UI SCALE" Foreground="#8FC1FF" FontFamily="Noto Sans Mono" FontSize="10" FontWeight="Bold" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="tool" Tag="scale:auto" Content="Auto" Click="OnAction" />
                <Button Classes="tool" Tag="scale:1" Content="100%" Click="OnAction" />
                <Button Classes="tool" Tag="scale:1.25" Content="125%" Click="OnAction" />
                <Button Classes="tool" Tag="scale:1.5" Content="150%" Click="OnAction" />
                <Button Classes="tool" Tag="scale:2" Content="200%" Click="OnAction" />
              </StackPanel>
              <TextBlock x:Name="ScaleInfo" Text="" Foreground="#91B7E8" FontFamily="Noto Sans Mono" FontSize="10" />
              <TextBlock Text="Scale applies to the whole desktop. Auto follows the screen resolution."
                         Foreground="#668AB9" FontSize="10" TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </Border>
      </Canvas>

      <!-- HUD -->
      <Border x:Name="Hud" IsVisible="False" Height="40" VerticalAlignment="Top" ZIndex="100"
              Background="#F5061125" BorderBrush="#484796FF" BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto" Margin="12,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
            <Button Classes="hud-item" Tag="start" Click="OnAction" Padding="0,0,8,0">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Width="17" Height="17" CornerRadius="5" Background="#0B70DF" BorderBrush="#18B9FF" BorderThickness="1" />
                <TextBlock Text="MixtarRVS" Foreground="#7DBDFF" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Classes="hud-item" Tag="files" Content="Files" Click="OnAction" />
            <Button Classes="hud-item" Tag="terminal" Content="Terminal" Click="OnAction" />
            <Button Classes="hud-item" Tag="runtime" Content="Runtime" Click="OnAction" />
            <Button Classes="hud-item" Tag="settings" Content="Settings" Click="OnAction" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="14">
            <TextBlock x:Name="GraphicsDot" Text="● MWM" Foreground="#668AB9" FontFamily="Noto Sans Mono" FontSize="10" />
            <TextBlock x:Name="VolumesDot" Text="● VOL" Foreground="#668AB9" FontFamily="Noto Sans Mono" FontSize="10" />
            <Border BorderBrush="#20FFFFFF" BorderThickness="1,0,0,0" Padding="14,0,0,0">
              <TextBlock x:Name="ClockText" Text="--:--:--" Foreground="#C4DCFF" FontFamily="Noto Sans Mono" FontSize="10" />
            </Border>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Start menu -->
      <Border x:Name="StartMenu" IsVisible="False" Width="430" HorizontalAlignment="Left" VerticalAlignment="Bottom"
              Margin="8,0,0,56" ZIndex="130" Background="#F214161A" BorderBrush="{StaticResource StrokeBrush}"
              BorderThickness="1" CornerRadius="11" BoxShadow="0 24 68 0 #D0000000">
        <Grid RowDefinitions="Auto,Auto">
          <TextBox x:Name="StartSearch" Margin="12,12" PlaceholderText="Search applications and commands"
                   Padding="12,0" TextChanged="OnStartSearchChanged" />
          <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="12,8,12,12" ColumnSpacing="12">
            <StackPanel x:Name="StartAppsPanel" Spacing="4">
              <TextBlock Text="APPLICATIONS" Foreground="#8EBDFF" FontFamily="Noto Sans Mono" FontSize="10" FontWeight="Bold" Margin="4,0,0,4" />
              <Button Classes="tree" Tag="files" Content="▣  Files Explorer" Click="OnAction" />
              <Button Classes="tree" Tag="terminal" Content="&gt;_  Terminal" Click="OnAction" />
              <Button Classes="tree" Tag="runtime" Content="◈  Runtime Monitor" Click="OnAction" />
              <Button Classes="tree" Tag="network" Content="◇  Network Inspector (preview)" Click="OnAction" />
              <Button Classes="tree" Tag="settings" Content="⚙  Settings" Click="OnAction" />
            </StackPanel>
            <StackPanel x:Name="StartSystemPanel" Grid.Column="1" Spacing="4">
              <TextBlock Text="SYSTEM" Foreground="#8EBDFF" FontFamily="Noto Sans Mono" FontSize="10" FontWeight="Bold" Margin="4,0,0,4" />
              <Button Classes="tree" Tag="root" Content="⌂  Root" Click="OnAction" />
              <Button Classes="tree" Tag="home" Content="●  Home" Click="OnAction" />
              <Button Classes="tree" Tag="verify" Content="✓  Platform State" Click="OnAction" />
              <Button Classes="tree" Tag="reboot" Content="↻  Reboot" Click="OnAction" />
              <Button Classes="tree" Tag="poweroff" Content="⏻  Power Off" Click="OnAction" />
            </StackPanel>
          </Grid>
        </Grid>
      </Border>

      <!-- Command palette -->
      <Border x:Name="CommandPalette" IsVisible="False" Width="620" HorizontalAlignment="Center" VerticalAlignment="Top"
              Margin="0,80,0,0" ZIndex="150" Background="#F514161A" BorderBrush="{StaticResource StrokeStrongBrush}"
              BorderThickness="1" CornerRadius="11" Padding="12" BoxShadow="0 26 76 0 #E0000000">
        <StackPanel Spacing="8">
          <TextBox x:Name="PaletteInput" PlaceholderText="Type a command..." Height="32" Padding="12,0" KeyDown="OnPaletteKeyDown" />
          <Grid ColumnDefinitions="*,Auto"><TextBlock Text="Files Explorer" /><TextBlock Grid.Column="1" Text="files" Foreground="#7FB2ED" FontFamily="Noto Sans Mono" /></Grid>
          <Grid ColumnDefinitions="*,Auto"><TextBlock Text="Terminal" /><TextBlock Grid.Column="1" Text="terminal" Foreground="#7FB2ED" FontFamily="Noto Sans Mono" /></Grid>
          <Grid ColumnDefinitions="*,Auto"><TextBlock Text="Runtime Monitor" /><TextBlock Grid.Column="1" Text="runtime" Foreground="#7FB2ED" FontFamily="Noto Sans Mono" /></Grid>
          <Grid ColumnDefinitions="*,Auto"><TextBlock Text="Settings" /><TextBlock Grid.Column="1" Text="settings" Foreground="#7FB2ED" FontFamily="Noto Sans Mono" /></Grid>
        </StackPanel>
      </Border>

      <!-- Console pull hint: appears when the pointer nears the top edge -->
      <Border x:Name="ConsoleGrip" ZIndex="190" Width="120" Height="5" CornerRadius="3"
              Background="#4CFFFFFF" VerticalAlignment="Top" HorizontalAlignment="Center"
              Margin="0,4,0,0" Opacity="0" IsHitTestVisible="False">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
          </Transitions>
        </Border.Transitions>
      </Border>

      <!-- System console layer: pulled down from the top edge (or F12) -->
      <Border x:Name="ConsoleLayer" ZIndex="200" Background="#F5111316" IsVisible="False">
        <Grid RowDefinitions="*,40,18" Margin="0">
          <ScrollViewer x:Name="ConsoleScroll" Margin="28,24,28,4">
            <StackPanel x:Name="ConsoleLines" Spacing="4" />
          </ScrollViewer>
          <Grid Grid.Row="1" Margin="28,0" ColumnDefinitions="Auto,*">
            <TextBlock x:Name="ConsolePrompt" Text="system#" Foreground="#27EE91" FontWeight="Bold"
                       FontFamily="Noto Sans Mono" FontSize="12" VerticalAlignment="Center" />
            <TextBox x:Name="ConsoleInput" Grid.Column="1" Margin="8,0,0,0" Padding="4,0" Background="Transparent"
                     BorderThickness="0" FontFamily="Noto Sans Mono" KeyDown="OnConsoleKeyDown" />
          </Grid>
          <Border Grid.Row="2" />
        </Grid>
      </Border>

      <!-- Taskbar -->
      <Border Height="48" VerticalAlignment="Bottom" ZIndex="140" Background="#F0121418"
              BorderBrush="#4C4796FF" BorderThickness="0,1,0,0">
        <!-- The 1px top border eats into the 48px bar; the bottom margin
             compensates so children center on the true visual middle. -->
        <Grid ColumnDefinitions="Auto,1,*,Auto" Margin="8,0,8,1" ColumnSpacing="8">
          <Button Grid.Column="0" Classes="start" Tag="start" Click="OnAction" Content="▰  Start" />
          <Border Grid.Column="1" Width="1" Height="24" Background="#20FFFFFF" />
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button x:Name="TerminalTask" Classes="task active" Tag="TerminalWindow" Content="▣  Terminal" Click="OnTaskClick" />
            <Button x:Name="FilesTask" Classes="task" Tag="FilesWindow" Content="▣  Files" Click="OnTaskClick" />
            <Button x:Name="RuntimeTask" Classes="task" Tag="RuntimeWindow" Content="◈  Runtime Monitor" Click="OnTaskClick" />
            <Button x:Name="NetworkTask" Classes="task" Tag="NetworkWindow" Content="◇  Network" Click="OnTaskClick" IsVisible="False" />
          </StackPanel>
          <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock x:Name="TrayGraphicsDot" Text="● MWM" Foreground="#6E7F98" FontFamily="Noto Sans Mono"
                       FontSize="10" VerticalAlignment="Center" />
            <TextBlock x:Name="TrayVolumesDot" Text="● VOL" Foreground="#6E7F98" FontFamily="Noto Sans Mono"
                       FontSize="10" VerticalAlignment="Center" />
            <Border BorderBrush="#20FFFFFF" BorderThickness="1,0,0,0" Padding="12,0,0,0" VerticalAlignment="Center">
              <TextBlock x:Name="TrayClock" Text="--:--:--" Foreground="#C4DCFF" FontFamily="Noto Sans Mono"
                         FontSize="10" VerticalAlignment="Center" />
            </Border>
            <TextBlock x:Name="DateText" Text="" Foreground="#91B7E8" FontFamily="Noto Sans Mono"
                       FontSize="10" VerticalAlignment="Center" />
            <Button Width="24" Height="32" Padding="0" Margin="4,0,0,0" Background="Transparent"
                    BorderBrush="#20FFFFFF" BorderThickness="1,0,0,0" CornerRadius="0"
                    Tag="showdesktop" Click="OnAction" ToolTip.Tip="Show desktop" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </LayoutTransformControl>
</Window>
