<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Mixtar HIG tokens and control styles - the single source of
       visual truth (Product/HIG.md is the written contract). -->
  <Styles.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#D914161A" />
    <SolidColorBrush x:Key="PanelSoftBrush" Color="#E6191B20" />
    <SolidColorBrush x:Key="StrokeBrush" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="StrokeStrongBrush" Color="#4DFFFFFF" />
    <SolidColorBrush x:Key="AccentBrush" Color="#18B9FF" />
    <SolidColorBrush x:Key="TextBrush" Color="#E8EEF7" />
    <SolidColorBrush x:Key="SoftBrush" Color="#A7B8CF" />
    <SolidColorBrush x:Key="MutedBrush" Color="#6E7F98" />
    <SolidColorBrush x:Key="MonoBrush" Color="#B9CBE4" />
  </Styles.Resources>

    <Style Selector="Border.desktop-window">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="BoxShadow" Value="inset 0 1 1 0 #1AFFFFFF, 0 15 35 0 #99000000" />
    </Style>
    <Style Selector="Border.desktop-window.active">
      <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}" />
      <Setter Property="BoxShadow" Value="inset 0 1 1 0 #26FFFFFF, 0 18 42 0 #B3000000" />
    </Style>
    <Style Selector="Border.titlebar">
      <Setter Property="Height" Value="34" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#1AFFFFFF" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="12,0,0,0" />
    </Style>
    <Style Selector="TextBlock.window-title">
      <Setter Property="Foreground" Value="#CFD8E6" />
      <Setter Property="FontFamily" Value="Noto Sans" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="LetterSpacing" Value="0.6" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <!-- Caption buttons per Mixtar-Studio "Stealth Dark Plex"
         (dark_plex_aero_vs_faux_aero.html): 46px square buttons, aero-blue
         hover for min/max, red gradient hover for close. -->
    <Style Selector="Button.window-dot">
      <Setter Property="Width" Value="46" />
      <Setter Property="Height" Value="33" />
      <Setter Property="MinWidth" Value="46" />
      <Setter Property="MinHeight" Value="33" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#DFDFDF" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontFamily" Value="Noto Sans" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.window-dot:pointerover">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#5BA4E5" Offset="0" />
          <GradientStop Color="#4388CC" Offset="0.49" />
          <GradientStop Color="#2969AD" Offset="0.5" />
          <GradientStop Color="#1C528F" Offset="1" />
        </LinearGradientBrush>
      </Setter>
    </Style>
    <Style Selector="Button.window-dot.close:pointerover">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#E85F51" Offset="0" />
          <GradientStop Color="#D34031" Offset="0.49" />
          <GradientStop Color="#B52B1E" Offset="0.5" />
          <GradientStop Color="#8E1C12" Offset="1" />
        </LinearGradientBrush>
      </Setter>
    </Style>
    <!-- Caption glyphs as vectors, 1:1 from the Studio spec: one shared
         10x10 viewBox, stroke 1.5, no fill. The minimize dash (y 8-9)
         ends exactly on the bottom edge of the box and the cross - the
         Aero baseline. Vectors also sidestep the guest font missing ✕. -->
    <Style Selector="Button.window-dot.min">
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
            <Path Width="10" Height="10" Stretch="None" Data="M 1,8 L 9,8 L 9,9 L 1,9 Z"
                  Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.window-dot.max">
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
            <Path Width="10" Height="10" Stretch="None" Data="M 1,1 L 9,1 L 9,9 L 1,9 Z"
                  Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.window-dot.close">
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
            <Path Width="10" Height="10" Stretch="None" Data="M 1,1 L 9,9 M 9,1 L 1,9"
                  Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <!-- Maximized state swaps the box for the Windows restore glyph:
         front square at (1,3), back square peeking out top-right. -->
    <Style Selector="Button.window-dot.max.restore">
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
            <Path Width="10" Height="10" Stretch="None"
                  Data="M 1,3 L 7,3 L 7,9 L 1,9 Z M 3,3 L 3,1 L 9,1 L 9,7 L 7,7"
                  Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.tool">
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Background" Value="#B2262A31" />
      <Setter Property="BorderBrush" Value="#47FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tool:pointerover"><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></Style>
    <Style Selector="Button.tool.danger"><Setter Property="BorderBrush" Value="#B0FF5C7B" /></Style>
    <Style Selector="Button.tree">
      <Setter Property="Height" Value="28" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Foreground" Value="#C2DBFF" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tree:pointerover"><Setter Property="Background" Value="#293A7EE6" /></Style>
    <Style Selector="Button.column-header">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Foreground" Value="#8BBCFF" />
      <Setter Property="FontFamily" Value="Noto Sans Mono" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.column-header:pointerover"><Setter Property="Foreground" Value="White" /></Style>
    <Style Selector="Button.crumb">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Foreground" Value="#C2DBFF" />
      <Setter Property="FontFamily" Value="Noto Sans Mono" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.crumb:pointerover">
      <Setter Property="Background" Value="#33417EE6" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <!-- Titlebar tabs: uniform-width 32px pills sharing one vertical axis
         with the + button and the caption buttons (user decision 19.07). -->
    <Style Selector="Button.file-tab">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="12,4" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#A9B4C4" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.file-tab:pointerover">
      <Setter Property="Background" Value="#0DFFFFFF" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.file-tab.active">
      <Setter Property="Background" Value="#26FFFFFF" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.tab-add">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#A9B4C4" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tab-add:pointerover">
      <Setter Property="Background" Value="#0DFFFFFF" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.tab-close">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#8894A6" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
            <Path Width="8" Height="8" Stretch="None" Data="M 1,1 L 7,7 M 7,1 L 1,7"
                  Stroke="{TemplateBinding Foreground}" StrokeThickness="1.2"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.tab-close:pointerover">
      <Setter Property="Background" Value="#33FFFFFF" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.task">
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Foreground" Value="#A9C4EC" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="Button.task.active">
      <Setter Property="Background" Value="#363568DB" />
      <Setter Property="BorderBrush" Value="#704C97FF" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.task.minimized"><Setter Property="Opacity" Value="0.55" /></Style>
    <Style Selector="Button.start">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="Background" Value="#0B65D8" />
      <Setter Property="BorderBrush" Value="#5EA8FF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.hud-item">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="Foreground" Value="{StaticResource SoftBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.hud-item:pointerover"><Setter Property="Foreground" Value="White" /></Style>
    <!-- The visual stays a 12px dot; the button around it is a 24x24
         transparent hit area (HIG minimum click target). -->
    <Style Selector="Button.map-node">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="#6B94C9" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="Transparent">
            <Border Width="12" Height="12" CornerRadius="6"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{TemplateBinding Background}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.map-node.local"><Setter Property="Background" Value="#FFC65C" /></Style>
    <Style Selector="Button.map-node.selected"><Setter Property="Background" Value="White" /></Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="#E01B1E24" />
      <Setter Property="BorderBrush" Value="#12FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="7" />
    </Style>
    <Style Selector="Border.file-row">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="BorderBrush" Value="#0EFFFFFF" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Border.file-row:pointerover"><Setter Property="Background" Value="#273580DB" /></Style>
    <Style Selector="Border.file-row.selected">
      <Setter Property="Background" Value="#473580DB" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="3,0,0,1" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Background" Value="#80000000" />
      <Setter Property="BorderBrush" Value="#425FA2FF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="CaretBrush" Value="White" />
      <Setter Property="SelectionBrush" Value="#703580DB" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
</Styles>
