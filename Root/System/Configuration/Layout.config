schema = 1

[identity]
name = "MixtarRVS"
architecture = "x86_64"

[layout]
system = "/System"
commands = "/System/Commands"
core = "/System/Core"
init = "/System/Init"
libraries = "/System/Libraries"
configuration = "/System/Configuration"
state = "/System/State"
cache = "/System/Cache"
logs = "/System/Logs"
runtime = "/System/Runtime"
processes = "/System/Processes"
hardware = "/System/Hardware"
devices = "/System/Devices"
terminal = "/System/Terminal"
users = "/Users"
volumes = "/Volumes"
temporary = "/Temporary"

[boot]
pid1 = "/System/Init/MixtarRVS"
system_shell = "/System/Terminal/POSIX/sh"
user_shell = "/System/Terminal/ZSH/zsh"
console = "ttyS0"
qemu_memory_mib = 1024
qemu_timeout_seconds = 90
source_date_epoch = 315532800

[build]
wsl_distro = "Debian"
jobs = "auto"
compiler_cache = true
compiler_cache_size = "20GiB"
p0_output = "Output/P0"
cache_directory = ".cache"
host_cache = "Cache"

[components.linux]
architecture = "x86_64"

[components.openzfs]
pool = "mixtar"
root_dataset = "mixtar/ROOT/default"
lifecycle_datasets = [
  { path = "DATA/users", target = "/Users", lifecycle = "persistent" },
  { path = "STATE/system", target = "/System/State", lifecycle = "persistent" },
  { path = "STATE/logs", target = "/System/Logs", lifecycle = "persistent" },
  { path = "CACHE", target = "/System/Cache", lifecycle = "rebuildable" },
]

[components.openrc]
role = "pid1"

[components.busybox]
modules_directory = "/System/Kernel/Linux"
depmod_file = "modules.dep"
kconfig_symbols = [
    "CONFIG_BUSYBOX",
    "CONFIG_CAT",
    "CONFIG_STATIC",
    "CONFIG_ASH",
    "CONFIG_SH_IS_ASH",
    "CONFIG_MKDIR",
    "CONFIG_MOUNT",
    "CONFIG_MOUNTPOINT",
    "CONFIG_GREP",
    "CONFIG_HOSTNAME",
    "CONFIG_POWEROFF",
    "CONFIG_RM",
    "CONFIG_SYNC",
    "CONFIG_TOUCH",
    "CONFIG_TEST",
    "CONFIG_PRINTF",
    "CONFIG_ASH_PRINTF",
    "CONFIG_ASH_TEST",
    "CONFIG_FEATURE_SH_MATH",
    "CONFIG_FEATURE_SH_STANDALONE",
    "CONFIG_FEATURE_MOUNT_FLAGS",
    "CONFIG_ECHO",
    "CONFIG_ASH_ECHO",
  "CONFIG_ASH_CMDCMD",
  "CONFIG_CTTYHACK",
  "CONFIG_SETSID",
  "CONFIG_MODPROBE",
  "CONFIG_INSMOD",
  "CONFIG_RMMOD",
  "CONFIG_LSMOD",
    "CONFIG_DEPMOD",
    "CONFIG_CP",
    "CONFIG_CHMOD",
    "CONFIG_CHOWN",
    "CONFIG_MDEV",
    "CONFIG_MKNOD",
    "CONFIG_SLEEP",
    "CONFIG_SWITCH_ROOT",
    "CONFIG_TAR",
    "CONFIG_UMOUNT",
  "CONFIG_GETTY",
  "CONFIG_LOGIN",
  "CONFIG_PASSWD",
  "CONFIG_CRYPTPW",
  "CONFIG_FEATURE_SHADOWPASSWDS",
  "CONFIG_FEATURE_SECURETTY",
  "CONFIG_USE_BB_PWD_GRP",
  "CONFIG_USE_BB_SHADOW",
  "CONFIG_USE_BB_CRYPT",
  "CONFIG_USE_BB_CRYPT_SHA",
  "CONFIG_AWK",
  "CONFIG_BLKID",
  "CONFIG_FEATURE_BLKID_TYPE",
  "CONFIG_FEATURE_VOLUMEID_BTRFS",
  "CONFIG_FEATURE_VOLUMEID_EXT",
  "CONFIG_FEATURE_VOLUMEID_FAT",
  "CONFIG_FEATURE_VOLUMEID_XFS",
  "CONFIG_CUT",
  "CONFIG_DATE",
  "CONFIG_HWCLOCK",
  "CONFIG_IFCONFIG",
  "CONFIG_ROUTE",
  "CONFIG_IP",
  "CONFIG_FEATURE_IP_ADDRESS",
  "CONFIG_FEATURE_IP_LINK",
  "CONFIG_FEATURE_IP_ROUTE",
  "CONFIG_KLOGD",
  "CONFIG_KILLALL",
  "CONFIG_LOGGER",
  "CONFIG_MV",
  "CONFIG_NSLOOKUP",
  "CONFIG_PIDOF",
  "CONFIG_PING",
  "CONFIG_READLINK",
  "CONFIG_SED",
  "CONFIG_SYSLOGD",
  "CONFIG_FEATURE_ROTATE_LOGFILE",
  "CONFIG_TR",
  "CONFIG_UDHCPC",
  "CONFIG_FEATURE_UDHCP_RFC3397",
  "CONFIG_WGET",
  "CONFIG_FEATURE_WGET_LONG_OPTIONS",
  "CONFIG_SHA256SUM",
  "CONFIG_FEATURE_MDEV_CONF",
  "CONFIG_FEATURE_MDEV_EXEC",
]
expected_applets = [
    "ash",
    "cat",
    "chmod",
    "chown",
    "cryptpw",
    "echo",
    "getty",
    "grep",
    "hostname",
    "login",
    "mkdir",
    "mount",
    "mountpoint",
    "passwd",
    "poweroff",
    "printf",
    "rm",
    "sh",
    "sync",
    "touch",
  "test",
  "cttyhack",
  "setsid",
  "modprobe",
  "insmod",
  "rmmod",
  "lsmod",
  "depmod",
  "cp",
  "mdev",
  "mknod",
  "sleep",
  "switch_root",
  "tar",
  "umount",
  "awk",
  "blkid",
  "cut",
  "date",
  "hwclock",
  "ifconfig",
  "route",
  "ip",
  "klogd",
  "killall",
  "logger",
  "mv",
  "nslookup",
  "pidof",
  "ping",
  "readlink",
  "sed",
  "syslogd",
  "tr",
  "udhcpc",
  "wget",
  "sha256sum",
]

[components.zsh]
role = "interactive-shell"

[security]
release_public_key = "/System/Configuration/Release/M1.public.pem"
module_signatures_required = true
secure_boot_artifacts = true

[update]
dataset_parent = "mixtar/ROOT"
esp_mount = "/System/EFI"
firmware_path = "/System/EFI/BOOT/BOOTX64.EFI"
previous_firmware_path = "/System/EFI/Mixtar/Previous.EFI"
recovery_firmware_path = "/System/EFI/Mixtar/Recovery.EFI"
transaction_state = "/System/State/Update/Transaction.config"

[test]
command_line_key = "mixtar.test"
poweroff_mode = "poweroff"
reboot_mode = "reboot"
