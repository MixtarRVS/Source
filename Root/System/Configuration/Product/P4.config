schema = 1

[identity]
name = "Mixtar P4 product budgets"
contract = "P4.md"

[policy]
result = "hard-limit-fails-release"
target_is_optimization_goal = true
hard_limit_is_release_gate = true
percent_cpu_scope = "one-logical-core"
memory_metric = "private-working-set"
time_clock = "monotonic"

[reference]
architecture = "x86_64"
virtual_cpus = 4
memory_mib = 4096
storage = "ssd"
release_build = true
warmup_runs = 3
measured_runs = 10
idle_window_seconds = 60

[baseline.avalonia_native_aot]
status = "prototype-only-not-release-evidence"
framework = "Avalonia 12.1"
runtime = "stable .NET 10 Native AOT"
warm_start_ms = 220.93
working_set_mib = 94.91
private_memory_mib = 135.39
idle_cpu_percent = 0.519
payload_mib = 136.21

[boot.console]
target_ms = 5000
hard_limit_ms = 10000

[boot.greeter]
target_ms = 7000
hard_limit_ms = 12000

[session.login_to_interactive]
target_ms = 1500
hard_limit_ms = 3000

[apx.reference_window_warm_start]
target_ms = 250
hard_limit_ms = 500

[apx.reference_window_cold_start]
target_ms = 750
hard_limit_ms = 1500

[apx.reference_window_memory]
target_working_set_mib = 96
hard_limit_working_set_mib = 128
target_private_mib = 144
hard_limit_private_mib = 160

[apx.reference_window_idle]
target_cpu_percent = 0.5
hard_limit_cpu_percent = 1.5

[session.graphical_idle]
target_working_set_mib = 256
hard_limit_working_set_mib = 384
target_cpu_percent = 1.0
hard_limit_cpu_percent = 2.0

[storage]
reference_apx_payload_target_mib = 144
reference_apx_payload_hard_limit_mib = 160
graphical_base_increment_target_mib = 256
graphical_base_increment_hard_limit_mib = 384
cold_start_reads_hard_limit_mib = 512
idle_writes_target_kib_per_hour = 1024
idle_writes_hard_limit_kib_per_hour = 4096

[interaction]
input_to_visible_response_target_ms = 25
input_to_visible_response_hard_limit_ms = 50
frame_time_p95_target_ms = 16.7
frame_time_p99_hard_limit_ms = 33.3

[stability]
apx_launch_cycles = 100
apx_launch_retained_growth_target_mib = 2
apx_launch_retained_growth_hard_limit_mib = 8
graphical_session_soak_hours = 8
graphical_session_retained_growth_hard_limit_mib = 32

[console_regression]
boots_without_graphical_stack = true
boots_when_mwm_fails = true
boots_when_avalonia_is_missing = true
requires_independent_console_image_gate = true
