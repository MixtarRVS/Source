# Mixtar login profile for Linux-PAM.
#
# Policy:
# - keep PAM as the real password authority
# - avoid multi-second desktop-manager failure delays
# - rely on the greeter/helper cooldown and lockout for repeated failures
# - establish a normal login session after authentication

auth       requisite  pam_nologin.so
auth       optional   pam_faildelay.so delay=250000
auth       required   pam_unix.so nodelay
account    required   pam_unix.so
password   required   pam_unix.so
session    required   pam_limits.so
session    required   pam_unix.so
session    optional   pam_umask.so umask=0077
session    optional   pam_env.so
