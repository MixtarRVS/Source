{
  "name": "MixtarRVS CoreV07",
  "version": "0.8",
  "policy": {
    "debian": "build-rescue-only",
    "mutation_scope": "repo-staging-only",
    "posix_identity": "compatibility-only",
    "native_root_is_clean": true,
    "sudo_default": false
  },
  "boot": {
    "mode": "single-uki",
    "official_artifact": "/System/EFI/MixtarRVS/0.8.efi",
    "official_artifact_provenance": "/System/EFI/MixtarRVS/0.8.efi.provenance",
    "efi_stage_artifact": "EFI/MixtarRVS/0.8.efi",
    "efi_stage_artifact_provenance": "EFI/MixtarRVS/0.8.efi.provenance",
    "forbidden_official_artifacts": [
      "/System/EFI/MixtarRVS/Current.efi",
      "/System/EFI/MixtarRVS/Previous.efi",
      "/System/Kernel/Linux/RT/7.1.2/vmlinuz",
      "/System/Kernel/Linux/RT/7.1.2/initramfs",
      "/System/Kernel/Linux/RT/7.1.2/initrd"
    ]
  },
  "kernel": {
    "family": "Linux",
    "profile": "RT",
    "version": "7.1.2",
    "layout": "/System/Kernel/Linux/RT/7.1.2"
  },
  "init": {
    "pid1": "/System/Init/MixtarRVS",
    "must_supervise_forever": true,
    "must_not_return_child_status": true
  },
  "shell": {
    "default": "/System/Shells/zsh",
    "prompt_is_configuration": true
  },
  "native_root": [
    "/Applications",
    "/System",
    "/Users",
    "/Volumes",
    "/Temporary"
  ],
  "forbidden_native_root": [
    "/bin",
    "/boot",
    "/dev",
    "/etc",
    "/home",
    "/lib",
    "/lib64",
    "/proc",
    "/root",
    "/run",
    "/sbin",
    "/sys",
    "/tmp",
    "/usr",
    "/var"
  ],
  "system_paths": [
    "/System/Init",
    "/System/Kernel",
    "/System/Kernel/Linux/RT/7.1.2",
    "/System/EFI/MixtarRVS",
    "/System/Shells",
    "/System/Userland",
    "/System/Tools",
    "/System/Drivers",
    "/System/Libraries",
    "/System/Configuration",
    "/System/Resources",
    "/System/Logs",
    "/System/Runtime",
    "/System/Runtime/Devices",
    "/System/Runtime/Kernel/proc",
    "/System/Runtime/Kernel/sys",
    "/System/Runtime/Sessions",
    "/System/Runtime/Sockets",
    "/System/Runtime/Security",
    "/System/Security",
    "/System/UI",
    "/System/Compatibility"
  ],
  "compatibility_roots": [
    "/System/Compatibility/POSIX",
    "/System/Compatibility/POSIX/Linux",
    "/System/Compatibility/POSIX/OpenBSD",
    "/System/Compatibility/POSIX/FreeBSD"
  ],
  "native_userland": {
    "path": "/System/Userland",
    "mode": "command-root"
  },
  "administrative_tools": {
    "path": "/System/Tools",
    "mode": "admin-only"
  },
  "driver_store": {
    "path": "/System/Drivers",
    "mode": "store-only"
  },
  "security": {
    "authority": "/System/Security",
    "policy": "/System/Configuration/Security/Policy.config",
    "runtime": "/System/Runtime/Security",
    "admin_mode": "session-token"
  },
  "ui": {
    "namespace": "/System/UI",
    "system_shell_apx": "/System/UI/Shell/MixtarShell.apx",
    "graphical_enabled": false
  }
}
