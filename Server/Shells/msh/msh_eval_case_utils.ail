// msh_eval_case_utils.ail
// Helpers for evaluating textual CASE AST nodes.

import msh_defs
import msh_arith_state
import msh_ast
import msh_expansion
import msh_expand_state
import msh_expand_vars
import msh_pattern
import msh_subst

int msh_eval_find_item_end(text: string):
    depth = 0
    in_quote = 0
    i = 0
    n = strlen(text)
    while i < n then
        c = char_at(text, i)
        if in_quote == 1 then
            if c == MSH_CH_BACKSLASH and i + 1 < n then
                i++
            elsif c == MSH_CH_DQUOTE then
                in_quote = 0
            end
        elsif c == MSH_CH_DQUOTE then
            in_quote = 1
        elsif c == MSH_CH_LPAREN or c == MSH_CH_LBRACKET or c == MSH_CH_LBRACE then
            depth++
        elsif c == MSH_CH_RPAREN or c == MSH_CH_RBRACKET or c == MSH_CH_RBRACE then
            if c == MSH_CH_RPAREN and depth == 1 then
                return i
            end
            if depth > 0 then
                depth--
            end
        end
        i++
    end
    return MSH_INDEX_NOT_FOUND
end

int msh_eval_case_patterns_match(patterns: string, subject: string):
    marker = "" + "WORD(\""
    pos = index_of(patterns, marker)
    while pos != MSH_INDEX_NOT_FOUND then
        start = pos + strlen(marker)
        stop = msh_ast_string_end(patterns, start)
        if stop == MSH_INDEX_NOT_FOUND then
            pos = MSH_INDEX_NOT_FOUND
        else
            encoded_pat = substr(patterns, start, stop - start)
            pat = msh_ast_unescape(encoded_pat)
            if msh_pattern_match(pat, subject) == 1 then
                dealloc(marker, encoded_pat, pat)
                return 1
            end
            dealloc(encoded_pat, pat)
            pos = index_of_from(patterns, marker, stop + 1)
        end
    end
    dealloc(marker)
    return 0
end

string msh_eval_case_append_pattern_text(out: string, text: string, quoted: int):
    next_out = "" + out
    i = 0
    while i < strlen(text) then
        old = next_out
        if quoted == 1 then
            next_out = msh_pattern_append_literal(next_out, char_at(text, i))
        else
            next_out = msh_str_append_char(next_out, char_at(text, i))
        end
        dealloc(old)
        i++
    end
    return next_out
end

def msh_eval_case_expand_pattern_word_state(word: string, vars: string, last_status: int): MshWordExpandResult
    if msh_pattern_word_has_quote_syntax(word) == 0 then
        return msh_expand_word_state(word, vars, last_status)
    end

    out = "" + ""
    current_vars = "" + vars
    i = 0
    in_single = 0
    in_double = 0
    while i < strlen(word) then
        c = char_at(word, i)
        if in_single == 1 then
            if c == MSH_CH_SQUOTE or c == MSH_Q_END then
                in_single = 0
            else
                old_sq = out
                out = msh_pattern_append_literal(out, c)
                dealloc(old_sq)
            end
        elsif (c == MSH_CH_SQUOTE or c == MSH_Q_SINGLE) and in_double == 0 then
            in_single = 1
        elsif c == MSH_Q_END and in_double == 1 then
            in_double = 0
        elsif c == MSH_CH_DQUOTE or c == MSH_Q_DOUBLE then
            if in_double == 1 then
                in_double = 0
            else
                in_double = 1
            end
        elsif c == MSH_Q_ESC and i + 1 < strlen(word) then
            i++
            old_esc = out
            out = msh_pattern_append_literal(out, char_at(word, i))
            dealloc(old_esc)
        elsif c == MSH_CH_BACKTICK then
            close_tick = msh_find_backquote_close(word, i + 1)
            if close_tick == MSH_INDEX_NOT_FOUND then
                old_tick = out
                out = msh_str_append_char(out, c)
                dealloc(old_tick)
            else
                body_tick = substr(word, i + 1, close_tick - i - 1)
                cmd_tick = msh_unescape_backquote_body(body_tick)
                raw_tick = msh_subst_capture_with_vars(cmd_tick, current_vars)
                value_tick = msh_trim_command_output(raw_tick)
                old_tick_value = out
                out = msh_eval_case_append_pattern_text(out, value_tick, in_double)
                dealloc(old_tick_value, body_tick, cmd_tick, raw_tick, value_tick)
                i = close_tick
            end
        elsif c == MSH_CH_DOLLAR and i + 1 < strlen(word) then
            next = char_at(word, i + 1)
            if next == MSH_CH_LBRACE then
                close = msh_find_brace_close(word, i + 2)
                if close == MSH_INDEX_NOT_FOUND then
                    old_bad = out
                    out = msh_str_append_char(out, c)
                    dealloc(old_bad)
                else
                    body = substr(word, i + 2, close - i - 2)
                    value_result = msh_expand_braced_body_state(body, current_vars, last_status)
                    if value_result.status != 0 then
                        dealloc(out, current_vars, body)
                        return value_result
                    end
                    old_body = out
                    out = msh_eval_case_append_pattern_text(out, value_result.text, in_double)
                    dealloc(old_body)
                    dealloc(current_vars)
                    current_vars = "" + value_result.vars
                    dealloc(body, value_result.text, value_result.vars)
                    i = close
                end
            elsif next == MSH_CH_LPAREN and i + 2 < strlen(word) and char_at(word, i + 2) == MSH_CH_LPAREN then
                close_arith = msh_find_arith_close(word, i + 3)
                if close_arith == MSH_INDEX_NOT_FOUND then
                    old_arith_bad = out
                    out = msh_str_append_char(out, c)
                    dealloc(old_arith_bad)
                else
                    expr = substr(word, i + 3, close_arith - i - 3)
                    arith_result = msh_arith_expand_state(expr, current_vars)
                    old_arith = out
                    out = msh_eval_case_append_pattern_text(out, arith_result.text, in_double)
                    dealloc(old_arith)
                    dealloc(current_vars)
                    current_vars = "" + arith_result.vars
                    dealloc(expr, arith_result.text, arith_result.vars)
                    i = close_arith + 1
                end
            elsif next == MSH_CH_LPAREN then
                close_cmd = msh_find_command_sub_close(word, i + 2)
                if close_cmd == MSH_INDEX_NOT_FOUND then
                    old_cmd_bad = out
                    out = msh_str_append_char(out, c)
                    dealloc(old_cmd_bad)
                else
                    cmd = substr(word, i + 2, close_cmd - i - 2)
                    raw = msh_subst_capture_with_vars(cmd, current_vars)
                    value = msh_trim_command_output(raw)
                    old_cmd = out
                    out = msh_eval_case_append_pattern_text(out, value, in_double)
                    dealloc(old_cmd, cmd, raw, value)
                    i = close_cmd
                end
            elsif msh_is_name_start(next) == 1 then
                end_pos = msh_name_end(word, i + 1)
                name = substr(word, i + 1, end_pos - i - 1)
                value = msh_param_value(current_vars, name, last_status)
                old_name = out
                out = msh_eval_case_append_pattern_text(out, value, in_double)
                dealloc(old_name, name, value)
                i = end_pos - 1
            else
                name2 = chr(next)
                value2 = msh_param_value(current_vars, name2, last_status)
                old_special = out
                out = msh_eval_case_append_pattern_text(out, value2, in_double)
                dealloc(old_special, name2, value2)
                i++
            end
        else
            old_plain = out
            if in_double == 1 then
                out = msh_pattern_append_literal(out, c)
            else
                out = msh_str_append_char(out, c)
            end
            dealloc(old_plain)
        end
        i++
    end
    return new MshWordExpandResult(out, current_vars, 0)
end

int msh_eval_case_patterns_match_state(patterns: string, subject: string, vars: string, last_status: int):
    marker = "" + "WORD(\""
    pos = index_of(patterns, marker)
    while pos != MSH_INDEX_NOT_FOUND then
        start = pos + strlen(marker)
        stop = msh_ast_string_end(patterns, start)
        if stop == MSH_INDEX_NOT_FOUND then
            pos = MSH_INDEX_NOT_FOUND
        else
            encoded_pat = substr(patterns, start, stop - start)
            raw_pat = msh_ast_unescape(encoded_pat)
            pat_result = msh_eval_case_expand_pattern_word_state(raw_pat, vars, last_status)
            if pat_result.status == 0 and msh_pattern_match(pat_result.text, subject) == 1 then
                dealloc(marker, encoded_pat, raw_pat, pat_result.text, pat_result.vars)
                return 1
            end
            dealloc(encoded_pat, raw_pat, pat_result.text, pat_result.vars)
            pos = index_of_from(patterns, marker, stop + 1)
        end
    end
    dealloc(marker)
    return 0
end
