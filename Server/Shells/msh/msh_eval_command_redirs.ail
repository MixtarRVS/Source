// msh_eval_command_redirs.ail
// Redirection frame for eval-like command paths.

import msh_eval_result
import msh_control
import msh_defs
import msh_exec
import msh_exec_fdrestore
import msh_exec_fds
import msh_fd_scope
import msh_quote
import msh_redirs
import msh_state

extern fn msh_eval_source_state_internal(source: string, vars: string): MshEvalResult

string msh_eval_decode_eval_source(source: string):
    out = "" + ""
    i = 0
    while i < strlen(source) then
        c = char_at(source, i)
        if msh_quote_is_marker(c) == 1 then
            i++
            continue
        elsif c == MSH_CH_CR then
            ch = chr(MSH_CH_LF)
        else
            ch = chr(c)
        end
        old = out
        out = out + ch
        dealloc(old, ch)
        i++
    end
    return out
end

def msh_eval_source_with_redir_prefix(source: string, vars: string): MshEvalResult
    key = "" + "__redir_diag_prefix"
    old_prefix = msh_state_get(vars, key)
    tagged = msh_state_set(vars, key, "eval")
    decoded = msh_eval_decode_eval_source(source)
    eval_result = msh_eval_source_state_internal(decoded, tagged)
    if strlen(old_prefix) > 0 then
        restored_vars = msh_state_set(eval_result.vars, key, old_prefix)
    else
        restored_vars = msh_state_unset(eval_result.vars, key)
    end
    status = eval_result.status
    parse_error = msh_state_get(restored_vars, "__parse_error")
    if parse_error == "1" then
        without_parse = msh_state_unset(restored_vars, "__parse_error")
        out_vars = msh_control_set(without_parse, "error_exit", status)
        dealloc(without_parse)
    else
        out_vars = "" + restored_vars
    end
    dealloc(key, old_prefix, tagged, decoded, eval_result.vars, restored_vars, parse_error)
    return new MshEvalResult(status, out_vars)
end

def msh_eval_eval_with_redirs(ast: string, source: string, vars: string): MshEvalResult
    if msh_exec_command_has_redirs(ast) == 0 then
        return msh_eval_source_with_redir_prefix(source, vars)
    end

    scope = msh_fd_scope_save()
    frame = msh_redir_save_stdio()
    if frame.ok == 0 then
        msh_redir_restore_stdio(frame)
        msh_fd_scope_restore(scope)
        dealloc(scope.pairs, scope.originals, scope.copies)
        return new MshEvalResult(1, "" + vars)
    end

    redir_status = msh_redir_apply_ast(ast, vars)
    if redir_status == 0 then
        meta_result = msh_exec_fds_apply_command_redirs(ast, vars)
        if meta_result.status == 0 then
            eval_result = msh_eval_source_with_redir_prefix(source, meta_result.vars)
            status = eval_result.status
            out_vars = msh_exec_fdrestore_ast_redirs(eval_result.vars, vars, ast)
            dealloc(eval_result.vars)
        else
            status = meta_result.status
            out_vars = "" + vars
        end
        dealloc(meta_result.vars)
    else
        status = redir_status
        out_vars = "" + vars
    end

    restore_status = msh_redir_restore_stdio(frame)
    if status == 0 and restore_status != 0 then
        status = restore_status
    end
    fd_restore_status = msh_fd_scope_restore(scope)
    if status == 0 and fd_restore_status != 0 then
        status = fd_restore_status
    end
    dealloc(scope.pairs, scope.originals, scope.copies)
    return new MshEvalResult(status, out_vars)
end
