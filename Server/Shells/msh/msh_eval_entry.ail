// msh_eval_entry.ail
// Public evaluator entry points that wrap the internal evaluator.

import msh_eval
import msh_eval_result
import msh_control
import msh_phase_state
import msh_path
import msh_state

string msh_eval_entry_base_vars(vars: string):
    out = "" + vars
    if msh_state_has(out, "IFS") == 0 then
        default_ifs = "" + " \t\n"
        ifs_vars = msh_state_set(out, "IFS", default_ifs)
        dealloc(out)
        out = msh_state_set(ifs_vars, "__entry_auto_ifs", default_ifs)
        dealloc(ifs_vars, default_ifs)
    end
    if msh_state_has(out, "PWD") == 0 then
        cwd = current_dir()
        shown_cwd = msh_path_slashify(cwd)
        pwd_vars = msh_state_set(out, "PWD", shown_cwd)
        dealloc(out)
        out = msh_state_set(pwd_vars, "__entry_auto_pwd", shown_cwd)
        dealloc(pwd_vars)
        dealloc(cwd, shown_cwd)
    end
    if msh_state_has(out, "PPID") == 0 then
        ppid_value = getppid()
        if ppid_value > 0 then
            ppid_text = str(ppid_value)
            ppid_vars = msh_state_set(out, "PPID", ppid_text)
            dealloc(out)
            out = msh_state_set(ppid_vars, "__entry_auto_ppid", ppid_text)
            dealloc(ppid_vars, ppid_text)
        end
    end
    return out
end

string msh_eval_entry_public_vars(raw_vars: string):
    public_vars = msh_state_public(raw_vars)
    without_marker = msh_state_unset(public_vars, "__entry_auto_pwd")
    dealloc(public_vars)
    public_vars = without_marker
    without_ifs_marker = msh_state_unset(public_vars, "__entry_auto_ifs")
    dealloc(public_vars)
    public_vars = without_ifs_marker
    auto_ifs = msh_state_get(raw_vars, "__entry_auto_ifs")
    if strlen(auto_ifs) > 0 then
        ifs = msh_state_get(raw_vars, "IFS")
        if ifs == auto_ifs then
            trimmed_ifs = msh_state_unset(public_vars, "IFS")
            dealloc(public_vars)
            public_vars = trimmed_ifs
        end
        dealloc(ifs)
    end
    dealloc(auto_ifs)
    auto_pwd = msh_state_get(raw_vars, "__entry_auto_pwd")
    if strlen(auto_pwd) > 0 then
        pwd = msh_state_get(raw_vars, "PWD")
        if pwd == auto_pwd then
            trimmed = msh_state_unset(public_vars, "PWD")
            dealloc(public_vars)
            public_vars = trimmed
        end
        dealloc(pwd)
    end
    dealloc(auto_pwd)
    without_ppid_marker = msh_state_unset(public_vars, "__entry_auto_ppid")
    dealloc(public_vars)
    public_vars = without_ppid_marker
    auto_ppid = msh_state_get(raw_vars, "__entry_auto_ppid")
    if strlen(auto_ppid) == 0 then
        dealloc(auto_ppid)
        return public_vars
    end
    ppid = msh_state_get(raw_vars, "PPID")
    if ppid == auto_ppid then
        trimmed_ppid = msh_state_unset(public_vars, "PPID")
        dealloc(public_vars)
        public_vars = trimmed_ppid
    end
    dealloc(auto_ppid, ppid)
    return public_vars
end

def msh_eval_source_state_full(source: string, vars: string): MshEvalResult
    base_vars = msh_eval_entry_base_vars(vars)
    eval_result = msh_eval_source_state_internal(source, base_vars)
    status = eval_result.status
    exit_action = msh_trap_get(eval_result.vars, "EXIT")
    if strlen(exit_action) > 0 and msh_trap_action_running(eval_result.vars, "EXIT") == 0 then
        status_text = str(status)
        trap_base = msh_control_clear(eval_result.vars)
        trap_marked = msh_trap_action_mark(trap_base, "EXIT", exit_action)
        trap_status_vars = msh_trap_action_status_set(trap_marked, "EXIT", status)
        trap_vars = msh_state_set(trap_status_vars, "__last_status", status_text)
        trap_result = msh_eval_source_state_internal(exit_action, trap_vars)
        if msh_control_active(trap_result.vars) == 1 then
            status = trap_result.status
        end
        public_vars = "" + trap_result.vars
        dealloc(status_text, trap_base, trap_marked, trap_status_vars, trap_vars, trap_result.vars)
    else
        public_vars = "" + eval_result.vars
    end
    dealloc(exit_action, eval_result.vars, base_vars)
    return new MshEvalResult(status, public_vars)
end

def msh_eval_source_state(source: string, vars: string): MshEvalResult
    full = msh_eval_source_state_full(source, vars)
    public_vars = msh_eval_entry_public_vars(full.vars)
    status = full.status
    dealloc(full.vars)
    return new MshEvalResult(status, public_vars)
end

def msh_eval_ast_entry(ast: string, vars: string): MshEvalResult
    base_vars = msh_eval_entry_base_vars(vars)
    eval_result = msh_eval_ast_state(ast, base_vars)
    status = eval_result.status
    exit_action = msh_trap_get(eval_result.vars, "EXIT")
    if strlen(exit_action) > 0 and msh_trap_action_running(eval_result.vars, "EXIT") == 0 then
        status_text = str(status)
        trap_base = msh_control_clear(eval_result.vars)
        trap_marked = msh_trap_action_mark(trap_base, "EXIT", exit_action)
        trap_status_vars = msh_trap_action_status_set(trap_marked, "EXIT", status)
        trap_vars = msh_state_set(trap_status_vars, "__last_status", status_text)
        trap_result = msh_eval_source_state_internal(exit_action, trap_vars)
        if msh_control_active(trap_result.vars) == 1 then
            status = trap_result.status
        end
        public_vars = msh_eval_entry_public_vars(trap_result.vars)
        dealloc(status_text, trap_base, trap_marked, trap_status_vars, trap_vars, trap_result.vars)
    else
        public_vars = msh_eval_entry_public_vars(eval_result.vars)
    end
    dealloc(exit_action, eval_result.vars, base_vars)
    return new MshEvalResult(status, public_vars)
end

int msh_eval_source(source: string):
    result = msh_eval_source_state(source, "")
    status = result.status
    dealloc(result.vars)
    return status
end
