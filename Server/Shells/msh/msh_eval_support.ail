// msh_eval_support.ail
// Small command-evaluator helpers split out of msh_eval.ail.

import msh_defs
import msh_diagnostics
import msh_errors
import msh_eval_assigns
import msh_eval_result
import msh_exec_lookup
import msh_fields

void msh_diag_dot_missing_source(source_arg: string):
    if msh_exec_name_has_path_sep(source_arg) == 1 then
        source_detail_left = "cannot open " + source_arg
        source_detail = source_detail_left + ": No such file"
        msh_diag_builtin(".", source_detail)
        dealloc(source_detail_left, source_detail)
    else
        source_detail = source_arg + ": not found"
        msh_diag_builtin(".", source_detail)
        dealloc(source_detail)
    end
end

void msh_diag_dot_cannot_open(source_arg: string, reason: string):
    source_detail_left = "cannot open " + source_arg
    source_detail_mid = source_detail_left + ": "
    source_detail = source_detail_mid + reason
    msh_diag_builtin(".", source_detail)
    dealloc(source_detail_left, source_detail_mid, source_detail)
end

def msh_eval_fields_slice(fields: str_array, skip: int): str_array
    out = str_array_new(4)
    i = skip
    while i < str_array_len(fields) then
        field = str_array_get(fields, i)
        owned = "" + field
        out = str_array_push(out, owned)
        i++
    end
    return out
end

string msh_eval_join_fields_from(fields: str_array, start: int):
    out = "" + ""
    i = start
    while i < str_array_len(fields) then
        field = str_array_get(fields, i)
        old = out
        if i == start then
            out = out + field
        else
            spaced = out + " "
            out = spaced + field
            dealloc(spaced)
        end
        dealloc(old)
        i++
    end
    return out
end

int msh_eval_dot_operand_index(fields: str_array, start: int):
    if str_array_len(fields) <= start then
        return MSH_INDEX_NOT_FOUND
    end
    first = str_array_get(fields, start)
    if first == "--" then
        if str_array_len(fields) <= start + 1 then
            return MSH_INDEX_NOT_FOUND
        end
        return start + 1
    end
    return start
end

def msh_eval_apply_special_assigns(name: string, vars: string, assigns: string): MshEvalResult
    assign_result = msh_eval_apply_assigns_state(vars, assigns)
    if assign_result.status != 0 then
        out_vars = msh_error_special_consequence(name, assign_result.status, assign_result.vars)
        status = assign_result.status
        dealloc(assign_result.vars)
        return new MshEvalResult(status, out_vars)
    end
    out_vars2 = "" + assign_result.vars
    dealloc(assign_result.vars)
    return new MshEvalResult(0, out_vars2)
end
