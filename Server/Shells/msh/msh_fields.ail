// msh_fields.ail
// Ownership helpers for shell field lists backed by str_array.

void msh_field_array_destroy(fields: str_array):
    i = 0
    while i < str_array_len(fields) then
        field = str_array_get(fields, i)
        dealloc(field)
        i++
    end
    dealloc_str_array(fields)
end
