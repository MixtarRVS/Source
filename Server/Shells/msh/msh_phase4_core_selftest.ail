int msh_expect_dot_source():
    write_file("msh_dot_selftest.tmp", "A=dot\n")
    result = msh_eval_source_state("PATH=.; . msh_dot_selftest.tmp; B=$A", "")
    delete_file("msh_dot_selftest.tmp")
    ok = 0
    if result.status == 0 and result.vars == "PATH=.\nA=dot\nB=dot\n" then
        ok = 1
    end
    if ok == 0 then
        print "msh phase4 dot-source selftest failed"
        got_status = "got status: " + str(result.status)
        print got_status
        dealloc(got_status)
        got_vars = "got vars: " + result.vars
        print got_vars
        dealloc(got_vars)
    end
    dealloc(result.vars)
    if ok == 1 then
        return 0
    end
    return 1
end

int msh_expect_dot_return():
    write_file("msh_dot_return_selftest.tmp", "A=before\nreturn 5\nA=bad\n")
    result = msh_eval_source_state("PATH=.; . msh_dot_return_selftest.tmp; B=$?", "")
    delete_file("msh_dot_return_selftest.tmp")
    ok = 0
    if result.status == 0 and result.vars == "PATH=.\nA=before\nB=5\n" then
        ok = 1
    end
    if ok == 0 then
        print "msh phase4 dot-return selftest failed"
        got_status = "got status: " + str(result.status)
        print got_status
        got_vars = "got vars: " + result.vars
        print got_vars
        dealloc(got_status, got_vars)
    end
    dealloc(result.vars)
    if ok == 1 then
        return 0
    end
    return 1
end

int msh_expect_redirection_only():
    delete_file("msh_redir_only_selftest.tmp")
    result = msh_eval_source_state("> msh_redir_only_selftest.tmp", "")
    exists = file_exists("msh_redir_only_selftest.tmp")
    delete_file("msh_redir_only_selftest.tmp")
    ok = 0
    if result.status == 0 and exists == 1 and result.vars == "" then
        ok = 1
    end
    if ok == 0 then
        print "msh phase4 redirection-only selftest failed"
    end
    dealloc(result.vars)
    if ok == 1 then
        return 0
    end
    return 1
end

int msh_expect_exit_trap_execution():
    path = "msh_exit_trap_selftest.tmp"
    delete_file(path)
    result = msh_eval_source_state("trap 'printf done > msh_exit_trap_selftest.tmp' EXIT; :", "")
    text = ""
    if file_exists(path) == 1 then
        text = read_file(path)
    end
    delete_file(path)
    ok = 0
    if result.status == 0 and text == "done" then
        ok = 1
    end
    if ok == 0 then
        print "msh phase4 EXIT trap selftest failed"
        got_status = "got status: " + str(result.status)
        got_text = "got text: " + text
        print got_status
        print got_text
        dealloc(got_status, got_text)
    end
    dealloc(result.vars, text)
    if ok == 1 then
        return 0
    end
    return 1
end

int msh_expect_background_execution():
    path = "msh_background_selftest.tmp"
    delete_file(path)
    result = msh_eval_source_state("printf bg > msh_background_selftest.tmp &\nwait", "")
    text = ""
    if file_exists(path) == 1 then
        text = read_file(path)
    end
    delete_file(path)
    ok = 0
    if result.status == 0 and text == "bg" then
        ok = 1
    end
    if ok == 0 then
        print "msh phase4 background selftest failed"
    end
    dealloc(result.vars, text)
    if ok == 1 then
        return 0
    end
    return 1
end

