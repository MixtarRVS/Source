// msh_phase4_selftest.ail
// Focused shell-state regressions.

import msh_eval
import msh_eval_entry
import msh_defs
import msh_exec
import msh_fields
import msh_phase_state
import msh_state
import msh_pipeio
import msh_umask
import msh_phase4_core_selftest
int msh_expect_alias_read_unit_timing():
    return msh_expect_eval_vars("alias hi='false'\nhi", 1, "")
end

int msh_expect_exec_persistent_output():
    path = "msh_exec_stdout_selftest.tmp"
    delete_file(path)
    source = "exec > msh_exec_stdout_selftest.tmp; printf ok"
    result = msh_eval_source_state(source, "")
    text = ""
    if file_exists(path) == 1 then
        text = read_file(path)
    end
    delete_file(path)
    ok = 0
    if result.status == 0 and result.vars == "" and text == "ok" then
        ok = 1
    end
    if ok == 0 then
        print "msh phase4 exec persistent stdout selftest failed"
    end
    dealloc(result.vars, text)
    if ok == 1 then
        return 0
    end
    return 1
end

int msh_expect_exec_persistent_input():
    path = "msh_exec_stdin_selftest.tmp"
    write_file(path, "one\ntwo\n")
    source = "exec < msh_exec_stdin_selftest.tmp; read A; read B"
    result = msh_eval_source_state(source, "")
    delete_file(path)
    ok = 0
    if result.status == 0 and result.vars == "A=one\nB=two\n" then
        ok = 1
    end
    if ok == 0 then
        print "msh phase4 exec persistent stdin selftest failed"
        got_status = "got status: " + str(result.status)
        got_vars = "got vars: " + result.vars
        print got_status
        print got_vars
        dealloc(got_status, got_vars)
    end
    dealloc(result.vars)
    if ok == 1 then
        return 0
    end
    return 1
end

