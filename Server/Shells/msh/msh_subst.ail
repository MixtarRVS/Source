// msh_subst.ail
// Command-substitution capture hooks.

import msh_defs

extern fn msh_subst_capture_eval_state(command: string, vars: string): string

string msh_subst_capture(command: string):
    return msh_subst_capture_eval_state(command, "")
end

string msh_subst_capture_with_vars(command: string, vars: string):
    return msh_subst_capture_eval_state(command, vars)
end
