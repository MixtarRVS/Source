// msh_test_builtin.ail
// POSIX test/[ builtin core predicates used by msh scripts.

import msh_fields
import msh_defs
import msh_diagnostics

record MshTestBuiltinResult then
    int status
end

record MshTestParseResult then
    int ok
    int value
    int next
end

int msh_test_int_within_profile_range(text: string):
    i = 0
    while i < strlen(text) then
        c0 = char_at(text, i)
        if c0 != MSH_CH_SPACE and c0 != MSH_CH_TAB then
            break
        end
        i++
    end
    negative = 0
    if i < strlen(text) and (char_at(text, i) == MSH_CH_MINUS or char_at(text, i) == MSH_CH_PLUS) then
        if char_at(text, i) == MSH_CH_MINUS then
            negative = 1
        end
        i++
    end
    while i < strlen(text) and char_at(text, i) == MSH_CH_DIGIT_0 then
        i++
    end
    digit_start = i
    digit_count = 0
    while i < strlen(text) then
        c = char_at(text, i)
        if c < MSH_CH_DIGIT_0 or c > MSH_CH_DIGIT_9 then
            break
        end
        digit_count++
        i++
    end
    if digit_count < 19 then
        return 1
    end
    if digit_count > 19 then
        return 0
    end
    limit = "" + "9223372036854775807"
    if negative == 1 then
        dealloc(limit)
        limit = "" + "9223372036854775808"
    end
    j = 0
    while j < 19 then
        dc = char_at(text, digit_start + j)
        lc = char_at(limit, j)
        if dc < lc then
            dealloc(limit)
            return 1
        end
        if dc > lc then
            dealloc(limit)
            return 0
        end
        j++
    end
    dealloc(limit)
    return 1
end

int msh_test_is_int(text: string):
    if strlen(text) == 0 then
        return 0
    end
    i = 0
    while i < strlen(text) then
        c0 = char_at(text, i)
        if c0 != MSH_CH_SPACE and c0 != MSH_CH_TAB then
            break
        end
        i++
    end
    if i >= strlen(text) then
        return 0
    end
    if char_at(text, i) == MSH_CH_MINUS or char_at(text, i) == MSH_CH_PLUS then
        if i + 1 >= strlen(text) then
            return 0
        end
        i++
    end
    saw_digit = 0
    while i < strlen(text) then
        c = char_at(text, i)
        if c == MSH_CH_SPACE or c == MSH_CH_TAB then
            while i < strlen(text) then
                tail = char_at(text, i)
                if tail != MSH_CH_SPACE and tail != MSH_CH_TAB then
                    return 0
                end
                i++
            end
            if saw_digit == 0 then
                return 0
            end
            return msh_test_int_within_profile_range(text)
        end
        if c < MSH_CH_DIGIT_0 or c > MSH_CH_DIGIT_9 then
            return 0
        end
        saw_digit = 1
        i++
    end
    if saw_digit == 0 then
        return 0
    end
    return msh_test_int_within_profile_range(text)
end

int msh_test_is_dir(path: string):
    old_dir = current_dir()
    rc = change_dir(path)
    if rc == 0 then
        change_dir(old_dir)
        dealloc(old_dir)
        return 1
    end
    dealloc(old_dir)
    return 0
end

int msh_test_int_compare(left: int, op: string, right: int):
    if op == "-eq" then
        return left == right
    end
    if op == "-ne" then
        return left != right
    end
    if op == "-gt" then
        return left > right
    end
    if op == "-ge" then
        return left >= right
    end
    if op == "-lt" then
        return left < right
    end
    if op == "-le" then
        return left <= right
    end
    return 0
end

int msh_test_int_op_known(op: string):
    if op == "-eq" or op == "-ne" or op == "-gt" or op == "-ge" or op == "-lt" or op == "-le" then
        return 1
    end
    return 0
end

void msh_test_diag_bad_int(name: string, left: string, right: string):
    bad = "" + left
    if msh_test_is_int(left) == 1 then
        dealloc(bad)
        bad = "" + right
    end
    detail = "Illegal number: " + bad
    msh_diag_builtin(name, detail)
    dealloc(bad, detail)
end

int msh_test_unary_operand_valid(name: string, op: string, value: string):
    if op == "-t" and msh_test_is_int(value) == 0 then
        msh_test_diag_bad_int(name, value, value)
        return 0
    end
    return 1
end

int msh_test_unary_known(op: string):
    if op == "-n" or op == "-z" or op == "-e" or op == "-f" or op == "-s" or op == "-d" then
        return 1
    end
    if op == "-b" or op == "-c" or op == "-g" or op == "-p" or op == "-S" or op == "-t" or op == "-u" then
        return 1
    end
    if op == "-L" or op == "-h" or op == "-r" or op == "-w" or op == "-x" then
        return 1
    end
    return 0
end

int msh_test_unary(op: string, value: string):
    if op == "-n" then
        return strlen(value) > 0
    end
    if op == "-z" then
        return strlen(value) == 0
    end
    if op == "-e" then
        return file_exists(value)
    end
    if op == "-f" then
        return file_is_regular(value)
    end
    if op == "-s" then
        return file_size(value) > 0
    end
    if op == "-d" then
        return msh_test_is_dir(value)
    end
    if op == "-b" then
        return file_is_block(value)
    end
    if op == "-c" then
        return file_is_char(value)
    end
    if op == "-g" then
        return file_is_setgid(value)
    end
    if op == "-p" then
        return file_is_fifo(value)
    end
    if op == "-S" then
        return file_is_socket(value)
    end
    if op == "-t" then
        if msh_test_is_int(value) == 1 then
            return fd_is_tty(parse_int(value))
        end
        return 0
    end
    if op == "-u" then
        return file_is_setuid(value)
    end
    if op == "-L" or op == "-h" then
        return file_is_symlink(value)
    end
    if op == "-r" then
        return access(value, 4)
    end
    if op == "-w" then
        return access(value, 2)
    end
    if op == "-x" then
        return access(value, 1)
    end
    return 0
end

int msh_test_binary_known(op: string):
    if op == "=" or op == "!=" then
        return 1
    end
    if op == "-ef" or op == "-nt" or op == "-ot" then
        return 1
    end
    if op == "-eq" or op == "-ne" or op == "-gt" or op == "-ge" or op == "-lt" or op == "-le" then
        return 1
    end
    return 0
end

int msh_test_binary(left: string, op: string, right: string):
    if op == "=" then
        return left == right
    end
    if op == "!=" then
        return left != right
    end
    if op == "-ef" then
        return file_same(left, right)
    end
    if op == "-nt" then
        if file_exists(left) == 0 then
            return 0
        end
        if file_exists(right) == 0 then
            return 1
        end
        return file_mtime(left) > file_mtime(right)
    end
    if op == "-ot" then
        if file_exists(right) == 0 then
            return 0
        end
        if file_exists(left) == 0 then
            return 1
        end
        return file_mtime(left) < file_mtime(right)
    end
    if msh_test_is_int(left) == 1 and msh_test_is_int(right) == 1 then
        return msh_test_int_compare(parse_int(left), op, parse_int(right))
    end
    return 0
end

def msh_test_parse_or(fields: str_array, pos: int, end_pos: int, name: string): MshTestParseResult
    left = msh_test_parse_and(fields, pos, end_pos, name)
    if left.ok == 0 then
        return left
    end
    value = left.value
    next = left.next
    while next < end_pos and str_array_get(fields, next) == "-o" then
        right = msh_test_parse_and(fields, next + 1, end_pos, name)
        if right.ok == 0 then
            return right
        end
        if value == 1 or right.value == 1 then
            value = 1
        else
            value = 0
        end
        next = right.next
    end
    return new MshTestParseResult(1, value, next)
end

def msh_test_parse_and(fields: str_array, pos: int, end_pos: int, name: string): MshTestParseResult
    left = msh_test_parse_not(fields, pos, end_pos, name)
    if left.ok == 0 then
        return left
    end
    value = left.value
    next = left.next
    while next < end_pos and str_array_get(fields, next) == "-a" then
        right = msh_test_parse_not(fields, next + 1, end_pos, name)
        if right.ok == 0 then
            return right
        end
        if value == 1 and right.value == 1 then
            value = 1
        else
            value = 0
        end
        next = right.next
    end
    return new MshTestParseResult(1, value, next)
end

def msh_test_parse_not(fields: str_array, pos: int, end_pos: int, name: string): MshTestParseResult
    if pos + 3 < end_pos and str_array_get(fields, pos) == "!" and str_array_get(fields, pos + 1) == "!" and str_array_get(fields, pos + 2) == "!" and pos + 4 == end_pos then
        return msh_test_parse_not(fields, pos + 1, end_pos, name)
    end
    if pos < end_pos and str_array_get(fields, pos) == "!" then
        inner = msh_test_parse_not(fields, pos + 1, end_pos, name)
        if inner.ok == 0 then
            return inner
        end
        value = 0
        if inner.value == 0 then
            value = 1
        end
        return new MshTestParseResult(1, value, inner.next)
    end
    return msh_test_parse_primary(fields, pos, end_pos, name)
end

def msh_test_parse_primary(fields: str_array, pos: int, end_pos: int, name: string): MshTestParseResult
    if pos >= end_pos then
        return new MshTestParseResult(0, 0, pos)
    end
    token = str_array_get(fields, pos)
    if token == "(" then
        if pos + 1 < end_pos and str_array_get(fields, pos + 1) == ")" then
            return new MshTestParseResult(1, 0, pos + 2)
        end
        inner = msh_test_parse_or(fields, pos + 1, end_pos, name)
        if inner.ok == 0 or inner.next >= end_pos or str_array_get(fields, inner.next) != ")" then
            msh_diag_builtin(name, "closing paren expected")
            return new MshTestParseResult(0, 0, inner.next)
        end
        return new MshTestParseResult(1, inner.value, inner.next + 1)
    end
    if pos + 1 < end_pos then
        op = str_array_get(fields, pos)
        if msh_test_unary_known(op) == 1 then
            if msh_test_unary_operand_valid(name, op, str_array_get(fields, pos + 1)) == 0 then
                return new MshTestParseResult(0, 0, pos)
            end
            value = msh_test_unary(op, str_array_get(fields, pos + 1))
            return new MshTestParseResult(1, value, pos + 2)
        end
    end
    if pos + 2 < end_pos then
        op3 = str_array_get(fields, pos + 1)
        if msh_test_binary_known(op3) == 1 then
            if msh_test_int_op_known(op3) == 1 and (msh_test_is_int(str_array_get(fields, pos)) == 0 or msh_test_is_int(str_array_get(fields, pos + 2)) == 0) then
                msh_test_diag_bad_int(name, str_array_get(fields, pos), str_array_get(fields, pos + 2))
                return new MshTestParseResult(0, 0, pos)
            end
            value3 = msh_test_binary(str_array_get(fields, pos), op3, str_array_get(fields, pos + 2))
            return new MshTestParseResult(1, value3, pos + 3)
        end
    end
    if strlen(token) > 0 then
        return new MshTestParseResult(1, 1, pos + 1)
    end
    return new MshTestParseResult(1, 0, pos + 1)
end

int msh_test_needs_expr_parser(fields: str_array, first: int, last: int):
    i = first
    while i < last then
        token = str_array_get(fields, i)
        if token == "-a" or token == "-o" then
            return 1
        end
        if token == "!" and i + 1 < last and str_array_get(fields, i + 1) == "!" then
            return 1
        end
        if (token == "(" or token == ")") and last - first > 1 then
            return 1
        end
        i++
    end
    return 0
end

def msh_test_state(fields: str_array): MshTestBuiltinResult
    first = 1
    last = str_array_len(fields)
    name = str_array_get(fields, 0)
    if name == "[" then
        if last < 2 then
            return new MshTestBuiltinResult(2)
        end
        closing = str_array_get(fields, last - 1)
        if closing != "]" then
            msh_diag_builtin("[", "missing ]")
            return new MshTestBuiltinResult(2)
        end
        last--
    end
    argc = last - first
    if msh_test_needs_expr_parser(fields, first, last) == 1 or argc >= 4 then
        parsed = msh_test_parse_or(fields, first, last, name)
        if parsed.ok == 0 then
            return new MshTestBuiltinResult(2)
        end
        if parsed.next != last then
            unexpected = str_array_get(fields, first)
            if str_array_get(fields, first) == "(" and first + 1 < last and str_array_get(fields, first + 1) == ")" then
                unexpected = str_array_get(fields, first + 1)
            end
            detail_unexpected = unexpected + ": unexpected operator"
            msh_diag_builtin(name, detail_unexpected)
            dealloc(detail_unexpected)
            return new MshTestBuiltinResult(2)
        end
        if parsed.value == 1 then
            return new MshTestBuiltinResult(0)
        end
        return new MshTestBuiltinResult(1)
    end
    if argc == 0 then
        return new MshTestBuiltinResult(1)
    end
    if argc == 1 then
        value = str_array_get(fields, first)
        if strlen(value) > 0 then
            return new MshTestBuiltinResult(0)
        end
        return new MshTestBuiltinResult(1)
    end
    if argc == 2 then
        op = str_array_get(fields, first)
        value2 = str_array_get(fields, first + 1)
        if op == "!" then
            if strlen(value2) > 0 then
                return new MshTestBuiltinResult(1)
            end
            return new MshTestBuiltinResult(0)
        end
        if msh_test_unary_known(op) == 1 and msh_test_unary_operand_valid(name, op, value2) == 0 then
            return new MshTestBuiltinResult(2)
        end
        if msh_test_unary_known(op) == 0 then
            if msh_test_binary_known(value2) == 1 then
                detail_arg = value2 + ": argument expected"
                msh_diag_builtin(name, detail_arg)
                dealloc(detail_arg)
                return new MshTestBuiltinResult(2)
            end
            detail_unknown = op + ": unexpected operator"
            msh_diag_builtin(name, detail_unknown)
            dealloc(detail_unknown)
            return new MshTestBuiltinResult(2)
        end
        if msh_test_unary(op, value2) == 1 then
            return new MshTestBuiltinResult(0)
        end
        return new MshTestBuiltinResult(1)
    end
    if argc == 3 then
        left = str_array_get(fields, first)
        op3 = str_array_get(fields, first + 1)
        right = str_array_get(fields, first + 2)
        if left == "!" then
            if msh_test_int_op_known(op3) == 1 and (msh_test_is_int(op3) == 0 or msh_test_is_int(right) == 0) then
                msh_test_diag_bad_int(name, op3, right)
                return new MshTestBuiltinResult(2)
            end
            if msh_test_unary_known(op3) == 1 and msh_test_unary_operand_valid(name, op3, right) == 0 then
                return new MshTestBuiltinResult(2)
            end
            if msh_test_unary(op3, right) == 1 then
                return new MshTestBuiltinResult(1)
            end
            return new MshTestBuiltinResult(0)
        end
        if msh_test_int_op_known(op3) == 1 and (msh_test_is_int(left) == 0 or msh_test_is_int(right) == 0) then
            msh_test_diag_bad_int(name, left, right)
            return new MshTestBuiltinResult(2)
        end
        if msh_test_binary_known(op3) == 0 then
            detail_unknown3 = left + ": unexpected operator"
            msh_diag_builtin(name, detail_unknown3)
            dealloc(detail_unknown3)
            return new MshTestBuiltinResult(2)
        end
        if msh_test_binary(left, op3, right) == 1 then
            return new MshTestBuiltinResult(0)
        end
        return new MshTestBuiltinResult(1)
    end
    unexpected2 = str_array_get(fields, first)
    detail_unexpected2 = unexpected2 + ": unexpected operator"
    msh_diag_builtin(name, detail_unexpected2)
    dealloc(detail_unexpected2)
    return new MshTestBuiltinResult(2)
end
