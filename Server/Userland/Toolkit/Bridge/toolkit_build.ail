// toolkit_build.ail
// AILang-owned build driver for translated FreeBSD Toolkit proofs.

import toolkit_core
import toolkit_reports
import toolkit_compat_tests
import toolkit_upstream_tests
import toolkit_probe
import toolkit_action_tests
import toolkit_libc_tests
import toolkit_coverage

void toolkit_build_usage():
    print "Usage: toolkit_build [status|plan|build-wsl|package-musl|install-mixtar|compat-alpine|clean-root-profile|test-wsl|upstream-wsl|action-wsl|libc-wsl|coverage|probe-wsl|probe-auto-wsl|probe-openbsd-wsl|verify-upstream|refresh-upstream-manifest|certify-wsl|help] [tool|all]"
    print "  status      Check known source files and Bridge inputs"
    print "  plan        Print strict build command(s)"
    print "  build-wsl   Build generated linux-x64 target(s) through WSL"
    print "  package-musl Build a repeatable musl source package for MixtarRVS"
    print "  install-mixtar Build/install a musl-native Toolkit group on the MixtarRVS laptop"
    print "  compat-alpine Ensure /Compatibility/POSIX/Alpine/3.24 exists as a symlink backend"
    print "  clean-root-profile Prepare the clean-root runtime namespace profile without activating it"
    print "  test-wsl    Compare generated tool behavior against WSL-native tools"
    print "  upstream-wsl Run FreeBSD upstream-derived edge tests"
    print "  action-wsl  Run cross-tool action tests under WSL"
    print "  libc-wsl    Rebuild AILang Runtime/LibC slices and run strict WSL ABI smokes"
    print "  coverage    Regenerate the manifest/artifact coverage report"
    print "  probe-wsl   Strict-compile every mirrored candidate and write one failure report"
    print "  probe-auto-wsl Strict-discover/probe every mirrored FreeBSD bin/usr.bin directory"
    print "  probe-openbsd-wsl Strict-discover/probe mirrored OpenBSD bin/sbin/usr.bin/usr.sbin/games"
    print "  verify-upstream Fail if mirrored OpenBSD/FreeBSD source was edited, added, or removed"
    print "  refresh-upstream-manifest Record current mirrored OpenBSD/FreeBSD source hashes"
    print "  certify-wsl Build, test, and write certification summary"
    print "  help        Show this help"
    print "Known groups: all, tier-a, source, core, tier1, tier2, tier3, tier4, tier5, tier6, tier7, tier8, tier9"
    print "  all/tier-a/source excludes hosted adapters; tier9 still exposes hard-edge and hosted placeholders explicitly."
    print "Known tools: echo, cat, pwd, true, false, mkdir, rmdir, cp, ls, mv, rm, domainname, hostname, realpath, sleep, sync, chmod, test, env, dirname, basename, head, tee, touch, readlink, uname, id, date, uniq, wc, ln, cut, sed, arch, printenv, yes, tty, rev, seq, mktemp, paste, comm, fold, nice, what, cal, hexdump, kill, getopt, fmt, split, logname, nohup, timeout, unexpand, column, col, rs, from, banner, cmp, colrm, expand, join, tr, apply, expr, jot, csplit, chroot, dd, du, locale, logger, look, nologin, ed, nproc, pr, printf, renice, sdiff, stat, ul, grep, tail, find, xargs, which, script, nl, rmt, shutdown, users, wall, df, mknod, tsort, who, diff, patch, getconf, zic, zdump, file, sort, m4, awk, diff3, gencat, ipcrm, stty, pkill, ps, uuidgen, chflags, pwait, cpuset, kenv, getfacl, setfacl, chio, pax, csh, sh, cron, dmesg, fdisk, fsck, getent, gprof, init, ipcs, less, lex, login, mount, mt, nm, passwd, ping, pkgconf, reboot, rpcgen, su, swapon, sysctl, top, umount, vi, vipw, vmstat, w, watch, yacc"
end

int toolkit_upstream_integrity(mode: string):
    prefix = "" + "wsl.exe -d Debian -- bash Server/Userland/Toolkit/Bridge/scripts/upstream_integrity.sh "
    cmd = prefix + mode
    dealloc(prefix)
    rc = system(cmd)
    dealloc(cmd)
    return rc
end

int toolkit_musl_target(action: string, tool: string):
    prefix = "" + "python Server/Userland/Toolkit/Bridge/scripts/mixtarrvs_musl_toolkit.py "
    with_action = prefix + action
    dealloc(prefix)
    with_space = with_action + " "
    dealloc(with_action)
    cmd = with_space + tool
    dealloc(with_space)
    rc = system(cmd)
    dealloc(cmd)
    return rc
end

int toolkit_prepare_libc_generated_dir():
    if file_exists("Server/Runtime/LibC/Generated") == 0 then
        mkdir("Server/Runtime/LibC/Generated")
    end
    return 0
end

int toolkit_emit_libc_c(source: string, output: string):
    toolkit_prepare_libc_generated_dir()
    prefix = "" + "python C:/Users/V/source/repos/AILang-Pure/ailang.py "
    with_source = prefix + source
    dealloc(prefix)
    with_flag = with_source + " --emit-c -o "
    dealloc(with_source)
    cmd = with_flag + output
    dealloc(with_flag)
    rc = system(cmd)
    dealloc(cmd)
    return rc
end

int toolkit_prepare_runtime_sources(tool: string):
    base_rc = toolkit_emit_libc_c("Server/Runtime/LibC/Source/bsd_compat.ail", "Server/Runtime/LibC/Generated/bsd_compat.c")
    if base_rc != 0 then
        return base_rc
    end
    if tool == "df" then
        return toolkit_emit_libc_c("Server/Runtime/LibC/Source/df_raw_stubs.ail", "Server/Runtime/LibC/Generated/df_raw_stubs.c")
    end
    if tool == "sort" then
        return toolkit_emit_libc_c("Server/Runtime/LibC/Source/md5_end.ail", "Server/Runtime/LibC/Generated/md5_end.c")
    end
    return 0
end

int toolkit_write_upstream_test_script(tool: string):
    toolkit_ensure_dirs_for(tool)
    script = toolkit_upstream_test_script(tool)
    path = toolkit_upstream_test_path(tool)
    rc = write_file(path, script)
    dealloc(script, path)
    if rc == 0 then
        return 1
    end
    return 0
end

int toolkit_status_one(tool: string):
    if toolkit_known(tool) == 0 then
        msg = "toolkit-build: unknown tool: " + tool
        print msg
        dealloc(msg)
        return 1
    end
    src = toolkit_source(tool)
    failures = toolkit_require(src, tool)
    dealloc(src)
    if tool == "cp" then
        failures = failures + toolkit_require("Server/Userland/Toolkit/FreeBSD/freebsd-src/bin/cp/utils.c", "cp utils.c")
    end
    if tool == "ls" then
        failures = failures + toolkit_require("Server/Userland/Toolkit/FreeBSD/freebsd-src/bin/ls/cmp.c", "ls cmp.c")
        failures = failures + toolkit_require("Server/Userland/Toolkit/FreeBSD/freebsd-src/bin/ls/print.c", "ls print.c")
        failures = failures + toolkit_require("Server/Userland/Toolkit/FreeBSD/freebsd-src/bin/ls/util.c", "ls util.c")
    end
    if tool == "diff3" then
        failures = failures + toolkit_require("Server/Userland/Toolkit/Bridge/scripts/diff3", "diff3 shell wrapper")
    end
    failures = failures + toolkit_require("Server/Userland/Toolkit/Bridge/include/capsicum_helpers.h", "Bridge include/capsicum_helpers.h")
    return failures
end

int toolkit_build_one(tool: string):
    status = toolkit_status_one(tool)
    if status != 0 then
        return status
    end
    doc_rc = toolkit_write_docs(tool)
    if doc_rc != 0 then
        print "toolkit-build: failed to write docs"
        return doc_rc
    end
    prep_rc = toolkit_prepare_runtime_sources(tool)
    if prep_rc != 0 then
        print "toolkit-build: failed to prepare AILang runtime sources"
        return prep_rc
    end
    cmd = toolkit_wsl_command(tool)
    msg = "toolkit-build: building " + tool
    print msg
    dealloc(msg)
    rc = system(cmd)
    dealloc(cmd)
    if rc != 0 then
        fail = "toolkit-build: failed " + tool
        print fail
        dealloc(fail)
        return rc
    end
    target = toolkit_target(tool)
    if file_exists(target) == 0 then
        dealloc(target)
        print "toolkit-build: build exited cleanly but output is missing"
        return 1
    end
    ok = "toolkit-build: wrote " + target
    print ok
    dealloc(ok, target)
    return 0
end

int toolkit_test_one(tool: string):
    status = toolkit_status_one(tool)
    if status != 0 then
        return status
    end
    target = toolkit_target(tool)
    if file_exists(target) == 0 then
        dealloc(target)
        print "toolkit-build: target missing; run build-wsl first"
        return 1
    end
    dealloc(target)
    script_rc = toolkit_write_test_script(tool)
    if script_rc != 0 then
        print "toolkit-build: failed to write WSL test script"
        return script_rc
    end
    cmd = toolkit_wsl_script_command(tool)
    msg = "toolkit-build: testing " + tool
    print msg
    dealloc(msg)
    rc = system(cmd)
    dealloc(cmd)
    if rc != 0 then
        fail = "toolkit-build: compatibility failures in " + tool
        print fail
        dealloc(fail)
        return rc
    end
    ok = "toolkit-build: compatibility ok " + tool
    print ok
    dealloc(ok)
    return 0
end

int toolkit_upstream_test_one(tool: string):
    status = toolkit_status_one(tool)
    if status != 0 then
        return status
    end
    target = toolkit_target(tool)
    if file_exists(target) == 0 then
        dealloc(target)
        print "toolkit-build: target missing; run build-wsl first"
        return 1
    end
    dealloc(target)
    script_rc = toolkit_write_upstream_test_script(tool)
    if script_rc != 0 then
        print "toolkit-build: failed to write FreeBSD upstream-derived test script"
        return script_rc
    end
    cmd = toolkit_upstream_wsl_script_command(tool)
    msg = "toolkit-build: upstream-derived testing " + tool
    print msg
    dealloc(msg)
    rc = system(cmd)
    dealloc(cmd)
    if rc != 0 then
        fail = "toolkit-build: upstream-derived failures in " + tool
        print fail
        dealloc(fail)
        return rc
    end
    ok = "toolkit-build: upstream-derived ok " + tool
    print ok
    dealloc(ok)
    return 0
end

int toolkit_certify_one(tool: string):
    build_rc = toolkit_build_one(tool)
    if build_rc != 0 then
        return build_rc
    end
    test_rc = toolkit_test_one(tool)
    if test_rc != 0 then
        return test_rc
    end
    upstream_rc = toolkit_upstream_test_one(tool)
    if upstream_rc != 0 then
        return upstream_rc
    end
    cert_rc = toolkit_write_cert_one(tool)
    if cert_rc != 0 then
        print "toolkit-build: failed to write certification report"
        return cert_rc
    end
    msg = "toolkit-build: certified " + tool
    print msg
    dealloc(msg)
    return 0
end

int toolkit_plan_one(tool: string):
    if toolkit_known(tool) == 0 then
        msg = "toolkit-build: unknown tool: " + tool
        print msg
        dealloc(msg)
        return 1
    end
    plan = toolkit_plan(tool)
    print plan
    dealloc(plan)
    return 0
end

