int toolkit_selects_tier_a(tool: string):
    if tool == "all" then
        return 1
    end
    if tool == "tier-a" then
        return 1
    end
    if tool == "source" then
        return 1
    end
    return 0
end

int toolkit_for_tier_a(op: string):
    failures = 0
    failures = failures + toolkit_for_each(op)
    failures = failures + toolkit_for_tier1(op)
    failures = failures + toolkit_for_tier2(op)
    failures = failures + toolkit_for_tier3(op)
    failures = failures + toolkit_for_tier4(op)
    failures = failures + toolkit_for_tier5(op)
    failures = failures + toolkit_for_tier6(op)
    failures = failures + toolkit_for_tier7(op)
    failures = failures + toolkit_for_tier8(op)
    failures = failures + toolkit_apply_op(op, "dmesg")
    failures = failures + toolkit_apply_op(op, "ed")
    failures = failures + toolkit_apply_op(op, "getent")
    failures = failures + toolkit_apply_op(op, "nm")
    failures = failures + toolkit_apply_op(op, "rpcgen")
    return failures
end

int toolkit_build_main():
    op = "status"
    tool = "all"
    if argc() >= 2 then
        op = argv(1)
    end
    if argc() >= 3 then
        tool = argv(2)
    end

    match op then
        case "status":
            if toolkit_selects_tier_a(tool) == 1 then
                return toolkit_for_tier_a("status")
            end
            if tool == "core" then
                return toolkit_for_each("status")
            end
            if tool == "tier1" then
                return toolkit_for_tier1("status")
            end
            if tool == "tier2" then
                return toolkit_for_tier2("status")
            end
            if tool == "tier3" then
                return toolkit_for_tier3("status")
            end
            if tool == "tier4" then
                return toolkit_for_tier4("status")
            end
            if tool == "tier5" then
                return toolkit_for_tier5("status")
            end
            if tool == "tier6" then
                return toolkit_for_tier6("status")
            end
            if tool == "tier7" then
                return toolkit_for_tier7("status")
            end
            if tool == "tier8" then
                return toolkit_for_tier8("status")
            end
            if tool == "tier9" then
                return toolkit_for_tier9("status")
            end
            return toolkit_status_one(tool)
        case "plan":
            if toolkit_selects_tier_a(tool) == 1 then
                return toolkit_for_tier_a("plan")
            end
            if tool == "core" then
                return toolkit_for_each("plan")
            end
            if tool == "tier1" then
                return toolkit_for_tier1("plan")
            end
            if tool == "tier2" then
                return toolkit_for_tier2("plan")
            end
            if tool == "tier3" then
                return toolkit_for_tier3("plan")
            end
            if tool == "tier4" then
                return toolkit_for_tier4("plan")
            end
            if tool == "tier5" then
                return toolkit_for_tier5("plan")
            end
            if tool == "tier6" then
                return toolkit_for_tier6("plan")
            end
            if tool == "tier7" then
                return toolkit_for_tier7("plan")
            end
            if tool == "tier8" then
                return toolkit_for_tier8("plan")
            end
            if tool == "tier9" then
                return toolkit_for_tier9("plan")
            end
            return toolkit_plan_one(tool)
        case "build-wsl":
            if toolkit_selects_tier_a(tool) == 1 then
                return toolkit_for_tier_a("build-wsl")
            end
            if tool == "core" then
                return toolkit_for_each("build-wsl")
            end
            if tool == "tier1" then
                return toolkit_for_tier1("build-wsl")
            end
            if tool == "tier2" then
                return toolkit_for_tier2("build-wsl")
            end
            if tool == "tier3" then
                return toolkit_for_tier3("build-wsl")
            end
            if tool == "tier4" then
                return toolkit_for_tier4("build-wsl")
            end
            if tool == "tier5" then
                return toolkit_for_tier5("build-wsl")
            end
            if tool == "tier6" then
                return toolkit_for_tier6("build-wsl")
            end
            if tool == "tier7" then
                return toolkit_for_tier7("build-wsl")
            end
            if tool == "tier8" then
                return toolkit_for_tier8("build-wsl")
            end
            if tool == "tier9" then
                return toolkit_for_tier9("build-wsl")
            end
            return toolkit_build_one(tool)
        case "package-musl":
            return toolkit_musl_target("package", tool)
        case "install-mixtar":
            return toolkit_musl_target("install", tool)
        case "compat-alpine":
            return toolkit_musl_target("compat-alpine", tool)
        case "clean-root-profile":
            return toolkit_musl_target("clean-root-profile", tool)
        case "test-wsl":
            if toolkit_selects_tier_a(tool) == 1 then
                return toolkit_for_tier_a("test-wsl")
            end
            if tool == "core" then
                return toolkit_for_each("test-wsl")
            end
            if tool == "tier1" then
                return toolkit_for_tier1("test-wsl")
            end
            if tool == "tier2" then
                return toolkit_for_tier2("test-wsl")
            end
            if tool == "tier3" then
                return toolkit_for_tier3("test-wsl")
            end
            if tool == "tier4" then
                return toolkit_for_tier4("test-wsl")
            end
            if tool == "tier5" then
                return toolkit_for_tier5("test-wsl")
            end
            if tool == "tier6" then
                return toolkit_for_tier6("test-wsl")
            end
            if tool == "tier7" then
                return toolkit_for_tier7("test-wsl")
            end
            if tool == "tier8" then
                return toolkit_for_tier8("test-wsl")
            end
            if tool == "tier9" then
                return toolkit_for_tier9("test-wsl")
            end
            return toolkit_test_one(tool)
        case "upstream-wsl":
            if toolkit_selects_tier_a(tool) == 1 then
                return toolkit_for_tier_a("upstream-wsl")
            end
            if tool == "core" then
                return toolkit_for_each("upstream-wsl")
            end
            if tool == "tier1" then
                return toolkit_for_tier1("upstream-wsl")
            end
            if tool == "tier2" then
                return toolkit_for_tier2("upstream-wsl")
            end
            if tool == "tier3" then
                return toolkit_for_tier3("upstream-wsl")
            end
            if tool == "tier4" then
                return toolkit_for_tier4("upstream-wsl")
            end
            if tool == "tier5" then
                return toolkit_for_tier5("upstream-wsl")
            end
            if tool == "tier6" then
                return toolkit_for_tier6("upstream-wsl")
            end
            if tool == "tier7" then
                return toolkit_for_tier7("upstream-wsl")
            end
            if tool == "tier8" then
                return toolkit_for_tier8("upstream-wsl")
            end
            if tool == "tier9" then
                return toolkit_for_tier9("upstream-wsl")
            end
            return toolkit_upstream_test_one(tool)
        case "probe-wsl":
            return toolkit_probe_wsl()
        case "probe-auto-wsl":
            return toolkit_auto_probe_wsl()
        case "probe-openbsd-wsl":
            return toolkit_openbsd_probe_wsl()
        case "verify-upstream":
            return toolkit_upstream_integrity("verify")
        case "refresh-upstream-manifest":
            return toolkit_upstream_integrity("refresh")
        case "action-wsl":
            return toolkit_action_test_wsl()
        case "libc-wsl":
            return toolkit_libc_test_wsl()
        case "coverage":
            return toolkit_coverage_report()
        case "certify-wsl":
            if toolkit_selects_tier_a(tool) == 1 then
                return toolkit_for_tier_a("certify-wsl")
            end
            if tool == "core" then
                return toolkit_for_each("certify-wsl")
            end
            if tool == "tier1" then
                return toolkit_for_tier1("certify-wsl")
            end
            if tool == "tier2" then
                return toolkit_for_tier2("certify-wsl")
            end
            if tool == "tier3" then
                return toolkit_for_tier3("certify-wsl")
            end
            if tool == "tier4" then
                return toolkit_for_tier4("certify-wsl")
            end
            if tool == "tier5" then
                return toolkit_for_tier5("certify-wsl")
            end
            if tool == "tier6" then
                return toolkit_for_tier6("certify-wsl")
            end
            if tool == "tier7" then
                return toolkit_for_tier7("certify-wsl")
            end
            if tool == "tier8" then
                return toolkit_for_tier8("certify-wsl")
            end
            if tool == "tier9" then
                return toolkit_for_tier9("certify-wsl")
            end
            return toolkit_certify_one(tool)
        case "help":
            toolkit_build_usage()
            return 0
        case "--help":
            toolkit_build_usage()
            return 0
        case "-h":
            toolkit_build_usage()
            return 0
        default:
            msg = "toolkit-build: unknown operation: " + op
            print msg
            dealloc(msg)
            toolkit_build_usage()
            return 1
    end
end

int main():
    return toolkit_build_main()
end


