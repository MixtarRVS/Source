int toolkit_apply_op(op: string, tool: string):
    if op == "status" then
        return toolkit_status_one(tool)
    end
    if op == "build-wsl" then
        return toolkit_build_one(tool)
    end
    if op == "test-wsl" then
        return toolkit_test_one(tool)
    end
    if op == "upstream-wsl" then
        return toolkit_upstream_test_one(tool)
    end
    if op == "certify-wsl" then
        return toolkit_certify_one(tool)
    end
    if op == "plan" then
        return toolkit_plan_one(tool)
    end
    return 1
end

