// toolkit_core.ail
// Shared paths, catalog, and command construction for Toolkit builds.

int toolkit_source_root_safe(value: string):
    n = strlen(value)
    if n == 0 then
        return 0
    end
    raw = reinterpret(i64, value)
    if index_of(value, "..") >= 0 then
        return 0
    end
    i = 0
    while i < n then
        ch = peek8(raw, i)
        letter_lower = ch >= 97 and ch <= 122
        letter_upper = ch >= 65 and ch <= 90
        digit = ch >= 48 and ch <= 57
        separator = ch == 47
        punctuation = ch == 45 or ch == 46 or ch == 58 or ch == 95
        if letter_lower == 0 and letter_upper == 0 and digit == 0 and separator == 0 and punctuation == 0 then
            return 0
        end
        i++
    end
    return 1
end

string toolkit_openbsd_path(relative: string):
    configured_root = getenv("MIXTAR_OPENBSD_SOURCE_ROOT")
    if strlen(configured_root) == 0 then
        root = "" + "Server/Userland/Toolkit/OpenBSD/src"
    else
        root = "" + configured_root
        if toolkit_source_root_safe(configured_root) == 0 then
            dealloc(root)
            root = "" + "/invalid-mixtar-openbsd-source-root"
        end
    end
    prefix = root + "/"
    path = prefix + relative
    dealloc(root, prefix)
    return path
end

string toolkit_normalize_openbsd_roots(command: string):
    legacy = "" + "Server/Userland/Toolkit/OpenBSD/src/"
    configured = toolkit_openbsd_path("")
    normalized = "" + command
    if configured != legacy then
        while index_of(normalized, legacy) >= 0 then
            next = str_replace(normalized, legacy, configured)
            dealloc(normalized)
            normalized = next
        end
    end
    dealloc(legacy, configured)
    return normalized
end

int toolkit_hosted_tool(tool: string):
    match tool then
        default:
            return 0
    end
end

