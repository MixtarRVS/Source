string toolkit_target(tool: string):
    prefix = "" + "Server/Userland/Generated/targets/linux-x64/bin/"
    out = prefix + tool
    dealloc(prefix)
    return out
end

string toolkit_report_path(tool: string):
    prefix = "" + "Server/Userland/Generated/reports/"
    mid = prefix + tool
    dealloc(prefix)
    out = mid + "-gap.md"
    dealloc(mid)
    return out
end

string toolkit_plan_path(tool: string):
    prefix = "" + "Server/Userland/Generated/build/"
    mid = prefix + tool
    dealloc(prefix)
    out = mid + "/BUILD_PLAN.md"
    dealloc(mid)
    return out
end

string toolkit_test_path(tool: string):
    prefix = "" + "Server/Userland/Generated/tests/"
    mid = prefix + tool
    dealloc(prefix)
    out = mid + "-compat.sh"
    dealloc(mid)
    return out
end

string toolkit_test_report_path(tool: string):
    prefix = "" + "Server/Userland/Generated/reports/"
    mid = prefix + tool
    dealloc(prefix)
    out = mid + "-compat.md"
    dealloc(mid)
    return out
end

string toolkit_cert_report_path(tool: string):
    prefix = "" + "Server/Userland/Generated/certification/"
    mid = prefix + tool
    dealloc(prefix)
    out = mid + ".md"
    dealloc(mid)
    return out
end

int toolkit_require(path: string, label: string):
    if file_exists(path) == 1 then
        msg_ok = "OK   " + label
        print msg_ok
        dealloc(msg_ok)
        return 0
    end
    msg_fail = "MISS " + label
    print msg_fail
    dealloc(msg_fail)
    return 1
end

int toolkit_ensure_dirs_for(tool: string):
    if file_exists("Server/Userland/Generated") == 0 then
        mkdir("Server/Userland/Generated")
    end
    if file_exists("Server/Userland/Generated/build") == 0 then
        mkdir("Server/Userland/Generated/build")
    end
    build_dir = "Server/Userland/Generated/build/" + tool
    if file_exists(build_dir) == 0 then
        mkdir(build_dir)
    end
    dealloc(build_dir)
    if file_exists("Server/Userland/Generated/reports") == 0 then
        mkdir("Server/Userland/Generated/reports")
    end
    if file_exists("Server/Userland/Generated/tests") == 0 then
        mkdir("Server/Userland/Generated/tests")
    end
    if file_exists("Server/Userland/Generated/certification") == 0 then
        mkdir("Server/Userland/Generated/certification")
    end
    if file_exists("Server/Userland/Generated/targets") == 0 then
        mkdir("Server/Userland/Generated/targets")
    end
    if file_exists("Server/Userland/Generated/targets/linux-x64") == 0 then
        mkdir("Server/Userland/Generated/targets/linux-x64")
    end
    if file_exists("Server/Userland/Generated/targets/linux-x64/bin") == 0 then
        mkdir("Server/Userland/Generated/targets/linux-x64/bin")
    end
    return 0
end

string toolkit_compile_command_raw(tool: string):
    if tool == "lex" then
        target_lex = toolkit_target(tool)
        lex_prefix = "" + "mkdir -p Server/Userland/Generated/build/lex Server/Userland/Generated/targets/linux-x64/bin && sed 's|#define M4 \"/usr/bin/m4\"|#define M4 \"m4\"|' Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex/config.h > Server/Userland/Generated/build/lex/config.h && printf '%s\\n' '#include <sys/types.h>' '#ifndef __GLIBC__' 'typedef unsigned char u_char;' '#endif' > Server/Userland/Generated/build/lex/mixtar_lex_types.h && tr -d '\\015' < Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex/mkskel.sh > Server/Userland/Generated/build/lex/mkskel.sh && bison -y -d -o Server/Userland/Generated/build/lex/parse.c Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex/parse.y && flex -o Server/Userland/Generated/build/lex/scan.c Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex/scan.l && tr -d '\\015' < Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex/flex.skl | sed -e 's/m4_/m4postproc_/g' -e 's/m4preproc_/m4_/g' | m4 -I Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex -P -DFLEX_MAJOR_VERSION=2 -DFLEX_MINOR_VERSION=5 -DFLEX_SUBMINOR_VERSION=39 | tr -d '\\015' | sed -e 's/m4postproc_/m4_/g' | sh Server/Userland/Generated/build/lex/mkskel.sh > Server/Userland/Generated/build/lex/skel.c && cc -std=gnu17 -Wall -Wextra -Werror -pedantic -Wno-sign-compare -Wno-unused-parameter -Wno-missing-field-initializers -Wno-unused-function -Wno-format-truncation -Wno-calloc-transposed-args -D_GNU_SOURCE -D_DEFAULT_SOURCE -DHAVE_CONFIG_H -D'pledge(a,b)=0' -include Server/Userland/Generated/build/lex/mixtar_lex_types.h -I Server/Userland/Generated/build/lex -I Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex -I Server/Userland/Toolkit/Bridge/include -o "
