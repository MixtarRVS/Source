        lex_prefix = "" + "mkdir -p Server/Userland/Generated/build/lex && sed 's|#define M4 \"/usr/bin/m4\"|#define M4 \"m4\"|' Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex/config.h > Server/Userland/Generated/build/lex/config.h && bison -y -d -o Server/Userland/Generated/build/lex/parse.c Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex/parse.y && flex -o Server/Userland/Generated/build/lex/scan.c Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex/scan.l && sed -e 's/m4_/m4postproc_/g' -e 's/m4preproc_/m4_/g' Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex/flex.skl | m4 -I Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex -P -DFLEX_MAJOR_VERSION=2 -DFLEX_MINOR_VERSION=5 -DFLEX_SUBMINOR_VERSION=39 | sed -e 's/m4postproc_/m4_/g' | sh Server/Userland/Toolkit/OpenBSD/src/usr.bin/lex/mkskel.sh > Server/Userland/Generated/build/lex/skel.c && "
        full_lex = lex_prefix + full
        dealloc(lex_prefix)
        dealloc(full)
        full = full_lex
    end
    if tool == "less" then
        less_prefix = "" + "mkdir -p Server/Userland/Generated/build/less && printf '%b\\n' '#ifndef MIXTAR_LESS_CONFIG_H' '#define MIXTAR_LESS_CONFIG_H' '#ifndef TCSASOFT' '#define TCSASOFT 0' '#endif' '#define SYSDIR \\042/etc\\042' '#define HELPDIR \\042/usr/share/misc\\042' '#endif' > Server/Userland/Generated/build/less/mixtar_less_config.h && "
        full_less = less_prefix + full
        dealloc(less_prefix)
        dealloc(full)
        full = full_less
    end
    if tool == "vi" then
        vi_prefix = "" + "mkdir -p Server/Userland/Generated/build/vi && tr -d '\\r' < Server/Userland/Toolkit/OpenBSD/src/usr.bin/vi/common/options.c | gawk -f Server/Userland/Toolkit/OpenBSD/src/usr.bin/vi/common/options.awk > Server/Userland/Generated/build/vi/options_def.h && tr -d '\\r' < Server/Userland/Toolkit/OpenBSD/src/usr.bin/vi/ex/ex_cmd.c | gawk -f Server/Userland/Toolkit/OpenBSD/src/usr.bin/vi/ex/ex.awk > Server/Userland/Generated/build/vi/ex_def.h && cp Server/Userland/Toolkit/OpenBSD/src/usr.bin/vi/build/config.h Server/Userland/Generated/build/vi/config.h && printf '%s\\n' '#undef _PATH_PRESERVE' > Server/Userland/Generated/build/vi/pathnames.h && cat Server/Userland/Toolkit/OpenBSD/src/usr.bin/vi/build/pathnames.h >> Server/Userland/Generated/build/vi/pathnames.h && "
        full_vi = vi_prefix + full
        dealloc(vi_prefix)
        dealloc(full)
        full = full_vi
    end
    if tool == "diff3" then
        dealloc(full)
        full = "" + "mkdir -p Server/Userland/Generated/targets/linux-x64/bin Server/Userland/Generated/targets/linux-x64/libexec && cc -std=c23 -Wall -Wextra -Werror -pedantic -D_GNU_SOURCE -D_DEFAULT_SOURCE -DMIXTAR_BRIDGE=1 -I Server/Userland/Toolkit/Bridge/include -include Server/Userland/Toolkit/Bridge/include/mixtar_bridge_compat.h -Wno-sign-compare -o Server/Userland/Generated/targets/linux-x64/libexec/diff3prog Server/Userland/Toolkit/OpenBSD/src/usr.bin/diff3/diff3prog.c Server/Runtime/LibC/Generated/bsd_compat.c && cp Server/Userland/Toolkit/Bridge/scripts/diff3 Server/Userland/Generated/targets/linux-x64/bin/diff3 && chmod +x Server/Userland/Generated/targets/linux-x64/bin/diff3"
    end
    if tool == "nm" then
        dealloc(full)
        full = "" + "mkdir -p Server/Userland/Generated/build/nm Server/Userland/Generated/targets/linux-x64/bin && cc -std=c23 -Wall -Wextra -Werror -pedantic -D_GNU_SOURCE -D_DEFAULT_SOURCE -DMIXTAR_BRIDGE=1 -DMIXTAR_NM_COMPAT=1 -I Server/Userland/Toolkit/Bridge/include -include Server/Userland/Toolkit/Bridge/include/mixtar_bridge_compat.h -Wno-sign-compare -Wno-unused-parameter -Wno-format -Wno-pedantic -Wno-old-style-definition -Wno-missing-field-initializers -Wno-implicit-fallthrough -Wno-pointer-sign -DELFSIZE=32 -c Server/Userland/Toolkit/OpenBSD/src/usr.bin/nm/elf.c -o Server/Userland/Generated/build/nm/elf32.o && cc -std=c23 -Wall -Wextra -Werror -pedantic -D_GNU_SOURCE -D_DEFAULT_SOURCE -DMIXTAR_BRIDGE=1 -DMIXTAR_NM_COMPAT=1 -I Server/Userland/Toolkit/Bridge/include -include Server/Userland/Toolkit/Bridge/include/mixtar_bridge_compat.h -Wno-sign-compare -Wno-unused-parameter -Wno-format -Wno-pedantic -Wno-old-style-definition -Wno-missing-field-initializers -Wno-implicit-fallthrough -Wno-pointer-sign -DELFSIZE=64 -c Server/Userland/Toolkit/OpenBSD/src/usr.bin/nm/elf.c -o Server/Userland/Generated/build/nm/elf64.o && cc -std=c23 -Wall -Wextra -Werror -pedantic -D_GNU_SOURCE -D_DEFAULT_SOURCE -DMIXTAR_BRIDGE=1 -DMIXTAR_NM_COMPAT=1 -I Server/Userland/Toolkit/Bridge/include -include Server/Userland/Toolkit/Bridge/include/mixtar_bridge_compat.h -Wno-sign-compare -Wno-unused-parameter -Wno-format -Wno-pedantic -Wno-old-style-definition -Wno-missing-field-initializers -Wno-implicit-fallthrough -Wno-pointer-sign -c Server/Userland/Toolkit/OpenBSD/src/usr.bin/nm/nm.c -o Server/Userland/Generated/build/nm/nm.o && cc -o Server/Userland/Generated/targets/linux-x64/bin/nm Server/Userland/Generated/build/nm/nm.o Server/Userland/Generated/build/nm/elf32.o Server/Userland/Generated/build/nm/elf64.o Server/Runtime/LibC/Generated/bsd_compat.c -lm -lutil"
    end
    dealloc(src, target)
    return full
end

string toolkit_compile_command(tool: string):
    raw = toolkit_compile_command_raw(tool)
    normalized = toolkit_normalize_openbsd_roots(raw)
    dealloc(raw)
    return normalized
end

string toolkit_wsl_command(tool: string):
    compile = toolkit_compile_command(tool)
    prefix = "" + "wsl.exe -d Debian -- bash -lc \"mkdir -p Server/Userland/Generated/targets/linux-x64/bin && "
    body = prefix + compile
    dealloc(prefix)
    full = body + "\""
    dealloc(body)
    dealloc(compile)
    return full
end

string toolkit_wsl_script_command(tool: string):
    script_path = toolkit_test_path(tool)
    prefix = "" + "wsl.exe -d Debian -- bash "
    cmd = prefix + script_path
    dealloc(prefix)
    dealloc(script_path)
    return cmd
end
