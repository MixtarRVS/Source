string toolkit_source(tool: string):
    if toolkit_hosted_tool(tool) == 1 then
        return "" + "Server/Userland/Toolkit/Bridge/scripts/hosted_common"
    end
    openbsd = toolkit_openbsd_source(tool)
    if openbsd != "" then
        if file_exists(openbsd) == 1 then
            return openbsd
        end
    end
    dealloc(openbsd)
    return toolkit_freebsd_source(tool)
end

string toolkit_compile_sources(tool: string):
    match tool then
        case "cp":
            return "" + "Server/Userland/Toolkit/FreeBSD/freebsd-src/bin/cp/cp.c Server/Userland/Toolkit/FreeBSD/freebsd-src/bin/cp/utils.c"
        case "ls":
