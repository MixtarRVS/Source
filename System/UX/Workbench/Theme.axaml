<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Mixtar HIG tokens and control styles - the single source of
       visual truth (Product/HIG.md is the written contract). -->
  <Styles.Resources>
    <!-- EVERY chrome color lives here (jeden plik ze zmiennymi). Markup and
         code-behind reference these tokens only; Theme.config overrides
         them by mutating the shared instances. Shadows, wallpaper art and
         terminal-output colors are content, not chrome - they stay local. -->
    <!-- Surfaces -->
    <SolidColorBrush x:Key="DesktopBrush" Color="#0B1220" />
    <SolidColorBrush x:Key="FrameBrush" Color="#D914161A" />
    <SolidColorBrush x:Key="ClientBrush" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="ClientBorderBrush" Color="#FF000000" />
    <SolidColorBrush x:Key="PanelBrush" Color="#D914161A" />
    <SolidColorBrush x:Key="PanelSoftBrush" Color="#E6191B20" />
    <SolidColorBrush x:Key="MenuBrush" Color="#F214161A" />
    <SolidColorBrush x:Key="OverlayBrush" Color="#F514161A" />
    <SolidColorBrush x:Key="CardBrush" Color="#E01B1E24" />
    <SolidColorBrush x:Key="HeaderBackBrush" Color="#E61A1D22" />
    <SolidColorBrush x:Key="SidebarBrush" Color="#3D0F1114" />
    <SolidColorBrush x:Key="StatusBackBrush" Color="#520A0C0F" />
    <SolidColorBrush x:Key="TerminalBackBrush" Color="#F20E1013" />
    <SolidColorBrush x:Key="ConsoleBackBrush" Color="#F5111316" />
    <SolidColorBrush x:Key="TaskbarBrush" Color="#F0121418" />
    <SolidColorBrush x:Key="InputBackBrush" Color="#80000000" />
    <SolidColorBrush x:Key="InputSoftBrush" Color="#D31E2126" />
    <SolidColorBrush x:Key="ToolBackBrush" Color="#B2262A31" />
    <SolidColorBrush x:Key="NetMapBrush" Color="#F0020711" />
    <SolidColorBrush x:Key="HudBrush" Color="#F5061125" />
    <!-- Text -->
    <SolidColorBrush x:Key="TextBrush" Color="#E8EEF7" />
    <SolidColorBrush x:Key="TitleBrush" Color="#CFD8E6" />
    <SolidColorBrush x:Key="MonoBrush" Color="#C4DCFF" />
    <SolidColorBrush x:Key="HeadingBrush" Color="#8FC1FF" />
    <SolidColorBrush x:Key="InfoBrush" Color="#91B7E8" />
    <SolidColorBrush x:Key="SoftBrush" Color="#9EC1EF" />
    <SolidColorBrush x:Key="ListTextBrush" Color="#D8E7FF" />
    <SolidColorBrush x:Key="TabTextBrush" Color="#A9B4C4" />
    <SolidColorBrush x:Key="TabActiveTextBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CaptionGlyphBrush" Color="#FFDFDFDF" />
    <SolidColorBrush x:Key="CaptionHoverGlyphBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CaptionCloseGlyphBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MutedBrush" Color="#668AB9" />
    <SolidColorBrush x:Key="FrameTextBrush" Color="#CFD8E6" />
    <SolidColorBrush x:Key="FrameHeadingBrush" Color="#8FC1FF" />
    <SolidColorBrush x:Key="FrameMutedBrush" Color="#668AB9" />
    <SolidColorBrush x:Key="FrameMonoBrush" Color="#C4DCFF" />
    <SolidColorBrush x:Key="FrameDividerBrush" Color="#20FFFFFF" />
    <SolidColorBrush x:Key="MenuBorderBrush" Color="#FF14161A" />
    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#27EE91" />
    <SolidColorBrush x:Key="SuccessDimBrush" Color="#9ED8C6" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FFC65C" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="#FFE3AC" />
    <SolidColorBrush x:Key="WarningBackBrush" Color="#40FFC65C" />
    <SolidColorBrush x:Key="DangerBrush" Color="#FF5C7B" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#B0FF5C7B" />
    <!-- Accent and selection -->
    <SolidColorBrush x:Key="AccentBrush" Color="#18B9FF" />
    <SolidColorBrush x:Key="SnapFillBrush" Color="#2618B9FF" />
    <SolidColorBrush x:Key="SnapBorderBrush" Color="#8018B9FF" />
    <SolidColorBrush x:Key="RowHoverBrush" Color="#273580DB" />
    <SolidColorBrush x:Key="RowSelectedBrush" Color="#473580DB" />
    <SolidColorBrush x:Key="TextSelectionBrush" Color="#703580DB" />
    <SolidColorBrush x:Key="TaskActiveBrush" Color="#363568DB" />
    <SolidColorBrush x:Key="TaskActiveBorderBrush" Color="#704C97FF" />
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#293A7EE6" />
    <SolidColorBrush x:Key="TabHoverBrush" Color="#0DFFFFFF" />
    <SolidColorBrush x:Key="TabActiveBrush" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="HoverWashBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="StartBrush" Color="#0B65D8" />
    <SolidColorBrush x:Key="StartBorderBrush" Color="#5EA8FF" />
    <SolidColorBrush x:Key="GridLineBrush" Color="#202569D2" />
    <!-- Lines -->
    <SolidColorBrush x:Key="StrokeBrush" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="StrokeStrongBrush" Color="#4DFFFFFF" />
    <SolidColorBrush x:Key="HairlineBrush" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="DividerBrush" Color="#20FFFFFF" />
    <SolidColorBrush x:Key="FrameStrokeBrush" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="FrameStrokeStrongBrush" Color="#4DFFFFFF" />
    <SolidColorBrush x:Key="FrameHairlineBrush" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="CommandBarBorderBrush" Color="#FF333333" />
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="#FF333333" />
    <SolidColorBrush x:Key="RowLineBrush" Color="#0EFFFFFF" />
    <SolidColorBrush x:Key="TrackBrush" Color="#17FFFFFF" />
    <SolidColorBrush x:Key="GripBrush" Color="#4CFFFFFF" />
    <SolidColorBrush x:Key="PaneBorderBrush" Color="#344B97FF" />
    <SolidColorBrush x:Key="FrameBorderBrush" Color="#4C4796FF" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#425FA2FF" />
    <SolidColorBrush x:Key="ToolBorderBrush" Color="#47FFFFFF" />
    <SolidColorBrush x:Key="NetLineBrush" Color="#416FA8E8" />
    <SolidColorBrush x:Key="NetLineFaintBrush" Color="#244B79B6" />
    <!-- Flat caption interaction colors. Mode-specific values are supplied
         by MainWindow.Theme.cs and remain configurable through Theme.config. -->
    <SolidColorBrush x:Key="CaptionHoverBrush" Color="#FF4388CC" />
    <SolidColorBrush x:Key="CaptionCloseHoverBrush" Color="#FFD34031" />
    <SolidColorBrush x:Key="CaptionPressedBrush" Color="#FF1A3957" />
  </Styles.Resources>

    <Style Selector="Border.desktop-window">
      <Setter Property="Background" Value="{StaticResource FrameBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource FrameStrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6,0,6,6" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="BoxShadow" Value="inset 0 1 1 0 #1AFFFFFF, 0 15 35 0 #99000000" />
    </Style>
    <Style Selector="Border.desktop-window.active">
      <Setter Property="BorderBrush" Value="{StaticResource FrameStrokeStrongBrush}" />
      <Setter Property="BoxShadow" Value="inset 0 1 1 0 #26FFFFFF, 0 18 42 0 #B3000000" />
    </Style>
    <Style Selector="Border.app-client">
      <Setter Property="Background" Value="{StaticResource ClientBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ClientBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.titlebar">
      <Setter Property="Height" Value="42" />
      <Setter Property="Background" Value="{StaticResource FrameBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource FrameHairlineBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="10,0,0,0" />
    </Style>
    <Style Selector="TextBlock.window-title">
      <Setter Property="Foreground" Value="{StaticResource CaptionGlyphBrush}" />
      <Setter Property="FontFamily" Value="Noto Sans" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="LetterSpacing" Value="0.6" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <!-- Caption buttons keep the Studio geometry but use modern flat hover
         colors instead of the reference's 2008-style gradients. -->
    <Style Selector="Button.window-dot">
      <Setter Property="Width" Value="46" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="46" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource TitleBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontFamily" Value="Noto Sans" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.window-dot:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource CaptionHoverGlyphBrush}" />
      <Setter Property="Background" Value="{DynamicResource CaptionHoverBrush}" />
    </Style>
    <Style Selector="Button.window-dot.close:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource CaptionCloseGlyphBrush}" />
      <Setter Property="Background" Value="{DynamicResource CaptionCloseHoverBrush}" />
    </Style>
    <Style Selector="Button.window-dot.min:pointerover">
      <Setter Property="BorderBrush" Value="#1AFFFFFF" />
      <Setter Property="BorderThickness" Value="1,0,0,0" />
    </Style>
    <Style Selector="Button.window-dot.max:pointerover">
      <Setter Property="BorderBrush" Value="#1AFFFFFF" />
      <Setter Property="BorderThickness" Value="1,0,0,0" />
    </Style>
    <Style Selector="Button.window-dot:pressed">
      <Setter Property="Background" Value="{DynamicResource CaptionPressedBrush}" />
    </Style>
    <!-- Caption glyphs as vectors, 1:1 from the Studio spec: one shared
         10x10 viewBox, stroke 1.5, no fill. The minimize dash (y 8-9)
         ends exactly on the bottom edge of the box and the cross - the
         Aero baseline. Vectors also sidestep the guest font missing ✕. -->
    <Style Selector="Button.window-dot.min">
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
            <Path Width="10" Height="10" Stretch="None" Data="M 1,8 L 9,8 L 9,9 L 1,9 Z"
                  Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.window-dot.max">
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
            <Path Width="10" Height="10" Stretch="None" Data="M 1,1 L 9,1 L 9,9 L 1,9 Z"
                  Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.window-dot.close">
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
            <Path Width="10" Height="10" Stretch="None" Data="M 1,1 L 9,9 M 9,1 L 1,9"
                  Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <!-- Maximized state: restore glyph 1:1 from the Studio QML spec -
         11x11 box, two 8x8 squares with hairline 1px strokes; the back
         square (top-right) is drawn only where the front one (bottom-left)
         does not occlude it. -->
    <Style Selector="Button.window-dot.max.restore">
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
            <Canvas Width="11" Height="11" HorizontalAlignment="Center" VerticalAlignment="Center">
              <Path Data="M 3.5,3 L 3.5,0.5 L 10.5,0.5 L 10.5,7.5 L 8,7.5"
                    Stroke="{TemplateBinding Foreground}" StrokeThickness="1" />
              <Border Canvas.Left="0" Canvas.Top="3" Width="8" Height="8"
                      BorderBrush="{TemplateBinding Foreground}" BorderThickness="1" />
            </Canvas>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.tool">
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Background" Value="{StaticResource ToolBackBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ToolBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tool:pointerover"><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></Style>
    <Style Selector="Button.tool.danger"><Setter Property="BorderBrush" Value="{StaticResource DangerSoftBrush}" /></Style>
    <Style Selector="Button.nav-arrow">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Opacity" Value="0.6" />
    </Style>
    <Style Selector="Button.nav-arrow:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.tree">
      <Setter Property="Height" Value="28" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Foreground" Value="{DynamicResource ListTextBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tree:pointerover"><Setter Property="Background" Value="{StaticResource ItemHoverBrush}" /></Style>
    <Style Selector="Button.tree.active">
      <Setter Property="Background" Value="{StaticResource RowSelectedBrush}" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.column-header">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Foreground" Value="{StaticResource HeadingBrush}" />
      <Setter Property="FontFamily" Value="Noto Sans Mono" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.column-header:pointerover"><Setter Property="Foreground" Value="{StaticResource TextBrush}" /></Style>
    <Style Selector="Button.crumb">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Foreground" Value="{StaticResource ListTextBrush}" />
      <Setter Property="FontFamily" Value="Noto Sans Mono" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.crumb:pointerover">
      <Setter Property="Background" Value="{StaticResource ItemHoverBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <!-- Titlebar tabs: uniform-width 32px pills sharing one vertical axis
         with the + button and the caption buttons (user decision 19.07). -->
    <Style Selector="Button.file-tab">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="16,6" />
      <Setter Property="CornerRadius" Value="6,6,0,0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TabTextBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Bottom" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}"
                  ClipToBounds="True">
            <ContentPresenter Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.file-tab:pointerover">
      <Setter Property="Background" Value="{DynamicResource TabHoverBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.file-tab.active">
      <Setter Property="Background" Value="{DynamicResource TabActiveBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TabActiveTextBrush}" />
    </Style>
    <Style Selector="Button.file-tab.active:pointerover">
      <Setter Property="Background" Value="{DynamicResource TabActiveBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TabActiveTextBrush}" />
    </Style>
    <Style Selector="Button.tab-add">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="6,6,0,0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TabTextBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="VerticalAlignment" Value="Bottom" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}"
                  ClipToBounds="True">
            <ContentPresenter Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.tab-add:pointerover">
      <Setter Property="Background" Value="{DynamicResource TabHoverBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.tab-close">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
            <Path Width="8" Height="8" Stretch="None" Data="M 1,1 L 7,7 M 7,1 L 1,7"
                  Stroke="{TemplateBinding Foreground}" StrokeThickness="1.2"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.tab-close:pointerover">
      <Setter Property="Background" Value="{StaticResource HoverWashBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.task">
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Foreground" Value="{DynamicResource FrameTextBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.task:pointerover">
      <Setter Property="Background" Value="{DynamicResource HoverWashBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource FrameHairlineBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource FrameTextBrush}" />
    </Style>
    <Style Selector="Button.task.active">
      <Setter Property="Background" Value="{DynamicResource TaskActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TaskActiveBorderBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.task.active:pointerover">
      <Setter Property="Background" Value="{DynamicResource TaskActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TaskActiveBorderBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.task:pressed">
      <Setter Property="Background" Value="{DynamicResource TaskActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TaskActiveBorderBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.task.minimized"><Setter Property="Opacity" Value="0.55" /></Style>
    <Style Selector="Button.task.minimized:pointerover"><Setter Property="Opacity" Value="1" /></Style>
    <Style Selector="Button.start">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="Background" Value="{StaticResource StartBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource StartBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.start:pointerover">
      <Setter Property="Background" Value="{DynamicResource StartBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StartBorderBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.start:pressed">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.hud-item">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Foreground" Value="{DynamicResource FrameTextBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.hud-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource HoverWashBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource FrameHairlineBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.hud-item:pressed">
      <Setter Property="Background" Value="{DynamicResource TaskActiveBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TaskActiveBorderBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <!-- The visual stays a 12px dot; the button around it is a 24x24
         transparent hit area (HIG minimum click target). -->
    <Style Selector="Button.map-node">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="{StaticResource MutedBrush}" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="Transparent">
            <Border Width="12" Height="12" CornerRadius="6"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{TemplateBinding Background}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.map-node.local"><Setter Property="Background" Value="{StaticResource WarningBrush}" /></Style>
    <Style Selector="Button.map-node.selected"><Setter Property="Background" Value="White" /></Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{StaticResource CardBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="7" />
    </Style>
    <Style Selector="Border.file-row">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="BorderBrush" Value="{StaticResource RowLineBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Border.file-row:pointerover"><Setter Property="Background" Value="{StaticResource RowHoverBrush}" /></Style>
    <Style Selector="Border.file-row.selected">
      <Setter Property="Background" Value="{StaticResource RowSelectedBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="3,0,0,1" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Background" Value="{StaticResource InputBackBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
      <Setter Property="SelectionBrush" Value="{StaticResource TextSelectionBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.start">
      <Setter Property="Foreground" Value="{StaticResource FrameTextBrush}" />
    </Style>
    <Style Selector="Button.task">
      <Setter Property="Foreground" Value="{StaticResource FrameTextBrush}" />
    </Style>
    <Style Selector="Button.hud-item">
      <Setter Property="Foreground" Value="{StaticResource FrameTextBrush}" />
    </Style>
  <!-- Prevent Fluent interaction states from replacing Mixtar's palette. -->
  <Style Selector="TextBox:pointerover">
    <Setter Property="Background" Value="{DynamicResource InputBackBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="TextBox:focus">
    <Setter Property="Background" Value="{DynamicResource InputBackBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="TextBox:focus-within">
    <Setter Property="Background" Value="{DynamicResource InputBackBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="Button.tool:pointerover">
    <Setter Property="Background" Value="{DynamicResource ToolBackBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="Button.tool:pressed">
    <Setter Property="Background" Value="{DynamicResource ItemHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="Button.crumb:pointerover">
    <Setter Property="Background" Value="{DynamicResource ItemHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="Button.tree:pointerover">
    <Setter Property="Background" Value="{DynamicResource ItemHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="TextBox.terminal-input">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource TextSelectionBrush}" />
  </Style>
  <Style Selector="TextBox.terminal-input:pointerover">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="TextBox.terminal-input:focus">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="TextBox.terminal-input:focus-within">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="TextBox.terminal-input /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
</Styles>
