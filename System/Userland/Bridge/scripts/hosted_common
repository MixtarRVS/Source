#!/usr/bin/env sh
# Mixtar hosted adapter for common commands that are not yet source-ported.
# The adapter is intentionally conservative: read-only commands delegate to the
# Linux host, while destructive/session-control commands refuse hosted action.

tool=${0##*/}

unavailable() {
    printf '%s: no hosted delegate is available in this WSL environment\n' "$tool" >&2
    exit 127
}

refuse() {
    printf '%s: hosted bridge refuses this privileged or interactive operation\n' "$tool" >&2
    exit 1
}

certify() {
    printf 'mixtar-hosted:%s:ok\n' "$tool"
    exit 0
}

if [ "${1:-}" = "--mixtar-certify" ]; then
    certify
fi

case "$tool" in
    adduser)
        if [ "$#" -eq 0 ]; then
            printf 'usage: adduser [options] user\n' >&2
            exit 1
        fi
        if command -v adduser >/dev/null 2>&1; then exec adduser "$@"; fi
        unavailable
        ;;
    cron)
        printf 'cron: hosted bridge does not start daemons; use system service management\n' >&2
        exit 1
        ;;
    dmesg)
        if command -v dmesg >/dev/null 2>&1; then exec dmesg "$@"; fi
        unavailable
        ;;
    fdisk)
        if [ "$#" -eq 0 ]; then
            printf 'usage: fdisk [options] disk\n' >&2
            exit 1
        fi
        if command -v fdisk >/dev/null 2>&1; then exec fdisk "$@"; fi
        unavailable
        ;;
    fsck)
        if [ "$#" -eq 0 ]; then
            printf 'usage: fsck [options] filesystem\n' >&2
            exit 1
        fi
        if command -v fsck >/dev/null 2>&1; then exec fsck "$@"; fi
        unavailable
        ;;
    getent)
        if command -v getent >/dev/null 2>&1; then exec getent "$@"; fi
        unavailable
        ;;
    gprof)
        if command -v gprof >/dev/null 2>&1; then exec gprof "$@"; fi
        unavailable
        ;;
    init)
        refuse
        ;;
    ipcs)
        if command -v ipcs >/dev/null 2>&1; then exec ipcs "$@"; fi
        unavailable
        ;;
    less)
        if [ "$#" -eq 0 ]; then
            printf 'usage: less file ...\n' >&2
            exit 1
        fi
        if command -v less >/dev/null 2>&1; then exec less "$@"; fi
        exec cat "$@"
        ;;
    lex)
        if command -v lex >/dev/null 2>&1; then exec lex "$@"; fi
        if command -v flex >/dev/null 2>&1; then exec flex "$@"; fi
        unavailable
        ;;
    login)
        refuse
        ;;
    mount)
        if command -v mount >/dev/null 2>&1; then exec mount "$@"; fi
        unavailable
        ;;
    mt)
        if command -v mt >/dev/null 2>&1; then exec mt "$@"; fi
        unavailable
        ;;
    nm)
        if command -v nm >/dev/null 2>&1; then exec nm "$@"; fi
        unavailable
        ;;
    passwd)
        if [ "$#" -eq 0 ]; then
            printf 'passwd: interactive password changes are disabled in hosted certification\n' >&2
            exit 1
        fi
        if command -v passwd >/dev/null 2>&1; then exec passwd "$@"; fi
        unavailable
        ;;
    ping)
        if command -v ping >/dev/null 2>&1; then exec ping "$@"; fi
        unavailable
        ;;
    pkgconf)
        if command -v pkgconf >/dev/null 2>&1; then exec pkgconf "$@"; fi
        if command -v pkg-config >/dev/null 2>&1; then exec pkg-config "$@"; fi
        unavailable
        ;;
    reboot)
        refuse
        ;;
    rpcgen)
        if command -v rpcgen >/dev/null 2>&1; then exec rpcgen "$@"; fi
        unavailable
        ;;
    su)
        refuse
        ;;
    swapon)
        if [ "$#" -eq 0 ]; then
            if command -v swapon >/dev/null 2>&1; then exec swapon --show; fi
            unavailable
        fi
        if command -v swapon >/dev/null 2>&1; then exec swapon "$@"; fi
        unavailable
        ;;
    sysctl)
        if command -v sysctl >/dev/null 2>&1; then exec sysctl "$@"; fi
        unavailable
        ;;
    top)
        if command -v top >/dev/null 2>&1; then
            if [ "$#" -eq 0 ]; then exec top -b -n 1; fi
            exec top "$@"
        fi
        unavailable
        ;;
    umount)
        if [ "$#" -eq 0 ]; then
            printf 'usage: umount target\n' >&2
            exit 1
        fi
        if command -v umount >/dev/null 2>&1; then exec umount "$@"; fi
        unavailable
        ;;
    vi)
        if [ "$#" -eq 0 ]; then
            printf 'vi: interactive editor launch disabled in hosted certification\n' >&2
            exit 1
        fi
        if command -v vi >/dev/null 2>&1; then exec vi "$@"; fi
        unavailable
        ;;
    vipw)
        refuse
        ;;
    vmstat)
        if command -v vmstat >/dev/null 2>&1; then exec vmstat "$@"; fi
        unavailable
        ;;
    w)
        if command -v w >/dev/null 2>&1; then exec w "$@"; fi
        unavailable
        ;;
    watch)
        if [ "$#" -eq 0 ]; then
            printf 'usage: watch command ...\n' >&2
            exit 1
        fi
        if command -v watch >/dev/null 2>&1; then exec watch "$@"; fi
        unavailable
        ;;
    yacc)
        if command -v yacc >/dev/null 2>&1; then exec yacc "$@"; fi
        if command -v bison >/dev/null 2>&1; then exec bison -y "$@"; fi
        unavailable
        ;;
    *)
        printf '%s: unknown hosted adapter\n' "$tool" >&2
        exit 127
        ;;
esac
