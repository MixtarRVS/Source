// toolkit_compat_tests.ail
// WSL compatibility smoke-test generation for Toolkit builds.

import toolkit_core

string toolkit_test_script(tool: string):
    target = toolkit_target(tool)
    report_path = toolkit_test_report_path(tool)
    body = "" + "#!/usr/bin/env bash\nset +e\nexport LC_ALL=C\ncd /mnt/c/Users/V/source/repos/MixtarRVS || exit 99\n"
    body2 = body + "target=\""
    dealloc(body)
    body3 = body2 + target
    dealloc(body2)
    body4 = body3 + "\"\ntarget=\"$PWD/$target\"\nreport=\""
    dealloc(body3)
    body5 = body4 + report_path
    dealloc(body4)
    body6 = body5 + "\"\nfailures=0\nmkdir -p \"$(dirname \"$report\")\"\nprintf '# "
    dealloc(body5)
    body7 = body6 + tool
    dealloc(body6)
    body8 = body7 + " WSL Compatibility Report\\n\\n' > \"$report\"\nprintf 'Generated target: `%s`\\n\\n' \"$target\" >> \"$report\"\n"
    dealloc(body7)

    if tool == "echo" then
        body9 = body8 + "compare_stdout() { name=\"$1\"; shift; \"$target\" \"$@\" > /tmp/mixtar-tool.out; trc=$?; /usr/bin/echo \"$@\" > /tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS %s\\n' \"$name\" >> \"$report\"; else printf -- '- FAIL %s\\n' \"$name\" >> \"$report\"; failures=$((failures+1)); fi; }\n"
        dealloc(body8)
        body10 = body9 + "compare_stdout basic hello world\ncompare_stdout dashdash -- not-an-option\n"
        dealloc(body9)
        body11 = body10 + "printf -- '\\nNote: FreeBSD echo intentionally differs from GNU echo for bare `\\\\c`; GNU parity is not required.\\n' >> \"$report\"\n"
        dealloc(body10)
        body12 = body11 + "exit \"$failures\"\n"
        dealloc(body11)
        dealloc(target, report_path)
        return body12
    end

    if tool == "cat" then
        body9 = body8 + "printf 'alpha\\nbeta\\n' >/tmp/mixtar-cat.in\n\"$target\" /tmp/mixtar-cat.in >/tmp/mixtar-tool.out; trc=$?; /usr/bin/cat /tmp/mixtar-cat.in >/tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS cat file stdout\\n' >> \"$report\"; else printf -- '- FAIL cat file stdout generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nprintf 'stdin-data\\n' | \"$target\" >/tmp/mixtar-tool.out; trc=$?; printf 'stdin-data\\n' | /usr/bin/cat >/tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS cat stdin stdout\\n' >> \"$report\"; else printf -- '- FAIL cat stdin stdout generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\n\"$target\" /tmp/mixtar-cat-missing >/tmp/mixtar-tool.out 2>/tmp/mixtar-tool.err; trc=$?; /usr/bin/cat /tmp/mixtar-cat-missing >/tmp/native-tool.out 2>/tmp/native-tool.err; nrc=$?; if [ \"$trc\" != 0 ] && [ \"$nrc\" != 0 ] && grep -qi 'No such file' /tmp/mixtar-tool.err; then printf -- '- PASS cat missing file error\\n' >> \"$report\"; else printf -- '- FAIL cat missing file generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nprintf -- '\\nNote: `BOOTSTRAP_CAT` limits this first conversion to raw cat behavior.\\n' >> \"$report\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "pwd" then
        body9 = body8 + "\"$target\" > /tmp/mixtar-tool.out; trc=$?; /usr/bin/pwd > /tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS pwd\\n' >> \"$report\"; else printf -- '- FAIL pwd\\n' >> \"$report\"; failures=$((failures+1)); fi\n"
        dealloc(body8)
        body10 = body9 + "\"$target\" -P > /tmp/mixtar-tool.out; trc=$?; /usr/bin/pwd -P > /tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS pwd -P\\n' >> \"$report\"; else printf -- '- FAIL pwd -P\\n' >> \"$report\"; failures=$((failures+1)); fi\nexit \"$failures\"\n"
        dealloc(body9)
        dealloc(target, report_path)
        return body10
    end

    if tool == "true" then
        body9 = body8 + "\"$target\"; trc=$?; /usr/bin/true; nrc=$?; if [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS true exit code %s\\n' \"$trc\" >> \"$report\"; else printf -- '- FAIL true generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "false" then
        body9 = body8 + "\"$target\"; trc=$?; /usr/bin/false; nrc=$?; if [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS false exit code %s\\n' \"$trc\" >> \"$report\"; else printf -- '- FAIL false generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "mkdir" then
        body9 = body8 + "check_mode() { label=\"$1\"; mode_arg=\"$2\"; expected=\"$3\"; tmp=\"/tmp/mixtar-mkdir-$$-$label\"; rm -rf \"$tmp\"; \"$target\" -m \"$mode_arg\" \"$tmp\"; rc=$?; actual=$(stat -c '%a' \"$tmp\" 2>/dev/null); rm -rf \"$tmp\"; if [ \"$rc\" = 0 ] && [ \"$actual\" = \"$expected\" ]; then printf -- '- PASS mkdir -m %s => %s\\n' \"$mode_arg\" \"$actual\" >> \"$report\"; else printf -- '- FAIL mkdir -m %s rc=%s actual=%s expected=%s\\n' \"$mode_arg\" \"$rc\" \"$actual\" \"$expected\" >> \"$report\"; failures=$((failures+1)); fi; }\ntmp=\"/tmp/mixtar-mkdir-$$\"\nrm -rf \"$tmp\"\n\"$target\" \"$tmp\"; rc1=$?; [ -d \"$tmp\" ]; exists=$?; /usr/bin/rmdir \"$tmp\" 2>/dev/null\nif [ \"$rc1\" = 0 ] && [ \"$exists\" = 0 ]; then printf -- '- PASS mkdir basic\\n' >> \"$report\"; else printf -- '- FAIL mkdir basic rc=%s exists=%s\\n' \"$rc1\" \"$exists\" >> \"$report\"; failures=$((failures+1)); fi\nrm -rf \"$tmp\"\n\"$target\" -p \"$tmp/a/b\"; rc2=$?; [ -d \"$tmp/a/b\" ]; exists2=$?; rm -rf \"$tmp\"\nif [ \"$rc2\" = 0 ] && [ \"$exists2\" = 0 ]; then printf -- '- PASS mkdir -p\\n' >> \"$report\"; else printf -- '- FAIL mkdir -p rc=%s exists=%s\\n' \"$rc2\" \"$exists2\" >> \"$report\"; failures=$((failures+1)); fi\ncheck_mode octal-700 700 700\ncheck_mode symbolic-user-only 'u=rwx,go=' 700\ncheck_mode symbolic-add-user-write 'a=rx,u+w' 755\ncheck_mode symbolic-X 'a=rX' 555\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "rmdir" then
        body9 = body8 + "tmp=\"/tmp/mixtar-rmdir-$$\"\nrm -rf \"$tmp\"\n/usr/bin/mkdir -p \"$tmp\"\n\"$target\" \"$tmp\"; rc1=$?; [ ! -e \"$tmp\" ]; gone=$?\nif [ \"$rc1\" = 0 ] && [ \"$gone\" = 0 ]; then printf -- '- PASS rmdir basic\\n' >> \"$report\"; else printf -- '- FAIL rmdir basic rc=%s gone=%s\\n' \"$rc1\" \"$gone\" >> \"$report\"; failures=$((failures+1)); fi\nrm -rf \"$tmp\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "cp" then
        body9 = body8 + "tmp=\"/tmp/mixtar-cp-$$\"\nrm -rf \"$tmp\"\nmkdir -p \"$tmp\"\nprintf 'alpha\\nbeta\\n' > \"$tmp/src\"\n\"$target\" \"$tmp/src\" \"$tmp/dst\"; rc1=$?; if [ \"$rc1\" = 0 ] && cmp -s \"$tmp/src\" \"$tmp/dst\"; then printf -- '- PASS cp file copy\\n' >> \"$report\"; else printf -- '- FAIL cp file copy rc=%s\\n' \"$rc1\" >> \"$report\"; failures=$((failures+1)); fi\n\"$target\" \"$tmp/missing\" \"$tmp/nope\" >/tmp/mixtar-cp.out 2>/tmp/mixtar-cp.err; rc2=$?; if [ \"$rc2\" != 0 ] && grep -qi 'No such file' /tmp/mixtar-cp.err; then printf -- '- PASS cp missing source error\\n' >> \"$report\"; else printf -- '- FAIL cp missing source rc=%s\\n' \"$rc2\" >> \"$report\"; failures=$((failures+1)); fi\nrm -rf \"$tmp\"\nprintf -- '\\nNote: ACL, MAC, flags, whiteout, and filesystem-specific metadata are Bridge-limited on Linux.\\n' >> \"$report\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "ls" then
        body9 = body8 + "tmp=\"/tmp/mixtar-ls-$$\"\nrm -rf \"$tmp\"\nmkdir -p \"$tmp\"\ntouch \"$tmp/a\" \"$tmp/b\"\n\"$target\" \"$tmp\" | sort >/tmp/mixtar-tool.out; trc=$?; /usr/bin/ls \"$tmp\" | sort >/tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS ls directory listing\\n' >> \"$report\"; else printf -- '- FAIL ls directory listing generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\n\"$target\" -1 \"$tmp\" | sort >/tmp/mixtar-tool.out; trc2=$?; /usr/bin/ls -1 \"$tmp\" | sort >/tmp/native-tool.out; nrc2=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc2\" = \"$nrc2\" ]; then printf -- '- PASS ls -1 directory listing\\n' >> \"$report\"; else printf -- '- FAIL ls -1 directory listing generated=%s native=%s\\n' \"$trc2\" \"$nrc2\" >> \"$report\"; failures=$((failures+1)); fi\nrm -rf \"$tmp\"\nprintf -- '\\nNote: ACL, MAC, birthtime, file flags, and BSD-specific display modes are Bridge-limited on Linux.\\n' >> \"$report\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "mv" then
        body9 = body8 + "tmp=\"/tmp/mixtar-mv-$$\"\nrm -rf \"$tmp\"\nmkdir -p \"$tmp\"\nprintf 'move-data\\n' > \"$tmp/src\"\n\"$target\" \"$tmp/src\" \"$tmp/dst\"; rc1=$?; if [ \"$rc1\" = 0 ] && [ ! -e \"$tmp/src\" ] && grep -qx 'move-data' \"$tmp/dst\"; then printf -- '- PASS mv rename file\\n' >> \"$report\"; else printf -- '- FAIL mv rename file rc=%s\\n' \"$rc1\" >> \"$report\"; failures=$((failures+1)); fi\n\"$target\" \"$tmp/missing\" \"$tmp/nope\" >/tmp/mixtar-mv.out 2>/tmp/mixtar-mv.err; rc2=$?; if [ \"$rc2\" != 0 ] && grep -qi 'No such file' /tmp/mixtar-mv.err; then printf -- '- PASS mv missing source error\\n' >> \"$report\"; else printf -- '- FAIL mv missing source rc=%s\\n' \"$rc2\" >> \"$report\"; failures=$((failures+1)); fi\nrm -rf \"$tmp\"\nprintf -- '\\nNote: cross-device fallback and metadata-preserving edges need broader fixtures.\\n' >> \"$report\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "rm" then
        body9 = body8 + "tmp=\"/tmp/mixtar-rm-$$\"\nrm -rf \"$tmp\"\nmkdir -p \"$tmp\"\nprintf 'remove-data\\n' > \"$tmp/file\"\n\"$target\" \"$tmp/file\"; rc1=$?; if [ \"$rc1\" = 0 ] && [ ! -e \"$tmp/file\" ]; then printf -- '- PASS rm file\\n' >> \"$report\"; else printf -- '- FAIL rm file rc=%s\\n' \"$rc1\" >> \"$report\"; failures=$((failures+1)); fi\n\"$target\" -f \"$tmp/missing\"; rc2=$?; if [ \"$rc2\" = 0 ]; then printf -- '- PASS rm -f missing\\n' >> \"$report\"; else printf -- '- FAIL rm -f missing rc=%s\\n' \"$rc2\" >> \"$report\"; failures=$((failures+1)); fi\nrm -rf \"$tmp\"\nprintf -- '\\nNote: recursive, interactive, whiteout, and undelete semantics need broader fixtures.\\n' >> \"$report\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "domainname" then
        body9 = body8 + "\"$target\" >/tmp/mixtar-tool.out 2>/tmp/mixtar-tool.err; trc=$?; /bin/domainname >/tmp/native-tool.out 2>/tmp/native-tool.err; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS domainname query\\n' >> \"$report\"; else printf -- '- FAIL domainname query generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nprintf -- '\\nNote: setting domain name usually requires privilege and is not certified here.\\n' >> \"$report\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "hostname" then
        body9 = body8 + "\"$target\" >/tmp/mixtar-tool.out 2>/tmp/mixtar-tool.err; trc=$?; /bin/hostname >/tmp/native-tool.out 2>/tmp/native-tool.err; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS hostname query\\n' >> \"$report\"; else printf -- '- FAIL hostname query generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nprintf -- '\\nNote: setting host name usually requires privilege and is not certified here.\\n' >> \"$report\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "realpath" then
        body9 = body8 + "tmp=\"/tmp/mixtar-realpath-$$\"\nrm -rf \"$tmp\"\nmkdir -p \"$tmp/a\"\ntouch \"$tmp/a/file\"\nln -s a \"$tmp/link\"\n\"$target\" \"$tmp/link/file\" >/tmp/mixtar-tool.out; trc=$?; /usr/bin/realpath \"$tmp/link/file\" >/tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS realpath symlink path\\n' >> \"$report\"; else printf -- '- FAIL realpath symlink path generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nrm -rf \"$tmp\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "sleep" then
        body9 = body8 + "start=$(date +%s)\n\"$target\" 0; trc=$?; /usr/bin/sleep 0; nrc=$?; if [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS sleep 0 exit code\\n' >> \"$report\"; else printf -- '- FAIL sleep 0 generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\n\"$target\" nope >/tmp/mixtar-sleep.out 2>/tmp/mixtar-sleep.err; rc2=$?; if [ \"$rc2\" != 0 ]; then printf -- '- PASS sleep invalid operand exits nonzero\\n' >> \"$report\"; else printf -- '- FAIL sleep invalid operand rc=%s\\n' \"$rc2\" >> \"$report\"; failures=$((failures+1)); fi\nend=$(date +%s)\nprintf -- '\\nElapsed wall seconds: %s\\n' \"$((end-start))\" >> \"$report\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "sync" then
        body9 = body8 + "\"$target\" >/tmp/mixtar-tool.out 2>/tmp/mixtar-tool.err; trc=$?; /bin/sync >/tmp/native-tool.out 2>/tmp/native-tool.err; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS sync no-argument behavior\\n' >> \"$report\"; else printf -- '- FAIL sync no-argument generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "chmod" then
        body9 = body8 + "tmp=\"/tmp/mixtar-chmod-$$\"\nrm -rf \"$tmp\"\nmkdir -p \"$tmp\"\ntouch \"$tmp/file\"\n\"$target\" 600 \"$tmp/file\"; rc1=$?; mode1=$(stat -c '%a' \"$tmp/file\" 2>/dev/null); if [ \"$rc1\" = 0 ] && [ \"$mode1\" = 600 ]; then printf -- '- PASS chmod octal 600\\n' >> \"$report\"; else printf -- '- FAIL chmod octal 600 rc=%s mode=%s\\n' \"$rc1\" \"$mode1\" >> \"$report\"; failures=$((failures+1)); fi\n\"$target\" u+x \"$tmp/file\"; rc2=$?; mode2=$(stat -c '%a' \"$tmp/file\" 2>/dev/null); if [ \"$rc2\" = 0 ] && [ \"$mode2\" = 700 ]; then printf -- '- PASS chmod symbolic u+x\\n' >> \"$report\"; else printf -- '- FAIL chmod symbolic u+x rc=%s mode=%s\\n' \"$rc2\" \"$mode2\" >> \"$report\"; failures=$((failures+1)); fi\nrm -rf \"$tmp\"\nprintf -- '\\nNote: recursive chmod and ACL-sensitive NFSv4 behavior are not certified yet.\\n' >> \"$report\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "test" then
        body9 = body8 + "compare_rc() { label=\"$1\"; shift; \"$target\" \"$@\" >/tmp/mixtar-test.out 2>/tmp/mixtar-test.err; trc=$?; /usr/bin/test \"$@\" >/tmp/native-test.out 2>/tmp/native-test.err; nrc=$?; if [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS %s rc=%s\\n' \"$label\" \"$trc\" >> \"$report\"; else printf -- '- FAIL %s generated=%s native=%s\\n' \"$label\" \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi; }\ntmp=\"/tmp/mixtar-test-$$\"\nrm -rf \"$tmp\"\nmkdir -p \"$tmp\"\ntouch \"$tmp/file\"\ncompare_rc 'test string equality true' alpha = alpha\ncompare_rc 'test string equality false' alpha = beta\ncompare_rc 'test file exists' -f \"$tmp/file\"\ncompare_rc 'test missing file' -f \"$tmp/missing\"\ncompare_rc 'test integer compare' 4 -lt 9\nrm -rf \"$tmp\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "env" then
        body9 = body8 + "\"$target\" -i MIXTAR_TIER=1 PATH=/bin:/usr/bin /usr/bin/env | sort >/tmp/mixtar-tool.out; trc=$?; /usr/bin/env -i MIXTAR_TIER=1 PATH=/bin:/usr/bin /usr/bin/env | sort >/tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS env clean environment command\\n' >> \"$report\"; else printf -- '- FAIL env clean environment command generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "dirname" then
        body9 = body8 + "\"$target\" /tmp/alpha/beta >/tmp/mixtar-tool.out; trc=$?; /usr/bin/dirname /tmp/alpha/beta >/tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS dirname basic path\\n' >> \"$report\"; else printf -- '- FAIL dirname basic path generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "basename" then
        body9 = body8 + "\"$target\" /tmp/alpha/beta.txt .txt >/tmp/mixtar-tool.out; trc=$?; /usr/bin/basename /tmp/alpha/beta.txt .txt >/tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS basename suffix removal\\n' >> \"$report\"; else printf -- '- FAIL basename suffix removal generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "head" then
        body9 = body8 + "printf 'one\\ntwo\\nthree\\n' >/tmp/mixtar-head.in\n\"$target\" -n 2 /tmp/mixtar-head.in >/tmp/mixtar-tool.out; trc=$?; /usr/bin/head -n 2 /tmp/mixtar-head.in >/tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS head -n 2\\n' >> \"$report\"; else printf -- '- FAIL head -n 2 generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "tee" then
        body9 = body8 + "tmp=\"/tmp/mixtar-tee-$$\"\nrm -rf \"$tmp\"\nmkdir -p \"$tmp\"\nprintf 'tee-data\\n' | \"$target\" \"$tmp/out\" >/tmp/mixtar-tool.out; trc=$?; if [ \"$trc\" = 0 ] && grep -qx 'tee-data' /tmp/mixtar-tool.out && grep -qx 'tee-data' \"$tmp/out\"; then printf -- '- PASS tee stdout and file\\n' >> \"$report\"; else printf -- '- FAIL tee stdout and file rc=%s\\n' \"$trc\" >> \"$report\"; failures=$((failures+1)); fi\nrm -rf \"$tmp\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "touch" then
        body9 = body8 + "tmp=\"/tmp/mixtar-touch-$$\"\nrm -rf \"$tmp\"\n\"$target\" \"$tmp\"; trc=$?; if [ \"$trc\" = 0 ] && [ -f \"$tmp\" ]; then printf -- '- PASS touch creates file\\n' >> \"$report\"; else printf -- '- FAIL touch creates file rc=%s\\n' \"$trc\" >> \"$report\"; failures=$((failures+1)); fi\nrm -f \"$tmp\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
    end

    if tool == "readlink" then
        body9 = body8 + "tmp=\"/tmp/mixtar-readlink-$$\"\nrm -rf \"$tmp\"\nmkdir -p \"$tmp\"\nln -s target-value \"$tmp/link\"\n\"$target\" \"$tmp/link\" >/tmp/mixtar-tool.out; trc=$?; /usr/bin/readlink \"$tmp/link\" >/tmp/native-tool.out; nrc=$?; if cmp -s /tmp/mixtar-tool.out /tmp/native-tool.out && [ \"$trc\" = \"$nrc\" ]; then printf -- '- PASS readlink symlink\\n' >> \"$report\"; else printf -- '- FAIL readlink symlink generated=%s native=%s\\n' \"$trc\" \"$nrc\" >> \"$report\"; failures=$((failures+1)); fi\nrm -rf \"$tmp\"\nexit \"$failures\"\n"
        dealloc(body8)
        dealloc(target, report_path)
        return body9
