end

int toolkit_write_test_script(tool: string):
    toolkit_ensure_dirs_for(tool)
    script = toolkit_test_script(tool)
    path = toolkit_test_path(tool)
    rc = write_file(path, script)
    dealloc(script, path)
    if rc == 0 then
        return 1
    end
    return 0
end
