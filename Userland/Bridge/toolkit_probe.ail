int toolkit_openbsd_probe_wsl():
    rc = toolkit_write_openbsd_probe_script()
    if rc != 0 then
        print "toolkit-build: failed to write OpenBSD auto-probe script"
        return rc
    end
    cmd = toolkit_openbsd_probe_wsl_command()
    print "toolkit-build: auto-probing mirrored OpenBSD Toolkit candidates"
    run_rc = system(cmd)
    dealloc(cmd)
    return run_rc
end
